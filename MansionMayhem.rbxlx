      <Item class="ModuleScript" referent="14">
        <Properties>
          <string name="Name">GameManager</string>
          <string name="Source"><![CDATA[-- ============================================================
-- GAME MANAGER — Core game loop for Mansion Mayhem Roblox
-- Manages seasons, daily events, voting, elimination, rooms
-- Day type state machine with phase transitions
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local ServerStorage = game:GetService("ServerStorage")
local TextService = game:GetService("TextService")

local SupabaseAPI = require(script.Parent.SupabaseAPI)
local Config = require(ReplicatedStorage.Shared.Config)
local VotingSystem = require(script.Parent.VotingSystem)
local EliminationSystem = require(script.Parent.EliminationSystem)
local FightSystem = require(script.Parent.FightSystem)
local AllianceSystem = require(script.Parent.AllianceSystem)
local QueenSystem = require(script.Parent.QueenSystem)
local ChallengeSystem = require(script.Parent.ChallengeSystem)
local ImmunitySystem = require(script.Parent.ImmunitySystem)
local MonetizationSystem = require(script.Parent.MonetizationSystem)
local NPCSystem = require(script.Parent.NPCSystem)
local AntiCheat = require(script.Parent.AntiCheat)
local DataStoreBackup = require(script.Parent.DataStoreBackup)
local BadgeSystem = require(script.Parent.BadgeSystem)

-- Private server detection
local isPrivateServer = game.PrivateServerId ~= "" and game.PrivateServerOwnerId ~= 0

local GameManager = {}
GameManager.seasonData = nil
GameManager.events = {}
GameManager.playerMap = {} -- Roblox UserId -> mansion player data
GameManager.currentPhase = "lobby"

-- Expose sub-systems for cross-references
GameManager.votingSystem = VotingSystem
GameManager.eliminationSystem = EliminationSystem
GameManager.fightSystem = FightSystem
GameManager.allianceSystem = AllianceSystem
GameManager.queenSystem = QueenSystem
GameManager.challengeSystem = ChallengeSystem
GameManager.immunitySystem = ImmunitySystem
GameManager.monetizationSystem = MonetizationSystem
GameManager.npcSystem = NPCSystem
GameManager.antiCheat = AntiCheat
GameManager.dataStoreBackup = DataStoreBackup
GameManager.badgeSystem = BadgeSystem

-- Day type state machine order
local DAY_PHASES = {
	"move_in",        -- Day 1: arrivals + room assignment
	"social",         -- Day 2: alliances form
	"challenge",      -- Day 3: main challenge
	"whisper",        -- Day 4: secrets + Director twists
	"confrontation",  -- Day 5: face-offs
	"deliberation",   -- Day 6: campaigning + last pleas
	"elimination",    -- Day 7: vote + someone goes home
}

-- ============================================================
-- INITIALIZATION
-- ============================================================

function GameManager.init()
	print("[GameManager] Starting Mansion Mayhem...")

	-- Create RemoteEvents for client communication
	local remotes = Instance.new("Folder")
	remotes.Name = "Remotes"
	remotes.Parent = ReplicatedStorage

	local events = {
		-- Existing
		"SeasonUpdate", "EventUpdate", "TeaWallUpdate",
		"DirectorAnnounce", "VoteStart", "VoteEnd",
		"RoomAssignment", "FightAlert", "CheckInResult",
		"PostConfession", "CastVote", "RequestCheckIn",
		"ScenarioUpdate", "LeaderboardUpdate",

		-- Voting
		"NominationStart", "NominationResult", "SubmitNomination",
		"VoteConfirm",

		-- Elimination
		"EliminationStart", "EliminationReveal", "EliminationComplete",
		"SpectatorMode",

		-- Fight
		"FightPrompt", "FightResolved", "StartFight",

		-- Alliance
		"AllianceInvite", "AllianceUpdate", "ProposeAlliance",
		"AcceptAlliance", "DeclineAlliance", "LeaveAlliance",

		-- Queen
		"QueenCrowned", "QueenApproval", "SubmitApproval",
		"QueenAssignRoom",

		-- Challenge
		"ChallengeList", "ChallengeUpdate", "AcceptChallenge",
		"GroupGoalUpdate",

		-- Immunity
		"ImmunityUpdate", "ImmunityAnnounce", "UseImmunityToken",

		-- Season info
		"SeasonInfoRequest", "SeasonInfoResponse",
		"LeaderboardRequest",

		-- Phase
		"PhaseUpdate",

		-- Effects & Camera
		"PlayEffect",
		"CameraControl",

		-- Error messaging
		"ErrorMessage",

		-- Bus system
		"BusCountdown",
		"BusCinematic",
		"BusArrive",
	}

	for _, name in events do
		local re = Instance.new("RemoteEvent")
		re.Name = name
		re.Parent = remotes
	end

	-- Load season data
	GameManager.loadSeason()

	-- Set up player connections
	Players.PlayerAdded:Connect(GameManager.onPlayerJoin)
	Players.PlayerRemoving:Connect(GameManager.onPlayerLeave)

	-- Wire client->server event handlers
	GameManager._wireClientEvents(remotes)

	-- Initialize sub-systems
	AntiCheat.init()
	DataStoreBackup.init()
	BadgeSystem.init()
	FightSystem.init()

	-- Initialize NPCs (spawn crew in the mansion)
	local mansion = workspace:FindFirstChild("Mansion")
	NPCSystem.init(mansion)

	-- Generate daily challenges
	ChallengeSystem.generateDailyChallenges(GameManager)

	-- Start game loop
	GameManager.startGameLoop()

	-- Start DataStore auto-save loop (every 60 seconds)
	DataStoreBackup.startAutoSaveLoop(GameManager)

	-- Private server admin commands
	if isPrivateServer then
		print("[GameManager] Private server detected. Owner ID:", game.PrivateServerOwnerId)
		if Config.PRIVATE_SERVER and Config.PRIVATE_SERVER.customSettings and Config.PRIVATE_SERVER.customSettings.fastMode then
			print("[GameManager] Fast mode enabled for private server (30s phase timers)")
		end

		Players.PlayerAdded:Connect(function(p)
			if p.UserId == game.PrivateServerOwnerId then
				print("[GameManager] Private server owner joined:", p.Name)
				p.Chatted:Connect(function(msg)
					if msg == "/skip" then
						-- Advance to next phase
						local currentIndex = 0
						for i, phase in DAY_PHASES do
							if phase == GameManager.currentPhase then
								currentIndex = i
								break
							end
						end
						local nextIndex = (currentIndex % #DAY_PHASES) + 1
						GameManager.setPhase(DAY_PHASES[nextIndex])
						GameManager.directorAnnounce("The owner has advanced the phase!")
					elseif msg:sub(1, 12) == "/startphase " then
						local targetPhase = msg:sub(13):lower():gsub(" ", "_")
						local validPhase = false
						for _, phase in DAY_PHASES do
							if phase == targetPhase then
								validPhase = true
								break
							end
						end
						if validPhase then
							GameManager.setPhase(targetPhase)
							GameManager.directorAnnounce("The owner has set the phase to: " .. targetPhase)
						end
					elseif msg:sub(1, 6) == "/crown" then
						local targetName = msg:sub(8)
						if targetName and #targetName > 0 then
							for _, target in Players:GetPlayers() do
								if target.Name:lower() == targetName:lower() or target.DisplayName:lower() == targetName:lower() then
									QueenSystem.dethroneQueen(GameManager)
									QueenSystem.crownQueen(target.UserId, GameManager)
									GameManager.directorAnnounce(target.DisplayName .. " has been crowned by the server owner!")
									break
								end
							end
						end
					end
				end)
			end
		end)
	end

	print("[GameManager] Mansion Mayhem ready!")
end

-- ============================================================
-- ERROR MESSAGING
-- ============================================================

function GameManager.sendError(player, message)
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ErrorMessage")
	if remote then
		remote:FireClient(player, { error = true, message = message })
	end
end

-- ============================================================
-- TEXT FILTERING (Roblox TextService)
-- ============================================================

function GameManager.filterText(text, player)
	local success, result = pcall(function()
		return TextService:FilterStringAsync(text, player.UserId)
	end)
	if success then
		local filterSuccess, filtered = pcall(function()
			return result:GetNonChatStringForBroadcastAsync()
		end)
		if filterSuccess then
			return filtered
		end
	end
	return nil -- reject if filtering fails
end

-- ============================================================
-- CLIENT EVENT WIRING
-- ============================================================

function GameManager._wireClientEvents(remotes)
	-- Confession
	local postConfession = remotes:FindFirstChild("PostConfession")
	if postConfession then
		postConfession.OnServerEvent:Connect(function(player, text)
			GameManager.handleConfession(player, text)
		end)
	end

	-- Check-in (with AntiCheat validation)
	local requestCheckIn = remotes:FindFirstChild("RequestCheckIn")
	if requestCheckIn then
		requestCheckIn.OnServerEvent:Connect(function(player)
			local valid, reason = AntiCheat.validateCheckIn(player, GameManager)
			if not valid then
				GameManager.sendError(player, "Check-in denied: " .. (reason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "checkin", 5) then
				GameManager.sendError(player, "Please wait before checking in again.")
				return
			end
			GameManager.handleCheckIn(player)
		end)
	end

	-- Voting / Nomination (with AntiCheat validation)
	local castVote = remotes:FindFirstChild("CastVote")
	if castVote then
		castVote.OnServerEvent:Connect(function(player, nomineeId)
			local valid, reason = AntiCheat.validateVote(player, nomineeId, GameManager)
			if not valid then
				GameManager.sendError(player, "Vote denied: " .. (reason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "vote", 2) then
				GameManager.sendError(player, "Please wait before voting again.")
				return
			end
			VotingSystem.handleVote(player, nomineeId, GameManager)
		end)
	end

	local submitNomination = remotes:FindFirstChild("SubmitNomination")
	if submitNomination then
		submitNomination.OnServerEvent:Connect(function(player, nomineeUserId)
			local valid, reason = AntiCheat.validateNomination(player, nomineeUserId, GameManager)
			if not valid then
				GameManager.sendError(player, "Nomination denied: " .. (reason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "nomination", 3) then
				GameManager.sendError(player, "Please wait before nominating again.")
				return
			end
			VotingSystem.handleNomination(player, nomineeUserId, GameManager)
		end)
	end

	-- Fight (with AntiCheat validation)
	local startFight = remotes:FindFirstChild("StartFight")
	if startFight then
		startFight.OnServerEvent:Connect(function(player, defenderUserId, reason)
			local valid, acReason = AntiCheat.validateFight(player, defenderUserId, GameManager)
			if not valid then
				GameManager.sendError(player, "Fight denied: " .. (acReason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "fight", 5) then
				GameManager.sendError(player, "Please wait before starting another fight.")
				return
			end

			local fight = FightSystem.startFight(player, defenderUserId, reason, GameManager)

			-- Record fight in AntiCheat tracking
			if fight then
				AntiCheat.recordFight(player.UserId, defenderUserId)

				-- Track fights started for "Drama Queen" milestone
				local attackerData = GameManager.playerMap[player.UserId]
				if attackerData then
					attackerData.fightsStarted = (attackerData.fightsStarted or 0) + 1
				end

				-- Check if fighter is betraying an alliance member -> "Backstabber" badge
				if AllianceSystem.areAllied(player.UserId, defenderUserId) then
					task.spawn(function()
						BadgeSystem.awardBadge(player, "Backstabber")
					end)
				end
			end

			-- Dispatch NPCs and effects when a fight starts
			if fight then
				local fightPos = Vector3.new(0, 1, 0)
				if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
					fightPos = player.Character.HumanoidRootPart.Position
				end

				-- Dispatch camera crew to any fight
				NPCSystem.dispatchCamera(fightPos)

				-- Dispatch security at high intensity
				if fight.intensity >= 7 then
					NPCSystem.dispatchSecurity(fightPos)
				end

				-- Fire sparks effect at fight location
				local playEffect = remotes:FindFirstChild("PlayEffect")
				if playEffect then
					playEffect:FireAllClients({
						effect = "fireSparks",
						position = fightPos,
						continuous = false,
					})
				end
			end
		end)
	end

	-- Alliance (with AntiCheat validation on propose)
	local proposeAlliance = remotes:FindFirstChild("ProposeAlliance")
	if proposeAlliance then
		proposeAlliance.OnServerEvent:Connect(function(player, targetUserId)
			local valid, acReason = AntiCheat.validateAllianceProposal(player, targetUserId, GameManager)
			if not valid then
				GameManager.sendError(player, "Alliance proposal denied: " .. (acReason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "alliance_propose", 5) then
				GameManager.sendError(player, "Please wait before proposing another alliance.")
				return
			end

			local result = AllianceSystem.proposeAlliance(player, targetUserId, GameManager)
			local remote = remotes:FindFirstChild("AllianceUpdate")
			if remote then
				remote:FireClient(player, {
					type = "propose_result",
					success = result.success,
					reason = result.reason,
					allianceName = result.allianceName,
				})
			end
		end)
	end

	local acceptAlliance = remotes:FindFirstChild("AcceptAlliance")
	if acceptAlliance then
		acceptAlliance.OnServerEvent:Connect(function(player)
			local result = AllianceSystem.acceptInvite(player, GameManager)
			local remote = remotes:FindFirstChild("AllianceUpdate")
			if remote then
				remote:FireClient(player, {
					type = "accept_result",
					success = result.success,
					reason = result.reason,
					allianceName = result.allianceName,
				})
			end
			-- Award "Alliance Maker" badge on successful alliance
			if result.success then
				task.spawn(function()
					BadgeSystem.awardBadge(player, "Alliance Maker")
				end)
			end
		end)
	end

	local declineAlliance = remotes:FindFirstChild("DeclineAlliance")
	if declineAlliance then
		declineAlliance.OnServerEvent:Connect(function(player)
			AllianceSystem.declineInvite(player, GameManager)
		end)
	end

	local leaveAlliance = remotes:FindFirstChild("LeaveAlliance")
	if leaveAlliance then
		leaveAlliance.OnServerEvent:Connect(function(player)
			AllianceSystem.leaveAlliance(player, GameManager)
		end)
	end

	-- Queen approval
	local submitApproval = remotes:FindFirstChild("SubmitApproval")
	if submitApproval then
		submitApproval.OnServerEvent:Connect(function(player, approve)
			QueenSystem.submitApproval(player, approve)
		end)
	end

	-- Queen room assignment
	local queenAssignRoom = remotes:FindFirstChild("QueenAssignRoom")
	if queenAssignRoom then
		queenAssignRoom.OnServerEvent:Connect(function(player, targetUserId, roomNumber)
			local result = QueenSystem.assignRoom(player, targetUserId, roomNumber, GameManager)
			local remote = remotes:FindFirstChild("AllianceUpdate")
			if remote then
				remote:FireClient(player, {
					type = "room_assign_result",
					success = result.success,
					reason = result.reason,
					roomName = result.roomName,
				})
			end
		end)
	end

	-- Challenge
	local acceptChallenge = remotes:FindFirstChild("AcceptChallenge")
	if acceptChallenge then
		acceptChallenge.OnServerEvent:Connect(function(player, challengeId)
			ChallengeSystem.acceptChallenge(player, challengeId)
		end)
	end

	-- Immunity (with AntiCheat validation)
	local useImmunityToken = remotes:FindFirstChild("UseImmunityToken")
	if useImmunityToken then
		useImmunityToken.OnServerEvent:Connect(function(player)
			local valid, acReason = AntiCheat.validateImmunityUse(player, GameManager)
			if not valid then
				GameManager.sendError(player, "Immunity use denied: " .. (acReason or "unknown"))
				return
			end
			if not AntiCheat.rateLimit(player, "immunity", 5) then
				GameManager.sendError(player, "Please wait before using immunity again.")
				return
			end

			local result = ImmunitySystem.useToken(player, GameManager)
			if result and result.success then
				AntiCheat.recordImmunityUse(player.UserId)
				-- Award "Immunity Shield" badge on first immunity use
				task.spawn(function()
					BadgeSystem.awardBadge(player, "Immunity Shield")
				end)
			end
		end)
	end

	-- Season info request
	local seasonInfoReq = remotes:FindFirstChild("SeasonInfoRequest")
	if seasonInfoReq then
		seasonInfoReq.OnServerEvent:Connect(function(player)
			GameManager._sendSeasonInfo(player)
		end)
	end

	-- Leaderboard request
	local leaderboardReq = remotes:FindFirstChild("LeaderboardRequest")
	if leaderboardReq then
		leaderboardReq.OnServerEvent:Connect(function(player)
			GameManager._sendLeaderboard(player)
		end)
	end
end

-- ============================================================
-- SEASON DATA
-- ============================================================

function GameManager.loadSeason()
	local status = SupabaseAPI.getSeasonStatus()
	if status and status.active then
		GameManager.seasonData = status
		print("[GameManager] Season loaded:", status.season.title)

		-- Load today's events
		GameManager.events = SupabaseAPI.getEvents(status.season.id) or {}
		print("[GameManager] Events loaded:", #GameManager.events)

		-- Determine current phase from day type
		if status.day then
			GameManager.currentPhase = status.day.day_type or "lobby"
		end

		-- Broadcast to all players
		GameManager.broadcastSeasonUpdate()
	else
		print("[GameManager] No active season")
	end
end

function GameManager.broadcastSeasonUpdate()
	local remote = ReplicatedStorage.Remotes:FindFirstChild("SeasonUpdate")
	if remote and GameManager.seasonData then
		remote:FireAllClients(GameManager.seasonData)
	end
end

-- ============================================================
-- PLAYER MANAGEMENT
-- ============================================================

function GameManager.onPlayerJoin(player)
	print("[GameManager] Player joined:", player.Name, "(ID:", player.UserId, ")")

	-- Map Roblox player to mansion player
	GameManager.playerMap[player.UserId] = {
		robloxId = player.UserId,
		name = player.DisplayName or player.Name,
		room = nil,
		checkedIn = false,
		eliminated = false,
		xp = 0,
		coins = 0,
		fightsWon = 0,
		fightsLost = 0,
		queenCount = 0,
	}

	-- Load saved data from DataStoreBackup and merge
	task.spawn(function()
		local savedData = DataStoreBackup.loadPlayer(player.UserId)
		if savedData then
			local playerData = GameManager.playerMap[player.UserId]
			if playerData then
				DataStoreBackup.mergeIntoPlayerData(playerData, savedData)
				print("[GameManager] Merged DataStore backup for", player.Name)
			end
		end
	end)

	-- Send current season data
	local remote = ReplicatedStorage.Remotes:FindFirstChild("SeasonUpdate")
	if remote and GameManager.seasonData then
		remote:FireClient(player, GameManager.seasonData)
	end

	-- Send events
	local eventRemote = ReplicatedStorage.Remotes:FindFirstChild("EventUpdate")
	if eventRemote then
		eventRemote:FireClient(player, GameManager.events)
	end

	-- Load and send tea wall
	GameManager.sendTeaWall(player)

	-- Send phase update
	GameManager._sendPhaseUpdate(player)

	-- Sync immunity data
	ImmunitySystem.syncToClient(player)

	-- Send challenge list
	local challengeRemote = ReplicatedStorage.Remotes:FindFirstChild("ChallengeList")
	if challengeRemote then
		challengeRemote:FireClient(player, {
			challenges = ChallengeSystem.getActiveChallenges(),
			groupGoals = {},
		})
	end

	-- Apply VIP tag if player has VIP pass
	task.spawn(function()
		task.wait(2) -- Wait for game pass cache to populate
		if MonetizationSystem.hasGamePass(player, "VIP") then
			MonetizationSystem._applyVIPTag(player)
		end
	end)

	-- Award "Welcome to the Mansion" badge on first join
	task.spawn(function()
		BadgeSystem.awardBadge(player, "Welcome to the Mansion")
	end)

	-- Announce arrival
	GameManager.directorAnnounce(player.DisplayName .. " has entered the Mansion.")
end

function GameManager.onPlayerLeave(player)
	-- Save player data to DataStoreBackup before disconnect
	DataStoreBackup.onPlayerLeave(player, GameManager)

	-- Notify all sub-systems
	VotingSystem.onPlayerLeave(player)
	EliminationSystem.onPlayerLeave(player)
	FightSystem.onPlayerLeave(player)
	AllianceSystem.onPlayerLeave(player)
	QueenSystem.onPlayerLeave(player)
	ChallengeSystem.onPlayerLeave(player)
	ImmunitySystem.onPlayerLeave(player)
	AntiCheat.onPlayerLeave(player)

	GameManager.playerMap[player.UserId] = nil
	print("[GameManager] Player left:", player.Name)
end

-- ============================================================
-- PHASE MANAGEMENT (Day Type State Machine)
-- ============================================================

function GameManager.setPhase(newPhase)
	local oldPhase = GameManager.currentPhase
	GameManager.currentPhase = newPhase

	print("[GameManager] Phase transition:", oldPhase, "->", newPhase)

	-- Broadcast phase change
	local remote = ReplicatedStorage.Remotes:FindFirstChild("PhaseUpdate")
	if remote then
		remote:FireAllClients({
			phase = newPhase,
			previousPhase = oldPhase,
		})
	end

	-- Execute phase-specific logic
	GameManager._onPhaseStart(newPhase)
end

function GameManager._onPhaseStart(phase)
	if phase == "move_in" then
		GameManager.directorAnnounce("WELCOME to the Mansion of Mayhem! Time to meet your housemates and find your rooms.")

	elseif phase == "social" then
		GameManager.directorAnnounce("SOCIAL DAY. Form alliances, make friends, make enemies. The cameras are always watching.")
		ChallengeSystem.generateDailyChallenges(GameManager)

	elseif phase == "challenge" then
		GameManager.directorAnnounce("CHALLENGE DAY. Today you compete. The winner earns glory, XP, and possibly the Crown.")
		ChallengeSystem.generateDailyChallenges(GameManager)

	elseif phase == "whisper" then
		GameManager.directorAnnounce("WHISPER DAY. Secrets are currency in the Mansion. The Director has information that could change everything.")

	elseif phase == "confrontation" then
		GameManager.directorAnnounce("CONFRONTATION DAY. Time to face the music. The truth WILL come out today.")

	elseif phase == "deliberation" then
		GameManager.directorAnnounce("DELIBERATION DAY. Tomorrow someone goes home. Campaign for your life. This is your last chance.")
		-- Start nominations
		task.delay(10, function()
			VotingSystem.startNominationPhase(GameManager)
		end)

	elseif phase == "elimination" then
		GameManager.directorAnnounce("ELIMINATION NIGHT. The votes have been cast. Someone is leaving the Mansion TONIGHT.")
		-- Run elimination sequence
		task.delay(10, function()
			GameManager._runEliminationSequence()
		end)
	end
end

function GameManager._runEliminationSequence()
	-- Get voting results
	local eliminatedPlayer = VotingSystem.tallyVotes(GameManager)
	if not eliminatedPlayer then
		GameManager.directorAnnounce("No valid votes were cast. The Director spares everyone... this time.")
		return
	end

	-- Build nominee list for dramatic reveal
	local nominees = {}
	for userId, data in VotingSystem.nominees do
		table.insert(nominees, { userId = userId, name = data.name })
	end

	-- Build results list
	local results = {}
	for _, nominee in nominees do
		local voteCount = 0
		for _, votedForId in VotingSystem.votes do
			if votedForId == nominee.userId then
				voteCount += 1
			end
		end
		table.insert(results, {
			userId = nominee.userId,
			name = nominee.name,
			voteCount = voteCount,
		})
	end
	table.sort(results, function(a, b) return a.voteCount > b.voteCount end)

	-- Run full elimination ceremony
	EliminationSystem.runFullElimination(nominees, results, GameManager)

	-- Award "Survivor" badge to all players who survived this elimination
	task.spawn(function()
		for userId, data in GameManager.playerMap do
			if not data.eliminated then
				local survivorPlayer = Players:GetPlayerByUserId(userId)
				if survivorPlayer then
					BadgeSystem.awardBadge(survivorPlayer, "Survivor")
				end
			end
		end
	end)

	-- Dispatch camera crew and Director to elimination room
	local elimRoomPos = Vector3.new(135, 1, -25)
	NPCSystem.dispatchCamera(elimRoomPos)
	NPCSystem.teleportNPC("THE DIRECTOR", elimRoomPos + Vector3.new(-5, 0, 5))

	-- Fire elimination effects to clients
	local remotes = ReplicatedStorage:FindFirstChild("Remotes")
	if remotes then
		local playEffect = remotes:FindFirstChild("PlayEffect")
		if playEffect then
			playEffect:FireAllClients({
				effect = "smoke",
				position = elimRoomPos,
				duration = 10,
			})
			playEffect:FireAllClients({
				effect = "spotlightSweep",
				position = elimRoomPos,
				duration = 20,
			})
		end

		-- Camera control: orbit around podium then zoom on eliminated
		local cameraControl = remotes:FindFirstChild("CameraControl")
		if cameraControl then
			cameraControl:FireAllClients({
				action = "orbitAround",
				center = elimRoomPos,
				radius = 15,
				duration = 8,
				height = 8,
			})

			-- After orbit, zoom on eliminated player
			local eliminated = results[1]
			if eliminated then
				task.delay(9, function()
					cameraControl:FireAllClients({
						action = "zoomOnPlayer",
						targetUserId = eliminated.userId,
						distance = 6,
						duration = 3,
					})
				end)

				-- Unlock camera after dramatic moment
				task.delay(15, function()
					cameraControl:FireAllClients({
						action = "unlockCamera",
					})
				end)
			end
		end
	end

	-- Clear voting state
	task.delay(30, function()
		VotingSystem.reset()
		ImmunitySystem.clearRoundImmunity()
		AntiCheat.clearImmunityRound()
	end)

	-- Crown new queen after elimination
	task.delay(45, function()
		-- Dethrone current queen
		QueenSystem.dethroneQueen(GameManager)
		-- Select and crown new queen
		local newQueenId = QueenSystem.selectQueenByXP(GameManager)
		if newQueenId then
			QueenSystem.crownQueen(newQueenId, GameManager)
			-- Grant queen immunity
			ImmunitySystem.grantQueenImmunity(newQueenId, GameManager)

			-- Award "Queen of the Week" badge
			local queenBadgePlayer = Players:GetPlayerByUserId(newQueenId)
			if queenBadgePlayer then
				task.spawn(function()
					BadgeSystem.awardBadge(queenBadgePlayer, "Queen of the Week")
				end)
			end

			-- Fire confetti and camera for queen crowning
			local qRemotes = ReplicatedStorage:FindFirstChild("Remotes")
			if qRemotes then
				local queenPlayer = Players:GetPlayerByUserId(newQueenId)
				local queenPos = Vector3.new(135, 3, -25) -- stage center
				if queenPlayer and queenPlayer.Character then
					local hrp = queenPlayer.Character:FindFirstChild("HumanoidRootPart")
					if hrp then queenPos = hrp.Position end
				end

				local playEffect = qRemotes:FindFirstChild("PlayEffect")
				if playEffect then
					playEffect:FireAllClients({
						effect = "confetti",
						position = queenPos,
						duration = 5,
					})
					-- Crown sparkle on the queen
					playEffect:FireAllClients({
						effect = "crownSparkle",
						targetUserId = newQueenId,
						enable = true,
					})
				end

				-- Camera: pan to throne, zoom on queen
				local cameraControl = qRemotes:FindFirstChild("CameraControl")
				if cameraControl then
					cameraControl:FireAllClients({
						action = "panTo",
						targetPosition = queenPos,
						duration = 2,
					})
					task.delay(3, function()
						cameraControl:FireAllClients({
							action = "zoomOnPlayer",
							targetUserId = newQueenId,
							distance = 6,
							duration = 2,
						})
					end)
					task.delay(8, function()
						cameraControl:FireAllClients({
							action = "unlockCamera",
						})
					end)
				end
			end
		end
	end)
end

function GameManager._sendPhaseUpdate(player)
	local remote = ReplicatedStorage.Remotes:FindFirstChild("PhaseUpdate")
	if remote then
		remote:FireClient(player, {
			phase = GameManager.currentPhase,
			previousPhase = nil,
		})
	end
end

-- ============================================================
-- SEASON INFO (for client panel)
-- ============================================================

function GameManager._sendSeasonInfo(player)
	local remote = ReplicatedStorage.Remotes:FindFirstChild("SeasonInfoResponse")
	if not remote then return end

	local queenInfo = QueenSystem.getQueenInfo()
	local activePlayers = 0
	local eliminatedPlayers = 0
	for _, data in GameManager.playerMap do
		if data.eliminated then
			eliminatedPlayers += 1
		else
			activePlayers += 1
		end
	end

	remote:FireClient(player, {
		season = GameManager.seasonData and GameManager.seasonData.season or nil,
		week = GameManager.seasonData and GameManager.seasonData.week or nil,
		day = GameManager.seasonData and GameManager.seasonData.day or nil,
		phase = GameManager.currentPhase,
		queen = queenInfo,
		activePlayers = activePlayers,
		eliminatedPlayers = eliminatedPlayers,
		eliminatedList = EliminationSystem.getEliminatedList(),
		alliances = AllianceSystem.getAllAlliances(),
	})
end

function GameManager._sendLeaderboard(player)
	local remote = ReplicatedStorage.Remotes:FindFirstChild("LeaderboardUpdate")
	if not remote then return end

	-- Build leaderboard from local player data
	local leaderboard = {}
	for userId, data in GameManager.playerMap do
		table.insert(leaderboard, {
			userId = userId,
			name = data.name,
			xp = data.xp or 0,
			eliminated = data.eliminated or false,
			fightsWon = data.fightsWon or 0,
		})
	end
	table.sort(leaderboard, function(a, b) return a.xp > b.xp end)

	-- Also try Supabase leaderboard
	if GameManager.seasonData and GameManager.seasonData.season then
		task.spawn(function()
			local supaLeaderboard = SupabaseAPI.getLeaderboard(GameManager.seasonData.season.id)
			if supaLeaderboard and #supaLeaderboard > 0 then
				remote:FireClient(player, {
					leaderboard = supaLeaderboard,
					source = "supabase",
				})
			end
		end)
	end

	remote:FireClient(player, {
		leaderboard = leaderboard,
		source = "local",
	})
end

-- ============================================================
-- TEA WALL
-- ============================================================

function GameManager.sendTeaWall(player)
	local confessions = SupabaseAPI.getConfessions(15)
	if confessions then
		local remote = ReplicatedStorage.Remotes:FindFirstChild("TeaWallUpdate")
		if remote then
			if player then
				remote:FireClient(player, confessions)
			else
				remote:FireAllClients(confessions)
			end
		end
	end
end

function GameManager.handleConfession(player, text)
	if not text or #text < 1 or #text > 280 then return end

	-- Rate limit confessions
	if not AntiCheat.rateLimit(player, "confession", 5) then
		GameManager.sendError(player, "Please wait before posting another confession.")
		return
	end

	-- Filter text through Roblox TextService
	local filteredText = GameManager.filterText(text, player)
	if not filteredText then
		GameManager.sendError(player, "Your confession could not be posted. Text filtering failed.")
		return
	end

	local gameId = "a0000000-0000-0000-0000-000000000001"
	SupabaseAPI.postConfession(gameId, "", filteredText)
	print("[TeaRoom]", player.Name, "posted:", filteredText)

	-- Award "Tea Spiller" badge for first confession
	task.spawn(function()
		BadgeSystem.awardBadge(player, "Tea Spiller")
	end)

	-- Track group goal
	ChallengeSystem.trackGroupGoal("confession", { userId = player.UserId }, GameManager)

	-- Refresh tea wall for everyone
	task.delay(1, function()
		GameManager.sendTeaWall(nil)
	end)
end

-- ============================================================
-- CHECK-IN
-- ============================================================

function GameManager.handleCheckIn(player)
	if not GameManager.seasonData or not GameManager.seasonData.active then return end

	local playerData = GameManager.playerMap[player.UserId]
	if playerData and playerData.checkedIn then
		local remote = ReplicatedStorage.Remotes:FindFirstChild("CheckInResult")
		if remote then remote:FireClient(player, { already_checked_in = true }) end
		return
	end

	local result = SupabaseAPI.checkIn(
		GameManager.seasonData.season.id,
		tostring(player.UserId)
	)

	if result then
		if playerData then playerData.checkedIn = true end

		-- Award immunity shard from check-in streak
		if result.immunity_shard_awarded then
			ImmunitySystem.awardShard(player.UserId, 1, "checkin_streak", GameManager)
		end

		-- Award "First Check-In" badge
		task.spawn(function()
			BadgeSystem.awardBadge(player, "First Check-In")
		end)

		-- Track group goal
		ChallengeSystem.trackGroupGoal("checkin", { userId = player.UserId }, GameManager)

		local remote = ReplicatedStorage.Remotes:FindFirstChild("CheckInResult")
		if remote then remote:FireClient(player, result) end
	end
end

-- ============================================================
-- DIRECTOR ANNOUNCEMENTS
-- ============================================================

function GameManager.directorAnnounce(message)
	local remote = ReplicatedStorage.Remotes:FindFirstChild("DirectorAnnounce")
	if remote then
		remote:FireAllClients(message)
	end
	print("[Director]", message)
end

-- ============================================================
-- XP AWARDING (applies Double XP multiplier from monetization)
-- ============================================================

function GameManager.awardXP(userId, amount)
	local playerData = GameManager.playerMap[userId]
	if not playerData then return end

	-- Apply XP multiplier from monetization
	local robloxPlayer = Players:GetPlayerByUserId(userId)
	local multiplier = 1
	if robloxPlayer then
		multiplier = MonetizationSystem.getXPMultiplier(robloxPlayer)
	end

	local finalXP = amount * multiplier
	playerData.xp = (playerData.xp or 0) + finalXP

	if multiplier > 1 then
		print("[GameManager] XP awarded to", playerData.name, ":", finalXP, "(", multiplier, "x multiplier)")
	end

	return finalXP
end

-- ============================================================
-- GAME LOOP — Runs every 60 seconds
-- ============================================================

function GameManager.startGameLoop()
	-- Determine tick interval (private server fast mode uses shorter intervals)
	local tickInterval = 60
	if isPrivateServer and Config.PRIVATE_SERVER and Config.PRIVATE_SERVER.customSettings and Config.PRIVATE_SERVER.customSettings.fastMode then
		tickInterval = 30
	end

	-- Main tick
	task.spawn(function()
		while true do
			task.wait(tickInterval)
			GameManager.tick()
		end
	end)

	-- Data refresh (5 minutes)
	task.spawn(function()
		while true do
			task.wait(300)
			GameManager.loadSeason()
			GameManager.sendTeaWall(nil)
		end
	end)

	-- Phase check (30 seconds) — check if day type changed from Supabase
	task.spawn(function()
		while true do
			task.wait(30)
			GameManager._checkPhaseTransition()
		end
	end)
end

function GameManager.tick()
	-- Check if any events should start
	local now = os.time()
	for _, event in GameManager.events do
		if event.status == "scheduled" then
			local eventTime = GameManager.parseISO(event.starts_at)
			if eventTime and now >= eventTime then
				GameManager.directorAnnounce("EVENT: " .. event.title .. " -- " .. (event.description or ""))
				event.status = "active"
			end
		end
	end

	-- Track fight group goal (if no active fights, day is drama-free so far)
	local activeFights = FightSystem.getActiveFights()
	if #activeFights > 0 then
		ChallengeSystem.trackGroupGoal("fight", {}, GameManager)
	end

	-- Check milestone badges periodically for all players
	for userId, data in GameManager.playerMap do
		local robloxPlayer = Players:GetPlayerByUserId(userId)
		if robloxPlayer then
			-- "Fight Club" — first fight win
			if (data.fightsWon or 0) >= 1 then
				task.spawn(function()
					BadgeSystem.awardBadge(robloxPlayer, "Fight Club")
				end)
			end

			-- Check milestone badges (Challenge Champion, Drama Queen, Mansion Veteran)
			BadgeSystem.checkMilestones(robloxPlayer, GameManager)
		end
	end
end

function GameManager._checkPhaseTransition()
	if not GameManager.seasonData or not GameManager.seasonData.day then return end

	local currentDayType = GameManager.seasonData.day.day_type
	if currentDayType and currentDayType ~= GameManager.currentPhase then
		GameManager.setPhase(currentDayType)
	end
end

function GameManager.parseISO(isoString: string): number?
	if not isoString then return nil end
	local y, m, d, h, mi, s = isoString:match("(%d+)-(%d+)-(%d+)T(%d+):(%d+):(%d+)")
	if y then
		return os.time({ year = tonumber(y), month = tonumber(m), day = tonumber(d), hour = tonumber(h), min = tonumber(mi), sec = tonumber(s) })
	end
	return nil
end

return GameManager
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="15">
        <Properties>
          <string name="Name">ImmunitySystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- IMMUNITY SYSTEM — Shards + tokens + shield effects
-- 3 shards = 1 immunity token. Use during nomination to be safe.
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SupabaseAPI = require(script.Parent.SupabaseAPI)
local Config = require(ReplicatedStorage.Shared.Config)

local ImmunitySystem = {}

-- State
ImmunitySystem.playerShards = {} -- { [userId] = shardCount }
ImmunitySystem.playerTokens = {} -- { [userId] = tokenCount }
ImmunitySystem.immunePlayers = {} -- { [userId] = { reason, expiresAt } }
ImmunitySystem.shieldEffects = {} -- { [userId] = partInstance }

-- Config
local SHARDS_PER_TOKEN = 3
local MAX_TOKENS = 3
local MAX_SHARDS = 99

-- ============================================================
-- SHARD MANAGEMENT
-- ============================================================

function ImmunitySystem.awardShard(userId, count, reason, gameManager)
	count = count or 1

	if not ImmunitySystem.playerShards[userId] then
		ImmunitySystem.playerShards[userId] = 0
	end

	ImmunitySystem.playerShards[userId] = math.min(
		ImmunitySystem.playerShards[userId] + count,
		MAX_SHARDS
	)

	local player = Players:GetPlayerByUserId(userId)
	local playerName = player and (player.DisplayName or player.Name) or "Unknown"

	print("[ImmunitySystem] Awarded", count, "shard(s) to", playerName, "— Total:", ImmunitySystem.playerShards[userId], "— Reason:", reason or "unspecified")

	-- Check for auto-conversion to token
	local shardsNow = ImmunitySystem.playerShards[userId]
	if shardsNow >= SHARDS_PER_TOKEN then
		local tokensToMake = math.floor(shardsNow / SHARDS_PER_TOKEN)
		local currentTokens = ImmunitySystem.playerTokens[userId] or 0

		-- Cap tokens
		local tokensToActuallyMake = math.min(tokensToMake, MAX_TOKENS - currentTokens)
		if tokensToActuallyMake > 0 then
			ImmunitySystem.playerShards[userId] = shardsNow - (tokensToActuallyMake * SHARDS_PER_TOKEN)
			ImmunitySystem.playerTokens[userId] = (ImmunitySystem.playerTokens[userId] or 0) + tokensToActuallyMake

			print("[ImmunitySystem]", playerName, "converted", tokensToActuallyMake, "token(s)! Tokens:", ImmunitySystem.playerTokens[userId])

			-- Notify player of token conversion
			if player then
				local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ImmunityUpdate")
				if remote then
					remote:FireClient(player, {
						type = "token_earned",
						tokens = ImmunitySystem.playerTokens[userId],
						shards = ImmunitySystem.playerShards[userId],
						message = "You forged an IMMUNITY TOKEN! (" .. SHARDS_PER_TOKEN .. " shards = 1 token)",
					})
				end
			end

			-- Director announcement
			if gameManager and tokensToActuallyMake > 0 then
				gameManager.directorAnnounce(playerName .. " has earned an IMMUNITY TOKEN. The game just changed.")
			end
		end
	end

	-- Update client HUD
	if player then
		local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ImmunityUpdate")
		if remote then
			remote:FireClient(player, {
				type = "shard_update",
				shards = ImmunitySystem.playerShards[userId],
				tokens = ImmunitySystem.playerTokens[userId] or 0,
			})
		end
	end
end

function ImmunitySystem.removeShard(userId, count)
	count = count or 1
	if not ImmunitySystem.playerShards[userId] then return end
	ImmunitySystem.playerShards[userId] = math.max(0, ImmunitySystem.playerShards[userId] - count)
end

-- ============================================================
-- TOKEN USAGE
-- ============================================================

function ImmunitySystem.useToken(player, gameManager)
	if not player then return { success = false, reason = "invalid_player" } end

	local userId = player.UserId
	local tokens = ImmunitySystem.playerTokens[userId] or 0

	if tokens <= 0 then
		return { success = false, reason = "no_tokens" }
	end

	-- Check if already immune
	if ImmunitySystem.immunePlayers[userId] then
		return { success = false, reason = "already_immune" }
	end

	-- Consume token
	ImmunitySystem.playerTokens[userId] = tokens - 1

	-- Grant immunity for this nomination/voting round
	ImmunitySystem.immunePlayers[userId] = {
		reason = "token",
		expiresAt = os.time() + 3600, -- 1 hour (covers a voting round)
	}

	print("[ImmunitySystem]", player.DisplayName, "used an IMMUNITY TOKEN! Remaining:", ImmunitySystem.playerTokens[userId])

	-- Apply visual shield effect
	ImmunitySystem._applyShieldEffect(player)

	-- Director announcement
	if gameManager then
		gameManager.directorAnnounce(
			player.DisplayName .. " has played an IMMUNITY TOKEN! They CANNOT be eliminated this round!"
		)
	end

	-- Notify all clients
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ImmunityUpdate")
	if remote then
		-- Notify the user
		remote:FireClient(player, {
			type = "token_used",
			tokens = ImmunitySystem.playerTokens[userId],
			shards = ImmunitySystem.playerShards[userId] or 0,
			immune = true,
		})

		-- Notify everyone about the immune player
		local immuneRemote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ImmunityAnnounce")
		if immuneRemote then
			immuneRemote:FireAllClients({
				userId = userId,
				name = player.DisplayName or player.Name,
				immune = true,
			})
		end

		-- Fire shield glow particle effect on the immune player
		local playEffect = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("PlayEffect")
		if playEffect then
			playEffect:FireAllClients({
				effect = "shieldGlow",
				targetUserId = userId,
				enable = true,
			})
		end
	end

	-- Sync to Supabase
	if gameManager and gameManager.seasonData then
		local seasonId = gameManager.seasonData.season and gameManager.seasonData.season.id
		if seasonId then
			task.spawn(function()
				SupabaseAPI.useImmunity(seasonId, tostring(userId))
			end)
		end
	end

	return { success = true, tokensRemaining = ImmunitySystem.playerTokens[userId] }
end

-- ============================================================
-- QUEEN IMMUNITY
-- ============================================================

function ImmunitySystem.grantQueenImmunity(userId, gameManager)
	ImmunitySystem.immunePlayers[userId] = {
		reason = "queen",
		expiresAt = os.time() + (7 * 24 * 3600), -- 1 week
	}

	local player = Players:GetPlayerByUserId(userId)
	if player then
		ImmunitySystem._applyShieldEffect(player)
	end

	print("[ImmunitySystem] Queen immunity granted to", userId)
end

function ImmunitySystem.revokeQueenImmunity(userId)
	if ImmunitySystem.immunePlayers[userId] and ImmunitySystem.immunePlayers[userId].reason == "queen" then
		ImmunitySystem.immunePlayers[userId] = nil
		ImmunitySystem._removeShieldEffect(userId)
	end
end

-- ============================================================
-- IMMUNITY CHECKS
-- ============================================================

function ImmunitySystem.isImmune(userId)
	local immunity = ImmunitySystem.immunePlayers[userId]
	if not immunity then return false end

	-- Check expiration
	if immunity.expiresAt and os.time() > immunity.expiresAt then
		ImmunitySystem.immunePlayers[userId] = nil
		ImmunitySystem._removeShieldEffect(userId)
		return false
	end

	return true
end

function ImmunitySystem.getShards(userId)
	return ImmunitySystem.playerShards[userId] or 0
end

function ImmunitySystem.getTokens(userId)
	return ImmunitySystem.playerTokens[userId] or 0
end

function ImmunitySystem.getImmunityInfo(userId)
	return {
		shards = ImmunitySystem.playerShards[userId] or 0,
		tokens = ImmunitySystem.playerTokens[userId] or 0,
		immune = ImmunitySystem.isImmune(userId),
		reason = ImmunitySystem.immunePlayers[userId] and ImmunitySystem.immunePlayers[userId].reason or nil,
	}
end

-- ============================================================
-- CLEAR ROUND IMMUNITY (after voting ends)
-- ============================================================

function ImmunitySystem.clearRoundImmunity()
	local cleared = {}
	for userId, immunity in ImmunitySystem.immunePlayers do
		if immunity.reason == "token" then
			table.insert(cleared, userId)
		end
	end

	for _, userId in cleared do
		ImmunitySystem.immunePlayers[userId] = nil
		ImmunitySystem._removeShieldEffect(userId)
	end

	if #cleared > 0 then
		print("[ImmunitySystem] Cleared round immunity for", #cleared, "player(s)")
	end
end

-- ============================================================
-- VISUAL SHIELD EFFECT
-- ============================================================

function ImmunitySystem._applyShieldEffect(player)
	if not player or not player.Character then return end

	local hrp = player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	-- Remove existing shield
	ImmunitySystem._removeShieldEffect(player.UserId)

	-- Create shield sphere around player
	local shield = Instance.new("Part")
	shield.Name = "ImmunityShield"
	shield.Shape = Enum.PartType.Ball
	shield.Size = Vector3.new(8, 8, 8)
	shield.Color = Config.Colors.Blue
	shield.Material = Enum.Material.ForceField
	shield.Transparency = 0.7
	shield.CanCollide = false
	shield.Anchored = false
	shield.Massless = true
	shield.Parent = player.Character

	-- Weld to HumanoidRootPart
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = hrp
	weld.Part1 = shield
	weld.Parent = shield

	shield.CFrame = hrp.CFrame

	-- Add glow
	local light = Instance.new("PointLight")
	light.Color = Config.Colors.Blue
	light.Brightness = 1.5
	light.Range = 20
	light.Parent = shield

	-- Add particle emitter for sparkle effect
	local particles = Instance.new("ParticleEmitter")
	particles.Color = ColorSequence.new(Config.Colors.Blue, Config.Colors.Gold)
	particles.Size = NumberSequence.new({ NumberSequenceKeypoint.new(0, 0.3), NumberSequenceKeypoint.new(1, 0) })
	particles.Lifetime = NumberRange.new(0.5, 1.5)
	particles.Rate = 20
	particles.Speed = NumberRange.new(2, 5)
	particles.SpreadAngle = Vector2.new(360, 360)
	particles.Parent = shield

	ImmunitySystem.shieldEffects[player.UserId] = shield
end

function ImmunitySystem._removeShieldEffect(userId)
	local shield = ImmunitySystem.shieldEffects[userId]
	if shield then
		shield:Destroy()
		ImmunitySystem.shieldEffects[userId] = nil
	end
end

-- ============================================================
-- SYNC ALL TO CLIENT (when player joins or reconnects)
-- ============================================================

function ImmunitySystem.syncToClient(player)
	if not player then return end

	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("ImmunityUpdate")
	if remote then
		remote:FireClient(player, {
			type = "full_sync",
			shards = ImmunitySystem.playerShards[player.UserId] or 0,
			tokens = ImmunitySystem.playerTokens[player.UserId] or 0,
			immune = ImmunitySystem.isImmune(player.UserId),
		})
	end
end

-- ============================================================
-- CLEANUP
-- ============================================================

function ImmunitySystem.onPlayerLeave(player)
	ImmunitySystem._removeShieldEffect(player.UserId)
	ImmunitySystem.immunePlayers[player.UserId] = nil
	-- Keep shards/tokens in case they rejoin (don't wipe)
end

return ImmunitySystem
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="16">
        <Properties>
          <string name="Name">MansionBuilder</string>
          <string name="Source"><![CDATA[-- ============================================================
-- MANSION BUILDER — Luxury Reality TV Mansion
-- Love Island Villa x Luxury Penthouse aesthetic
-- Fully enclosed mansion with outer shell, roof, doorways
-- ============================================================

local TweenService = game:GetService("TweenService")
local Config = require(game.ReplicatedStorage.Shared.Config)

local MansionBuilder = {}

-- ============================================================
-- CONSTANTS
-- ============================================================

local FLOOR_Y = 0
local FLOOR2_Y = 22
local WALL_HEIGHT = 16
local ROOM_SIZE = 45

-- Mansion outer bounds (used for outer shell)
-- Ground floor spans from lobby (X=-5) to elevator (X=210), Z from -60 to 55
local OUTER_X_MIN = -10
local OUTER_X_MAX = 210
local OUTER_Z_MIN = -62
local OUTER_Z_MAX = 55
local OUTER_WIDTH = OUTER_X_MAX - OUTER_X_MIN
local OUTER_DEPTH = OUTER_Z_MAX - OUTER_Z_MIN
local OUTER_CX = (OUTER_X_MIN + OUTER_X_MAX) / 2
local OUTER_CZ = (OUTER_Z_MIN + OUTER_Z_MAX) / 2

-- Doorway dimensions
local DOORWAY_WIDTH = 6
local DOORWAY_HEIGHT = 10
local DOOR_FRAME_THICKNESS = 0.5

-- Color palette — warm luxury tones
local MARBLE_WHITE  = Color3.fromHex("#F0E6D8")
local MARBLE_DARK   = Color3.fromHex("#1A0E14")
local WALL_COLOR    = Color3.fromHex("#1E1428")
local WALL_LIGHT    = Color3.fromHex("#2A1E35")
local GOLD          = Color3.fromHex("#D4A847")
local GOLD_BRIGHT   = Color3.fromHex("#FFD700")
local NEON_PINK     = Color3.fromHex("#FF1493")
local ROSE_GOLD     = Color3.fromHex("#E8A0BF")
local DARK          = Color3.fromHex("#0A0610")
local CREAM         = Color3.fromHex("#F0E8DC")
local TEAL_GREEN    = Color3.fromHex("#1B5E3B")
local PURPLE        = Color3.fromHex("#9B30FF")
local PURPLE_DARK   = Color3.fromHex("#2D1050")
local CRIMSON       = Color3.fromHex("#E94560")
local AMBER         = Color3.fromHex("#FFBF00")
local SKY_BLUE      = Color3.fromHex("#00BFFF")
local GLASS_BLUE    = Color3.fromHex("#88CCEE")
local COUCH_CREAM   = Color3.fromHex("#E8DDD0")
local COUCH_GREEN   = Color3.fromHex("#1B4D3E")
local CURTAIN_DARK  = Color3.fromHex("#12081E")

-- ============================================================
-- CORE HELPER FUNCTIONS
-- ============================================================

function MansionBuilder.createPart(parent, name, pos, size, color, mat, anchored)
	local part = Instance.new("Part")
	part.Name = name
	part.Position = pos
	part.Size = size
	part.Color = color or WALL_COLOR
	part.Material = mat or Enum.Material.SmoothPlastic
	part.Anchored = anchored ~= false
	part.CanCollide = true
	part.Parent = parent
	return part
end

function MansionBuilder.createNeon(parent, name, pos, size, color)
	local part = MansionBuilder.createPart(parent, name, pos, size, color or NEON_PINK, Enum.Material.Neon)
	part.CanCollide = false
	return part
end

function MansionBuilder.createSign(parent, text, pos, size, color, rotation)
	local part = Instance.new("Part")
	part.Name = "Sign_" .. text
	part.Position = pos
	part.Size = Vector3.new(size or 8, 3, 0.2)
	part.Color = DARK
	part.Material = Enum.Material.SmoothPlastic
	part.Anchored = true
	part.CanCollide = false
	part.Transparency = 0.5
	if rotation then
		part.Orientation = rotation
	end
	part.Parent = parent

	local sg = Instance.new("SurfaceGui")
	sg.Face = Enum.NormalId.Front
	sg.Parent = part

	local tl = Instance.new("TextLabel")
	tl.Size = UDim2.new(1, 0, 1, 0)
	tl.BackgroundTransparency = 1
	tl.Text = text
	tl.TextColor3 = color or GOLD
	tl.TextScaled = true
	tl.Font = Enum.Font.GothamBold
	tl.Parent = sg

	-- Also add a back-face SurfaceGui so sign is readable from both sides
	local sg2 = Instance.new("SurfaceGui")
	sg2.Face = Enum.NormalId.Back
	sg2.Parent = part
	local tl2 = Instance.new("TextLabel")
	tl2.Size = UDim2.new(1, 0, 1, 0)
	tl2.BackgroundTransparency = 1
	tl2.Text = text
	tl2.TextColor3 = color or GOLD
	tl2.TextScaled = true
	tl2.Font = Enum.Font.GothamBold
	tl2.Parent = sg2

	return part
end

-- ============================================================
-- DOORWAY HELPER — Creates a wall with a doorway opening
-- The wall is split into 3 parts: left section, above-door section, right section
-- Plus gold door frame trim
-- ============================================================

function MansionBuilder.createWallWithDoorway(parent, name, wallPos, wallSize, doorCenterOffset, wallColor, floorY)
	-- wallPos = center of the full wall
	-- wallSize = full wall dimensions (X, Y, Z)
	-- doorCenterOffset = offset along the long axis of the wall for the door center (0 = centered)
	-- For X-axis walls (WallNorth/South), the door offset is along X
	-- For Z-axis walls (WallEast/West), the door offset is along Z

	local wc = wallColor or WALL_COLOR
	local fy = floorY or FLOOR_Y
	local dw = DOORWAY_WIDTH
	local dh = DOORWAY_HEIGHT
	local offset = doorCenterOffset or 0

	-- Determine wall orientation
	local isXWall = wallSize.X > wallSize.Z -- wall stretches along X axis

	if isXWall then
		local fullLen = wallSize.X
		local wallThick = wallSize.Z
		local wallH = wallSize.Y

		local doorLeft = offset - dw / 2
		local doorRight = offset + dw / 2

		-- Left section (from -fullLen/2 to doorLeft)
		local leftLen = (fullLen / 2) + doorLeft
		if leftLen > 0.5 then
			local leftCx = wallPos.X - fullLen / 2 + leftLen / 2
			MansionBuilder.createPart(parent, name .. "_L",
				Vector3.new(leftCx, wallPos.Y, wallPos.Z),
				Vector3.new(leftLen, wallH, wallThick), wc)
		end

		-- Right section (from doorRight to fullLen/2)
		local rightLen = (fullLen / 2) - doorRight
		if rightLen > 0.5 then
			local rightCx = wallPos.X + fullLen / 2 - rightLen / 2
			MansionBuilder.createPart(parent, name .. "_R",
				Vector3.new(rightCx, wallPos.Y, wallPos.Z),
				Vector3.new(rightLen, wallH, wallThick), wc)
		end

		-- Above-door section
		local aboveH = wallH - dh
		if aboveH > 0.5 then
			local aboveCy = wallPos.Y + wallH / 2 - aboveH / 2
			MansionBuilder.createPart(parent, name .. "_Top",
				Vector3.new(wallPos.X + offset, aboveCy, wallPos.Z),
				Vector3.new(dw, aboveH, wallThick), wc)
		end

		-- Gold door frame
		local doorBottomY = wallPos.Y - wallH / 2
		-- Left jamb
		MansionBuilder.createPart(parent, name .. "_FrameL",
			Vector3.new(wallPos.X + doorLeft, doorBottomY + dh / 2, wallPos.Z),
			Vector3.new(DOOR_FRAME_THICKNESS, dh, wallThick + 0.4), GOLD, Enum.Material.Metal)
		-- Right jamb
		MansionBuilder.createPart(parent, name .. "_FrameR",
			Vector3.new(wallPos.X + doorRight, doorBottomY + dh / 2, wallPos.Z),
			Vector3.new(DOOR_FRAME_THICKNESS, dh, wallThick + 0.4), GOLD, Enum.Material.Metal)
		-- Top lintel
		MansionBuilder.createPart(parent, name .. "_FrameTop",
			Vector3.new(wallPos.X + offset, doorBottomY + dh, wallPos.Z),
			Vector3.new(dw + DOOR_FRAME_THICKNESS * 2, DOOR_FRAME_THICKNESS, wallThick + 0.4), GOLD, Enum.Material.Metal)
	else
		-- Z-axis wall (stretches along Z)
		local fullLen = wallSize.Z
		local wallThick = wallSize.X
		local wallH = wallSize.Y

		local doorLeft = offset - dw / 2
		local doorRight = offset + dw / 2

		-- Left section (negative Z side)
		local leftLen = (fullLen / 2) + doorLeft
		if leftLen > 0.5 then
			local leftCz = wallPos.Z - fullLen / 2 + leftLen / 2
			MansionBuilder.createPart(parent, name .. "_L",
				Vector3.new(wallPos.X, wallPos.Y, leftCz),
				Vector3.new(wallThick, wallH, leftLen), wc)
		end

		-- Right section (positive Z side)
		local rightLen = (fullLen / 2) - doorRight
		if rightLen > 0.5 then
			local rightCz = wallPos.Z + fullLen / 2 - rightLen / 2
			MansionBuilder.createPart(parent, name .. "_R",
				Vector3.new(wallPos.X, wallPos.Y, rightCz),
				Vector3.new(wallThick, wallH, rightLen), wc)
		end

		-- Above-door section
		local aboveH = wallH - dh
		if aboveH > 0.5 then
			local aboveCy = wallPos.Y + wallH / 2 - aboveH / 2
			MansionBuilder.createPart(parent, name .. "_Top",
				Vector3.new(wallPos.X, aboveCy, wallPos.Z + offset),
				Vector3.new(wallThick, aboveH, dw), wc)
		end

		-- Gold door frame
		local doorBottomY = wallPos.Y - wallH / 2
		-- Left jamb
		MansionBuilder.createPart(parent, name .. "_FrameL",
			Vector3.new(wallPos.X, doorBottomY + dh / 2, wallPos.Z + doorLeft),
			Vector3.new(wallThick + 0.4, dh, DOOR_FRAME_THICKNESS), GOLD, Enum.Material.Metal)
		-- Right jamb
		MansionBuilder.createPart(parent, name .. "_FrameR",
			Vector3.new(wallPos.X, doorBottomY + dh / 2, wallPos.Z + doorRight),
			Vector3.new(wallThick + 0.4, dh, DOOR_FRAME_THICKNESS), GOLD, Enum.Material.Metal)
		-- Top lintel
		MansionBuilder.createPart(parent, name .. "_FrameTop",
			Vector3.new(wallPos.X, doorBottomY + dh, wallPos.Z + offset),
			Vector3.new(wallThick + 0.4, DOOR_FRAME_THICKNESS, dw + DOOR_FRAME_THICKNESS * 2), GOLD, Enum.Material.Metal)
	end
end

-- ============================================================
-- WINDOW HELPER — Creates a transparent glass section in a wall
-- ============================================================

function MansionBuilder.createWindow(parent, pos, size, name)
	local win = MansionBuilder.createPart(parent, name or "Window", pos, size, GLASS_BLUE, Enum.Material.Glass)
	win.Transparency = 0.5
	-- Gold frame around window
	MansionBuilder.createPart(parent, (name or "Window") .. "_FrameTop",
		pos + Vector3.new(0, size.Y / 2, 0),
		Vector3.new(size.X + 0.4, 0.3, size.Z + 0.4), GOLD, Enum.Material.Metal)
	MansionBuilder.createPart(parent, (name or "Window") .. "_FrameBot",
		pos - Vector3.new(0, size.Y / 2, 0),
		Vector3.new(size.X + 0.4, 0.3, size.Z + 0.4), GOLD, Enum.Material.Metal)
	return win
end

-- ============================================================
-- NEW FURNITURE HELPERS
-- ============================================================

function MansionBuilder.createCouch(parent, pos, size, rotation, color)
	local couch = Instance.new("Model")
	couch.Name = "Couch"
	couch.Parent = parent

	-- Seat cushion
	local seat = MansionBuilder.createPart(couch, "Seat", pos, size or Vector3.new(8, 2, 4), color or COUCH_CREAM, Enum.Material.Fabric)
	if rotation then seat.Orientation = rotation end

	-- Backrest — offset based on rotation
	local backOffset = Vector3.new(0, 1.5, -2)
	if rotation then
		local ry = rotation.Y
		if math.abs(ry - 90) < 1 or math.abs(ry + 270) < 1 then
			backOffset = Vector3.new(-2, 1.5, 0)
		elseif math.abs(ry + 90) < 1 or math.abs(ry - 270) < 1 then
			backOffset = Vector3.new(2, 1.5, 0)
		elseif math.abs(ry - 180) < 1 or math.abs(ry + 180) < 1 then
			backOffset = Vector3.new(0, 1.5, 2)
		end
	end
	local back = MansionBuilder.createPart(couch, "Back",
		pos + backOffset,
		Vector3.new((size and size.X) or 8, 3, 1),
		color or COUCH_CREAM, Enum.Material.Fabric)
	if rotation then back.Orientation = rotation end

	-- Throw pillows
	local pillowColors = {GOLD_BRIGHT, NEON_PINK, ROSE_GOLD}
	for i = 1, 2 do
		local px = (i == 1) and -2 or 2
		MansionBuilder.createPart(couch, "Pillow" .. i,
			pos + Vector3.new(px, 1.2, -1),
			Vector3.new(1.5, 1, 1.2),
			pillowColors[i], Enum.Material.Fabric)
	end

	return couch
end

function MansionBuilder.createPlant(parent, pos, height)
	local plant = Instance.new("Model")
	plant.Name = "Plant"
	plant.Parent = parent

	-- Pot
	local pot = Instance.new("Part")
	pot.Name = "Pot"
	pot.Shape = Enum.PartType.Cylinder
	pot.Size = Vector3.new(3, 4, 4)
	pot.Position = pos + Vector3.new(0, 1.5, 0)
	pot.Orientation = Vector3.new(0, 0, 90)
	pot.Color = GOLD
	pot.Material = Enum.Material.SmoothPlastic
	pot.Anchored = true
	pot.Parent = plant

	-- Trunk
	local trunk = Instance.new("Part")
	trunk.Name = "Trunk"
	trunk.Shape = Enum.PartType.Cylinder
	trunk.Size = Vector3.new(height or 10, 1.5, 1.5)
	trunk.Position = pos + Vector3.new(0, (height or 10) / 2 + 3, 0)
	trunk.Orientation = Vector3.new(0, 0, 0)
	trunk.Color = Color3.fromHex("#3B2F1A")
	trunk.Material = Enum.Material.Wood
	trunk.Anchored = true
	trunk.Parent = plant

	-- Canopy — cluster of green spheres
	local topY = pos.Y + (height or 10) + 3
	for i = 1, 5 do
		local leaf = Instance.new("Part")
		leaf.Name = "Leaf" .. i
		leaf.Shape = Enum.PartType.Ball
		leaf.Size = Vector3.new(4, 4, 4)
		local offsets = {
			Vector3.new(0, 0, 0),
			Vector3.new(2, -1, 1),
			Vector3.new(-2, -1, -1),
			Vector3.new(1, 1, -2),
			Vector3.new(-1, 1, 2),
		}
		leaf.Position = Vector3.new(pos.X, topY, pos.Z) + offsets[i]
		leaf.Color = Color3.fromHex("#2D8B46")
		leaf.Material = Enum.Material.Grass
		leaf.Anchored = true
		leaf.CanCollide = false
		leaf.Parent = plant
	end

	return plant
end

function MansionBuilder.createPendantLight(parent, pos, color, brightness)
	local pendant = Instance.new("Model")
	pendant.Name = "PendantLight"
	pendant.Parent = parent

	-- Cord
	MansionBuilder.createPart(pendant, "Cord", pos + Vector3.new(0, 1.5, 0), Vector3.new(0.2, 3, 0.2), GOLD)

	-- Shade (sphere)
	local shade = Instance.new("Part")
	shade.Name = "Shade"
	shade.Shape = Enum.PartType.Ball
	shade.Size = Vector3.new(3, 3, 3)
	shade.Position = pos
	shade.Color = color or GOLD
	shade.Material = Enum.Material.Neon
	shade.Anchored = true
	shade.Transparency = 0.2
	shade.CanCollide = false
	shade.Parent = pendant

	local pl = Instance.new("PointLight")
	pl.Color = color or Color3.fromHex("#FFEEDD")
	pl.Brightness = brightness or 1.5
	pl.Range = 30
	pl.Parent = shade

	return pendant
end

function MansionBuilder.createBarStool(parent, pos)
	local stool = Instance.new("Model")
	stool.Name = "BarStool"
	stool.Parent = parent

	-- Leg (cylinder)
	local leg = Instance.new("Part")
	leg.Name = "Leg"
	leg.Shape = Enum.PartType.Cylinder
	leg.Size = Vector3.new(3.5, 1, 1)
	leg.Position = pos + Vector3.new(0, 1.75, 0)
	leg.Orientation = Vector3.new(0, 0, 0)
	leg.Color = GOLD
	leg.Material = Enum.Material.Metal
	leg.Anchored = true
	leg.Parent = stool

	-- Seat (cylinder)
	local seat = Instance.new("Part")
	seat.Name = "Seat"
	seat.Shape = Enum.PartType.Cylinder
	seat.Size = Vector3.new(0.8, 2.5, 2.5)
	seat.Position = pos + Vector3.new(0, 3.8, 0)
	seat.Orientation = Vector3.new(0, 0, 90)
	seat.Color = CREAM
	seat.Material = Enum.Material.Fabric
	seat.Anchored = true
	seat.Parent = stool

	return stool
end

function MansionBuilder.createSconce(parent, pos, direction)
	local sconce = Instance.new("Model")
	sconce.Name = "Sconce"
	sconce.Parent = parent

	-- Bracket
	MansionBuilder.createPart(sconce, "Bracket", pos, Vector3.new(1, 2, 1), GOLD, Enum.Material.Metal)

	-- Bulb
	local bulb = Instance.new("Part")
	bulb.Name = "Bulb"
	bulb.Shape = Enum.PartType.Ball
	bulb.Size = Vector3.new(1.5, 1.5, 1.5)
	bulb.Position = pos + (direction or Vector3.new(0, 0, 1))
	bulb.Color = AMBER
	bulb.Material = Enum.Material.Neon
	bulb.Anchored = true
	bulb.CanCollide = false
	bulb.Parent = sconce

	local pl = Instance.new("PointLight")
	pl.Color = Color3.fromHex("#FFEEDD")
	pl.Brightness = 1.2
	pl.Range = 20
	pl.Parent = bulb

	return sconce
end

function MansionBuilder.createSkyline(parent)
	local skyline = Instance.new("Model")
	skyline.Name = "Skyline"
	skyline.Parent = parent

	-- Row of buildings at edge
	local buildingHeights = {60, 45, 80, 35, 70, 55, 90, 40, 65, 50, 75, 42, 85, 38, 58}
	local startX = -80
	for i, h in ipairs(buildingHeights) do
		local bx = startX + (i - 1) * 12
		local building = MansionBuilder.createPart(skyline, "Building" .. i,
			Vector3.new(bx + 100, h / 2 + FLOOR2_Y + WALL_HEIGHT, 80),
			Vector3.new(8, h, 8),
			Color3.fromHex("#0D0D15"), Enum.Material.SmoothPlastic)

		-- Window lights — small yellow neon dots
		for wy = 1, math.floor(h / 8) do
			for wx = 1, 2 do
				local windowX = bx + 100 + (wx == 1 and -2 or 2)
				local windowY = FLOOR2_Y + WALL_HEIGHT + wy * 7
				if windowY < FLOOR2_Y + WALL_HEIGHT + h - 3 then
					local window = MansionBuilder.createNeon(skyline, "Win" .. i .. "_" .. wy .. "_" .. wx,
						Vector3.new(windowX, windowY, 76),
						Vector3.new(1.5, 1.5, 0.3),
						Color3.fromHex("#FFE488"))
					window.Transparency = 0.3
				end
			end
		end
	end

	return skyline
end

function MansionBuilder.createFlowerVase(parent, pos, flowerColor)
	local vase = Instance.new("Model")
	vase.Name = "FlowerVase"
	vase.Parent = parent

	-- Base pedestal
	local base = Instance.new("Part")
	base.Name = "Base"
	base.Shape = Enum.PartType.Cylinder
	base.Size = Vector3.new(3, 2, 2)
	base.Position = pos + Vector3.new(0, 1.5, 0)
	base.Orientation = Vector3.new(0, 0, 0)
	base.Color = GOLD
	base.Material = Enum.Material.Metal
	base.Anchored = true
	base.Parent = vase

	-- Flowers (spheres)
	local fColors = flowerColor or {NEON_PINK, ROSE_GOLD, Color3.fromHex("#FF6B8A")}
	for i = 1, 3 do
		local flower = Instance.new("Part")
		flower.Name = "Flower" .. i
		flower.Shape = Enum.PartType.Ball
		flower.Size = Vector3.new(1.2, 1.2, 1.2)
		local offsets = {Vector3.new(-0.5, 3.5, 0), Vector3.new(0.5, 4, 0.3), Vector3.new(0, 3.8, -0.4)}
		flower.Position = pos + offsets[i]
		flower.Color = fColors[((i - 1) % #fColors) + 1]
		flower.Material = Enum.Material.SmoothPlastic
		flower.Anchored = true
		flower.CanCollide = false
		flower.Parent = vase
	end

	return vase
end

function MansionBuilder.createChandelier(parent, pos, radius, color)
	local chandelier = Instance.new("Model")
	chandelier.Name = "Chandelier"
	chandelier.Parent = parent

	-- Central ring (neon)
	-- We approximate a ring with 8 neon bars arranged in octagon
	local segments = 8
	for i = 1, segments do
		local angle = (i - 1) * (2 * math.pi / segments)
		local nextAngle = i * (2 * math.pi / segments)
		local midAngle = (angle + nextAngle) / 2
		local r = radius or 8
		local cx = pos.X + math.cos(midAngle) * r
		local cz = pos.Z + math.sin(midAngle) * r
		local segLen = 2 * r * math.sin(math.pi / segments)
		local bar = MansionBuilder.createNeon(chandelier, "Ring" .. i,
			Vector3.new(cx, pos.Y, cz),
			Vector3.new(segLen, 0.5, 0.5),
			color or GOLD_BRIGHT)
		bar.Orientation = Vector3.new(0, math.deg(midAngle), 0)
	end

	-- Hanging chains
	for i = 1, 4 do
		local angle = (i - 1) * (math.pi / 2)
		local r = (radius or 8) * 0.5
		MansionBuilder.createPart(chandelier, "Chain" .. i,
			Vector3.new(pos.X + math.cos(angle) * r, pos.Y + 2, pos.Z + math.sin(angle) * r),
			Vector3.new(0.2, 4, 0.2), GOLD, Enum.Material.Metal)
	end

	-- Central light
	local center = Instance.new("Part")
	center.Name = "CenterLight"
	center.Shape = Enum.PartType.Ball
	center.Size = Vector3.new(2, 2, 2)
	center.Position = pos
	center.Color = color or GOLD_BRIGHT
	center.Material = Enum.Material.Neon
	center.Anchored = true
	center.CanCollide = false
	center.Parent = chandelier

	local pl = Instance.new("PointLight")
	pl.Color = Color3.fromHex("#FFEEDD")
	pl.Brightness = 2
	pl.Range = 50
	pl.Parent = center

	return chandelier
end

function MansionBuilder.createArtFrame(parent, pos, size, rotation)
	local frame = Instance.new("Model")
	frame.Name = "ArtFrame"
	frame.Parent = parent

	-- Gold border frame
	local borderSize = size or Vector3.new(4, 3, 0.3)
	local border = MansionBuilder.createPart(frame, "Border", pos, borderSize + Vector3.new(0.6, 0.6, 0), GOLD, Enum.Material.Metal)
	if rotation then border.Orientation = rotation end

	-- Dark canvas
	local canvas = MansionBuilder.createPart(frame, "Canvas", pos + Vector3.new(0, 0, 0.05), borderSize, Color3.fromHex("#1A1225"))
	if rotation then canvas.Orientation = rotation end
	canvas.CanCollide = false

	return frame
end

function MansionBuilder.createFountain(parent, pos)
	local fountain = Instance.new("Model")
	fountain.Name = "Fountain"
	fountain.Parent = parent

	-- Base pool
	local base = Instance.new("Part")
	base.Name = "Base"
	base.Shape = Enum.PartType.Cylinder
	base.Size = Vector3.new(2, 12, 12)
	base.Position = pos + Vector3.new(0, 1, 0)
	base.Orientation = Vector3.new(0, 0, 90)
	base.Color = MARBLE_WHITE
	base.Material = Enum.Material.Marble
	base.Anchored = true
	base.Parent = fountain

	-- Water
	local water = Instance.new("Part")
	water.Name = "Water"
	water.Shape = Enum.PartType.Cylinder
	water.Size = Vector3.new(1.5, 11, 11)
	water.Position = pos + Vector3.new(0, 1.3, 0)
	water.Orientation = Vector3.new(0, 0, 90)
	water.Color = SKY_BLUE
	water.Material = Enum.Material.Neon
	water.Transparency = 0.4
	water.Anchored = true
	water.CanCollide = false
	water.Parent = fountain

	-- Center pillar
	local pillar = Instance.new("Part")
	pillar.Name = "Pillar"
	pillar.Shape = Enum.PartType.Cylinder
	pillar.Size = Vector3.new(6, 2, 2)
	pillar.Position = pos + Vector3.new(0, 4, 0)
	pillar.Color = MARBLE_WHITE
	pillar.Material = Enum.Material.Marble
	pillar.Anchored = true
	pillar.Parent = fountain

	-- Water jet glow
	MansionBuilder.createNeon(fountain, "Jet", pos + Vector3.new(0, 8, 0), Vector3.new(0.5, 4, 0.5), SKY_BLUE)

	return fountain
end

-- ============================================================
-- ROOM SHELL HELPER — builds floor, ceiling, walls for a room
-- Now supports doorway specification
-- ============================================================

function MansionBuilder.createRoomShell(parent, name, cx, cy, cz, width, depth, wallHeight, floorColor, wallColor, ceilColor, floorMat)
	local room = Instance.new("Folder")
	room.Name = name
	room.Parent = parent

	local wh = wallHeight or WALL_HEIGHT
	local hw = width / 2
	local hd = depth / 2

	-- Floor
	MansionBuilder.createPart(room, "Floor",
		Vector3.new(cx, cy - 0.5, cz),
		Vector3.new(width, 1, depth),
		floorColor or MARBLE_WHITE, floorMat or Enum.Material.Marble)

	-- Ceiling
	MansionBuilder.createPart(room, "Ceiling",
		Vector3.new(cx, cy + wh, cz),
		Vector3.new(width, 1, depth),
		ceilColor or DARK)

	-- Walls — North, South, East, West (solid by default)
	MansionBuilder.createPart(room, "WallNorth",
		Vector3.new(cx, cy + wh / 2, cz + hd),
		Vector3.new(width, wh, 1),
		wallColor or WALL_COLOR)
	MansionBuilder.createPart(room, "WallSouth",
		Vector3.new(cx, cy + wh / 2, cz - hd),
		Vector3.new(width, wh, 1),
		wallColor or WALL_COLOR)
	MansionBuilder.createPart(room, "WallWest",
		Vector3.new(cx - hw, cy + wh / 2, cz),
		Vector3.new(1, wh, depth),
		wallColor or WALL_COLOR)
	MansionBuilder.createPart(room, "WallEast",
		Vector3.new(cx + hw, cy + wh / 2, cz),
		Vector3.new(1, wh, depth),
		wallColor or WALL_COLOR)

	-- Gold floor trim neon strips
	MansionBuilder.createNeon(room, "FloorTrimN", Vector3.new(cx, cy + 0.1, cz + hd - 0.5), Vector3.new(width - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(room, "FloorTrimS", Vector3.new(cx, cy + 0.1, cz - hd + 0.5), Vector3.new(width - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(room, "FloorTrimW", Vector3.new(cx - hw + 0.5, cy + 0.1, cz), Vector3.new(0.3, 0.2, depth - 2), GOLD)
	MansionBuilder.createNeon(room, "FloorTrimE", Vector3.new(cx + hw - 0.5, cy + 0.1, cz), Vector3.new(0.3, 0.2, depth - 2), GOLD)

	-- Gold ceiling cove lighting
	MansionBuilder.createNeon(room, "CeilTrimN", Vector3.new(cx, cy + wh - 0.3, cz + hd - 0.5), Vector3.new(width - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(room, "CeilTrimS", Vector3.new(cx, cy + wh - 0.3, cz - hd + 0.5), Vector3.new(width - 2, 0.2, 0.3), GOLD)

	return room
end

-- ============================================================
-- Helper to replace a solid wall with a doorway version
-- Removes the named wall part and adds doorway sections
-- ============================================================

function MansionBuilder.addDoorwayToWall(room, wallName, doorOffset, floorY)
	local wall = room:FindFirstChild(wallName)
	if not wall then return end

	local wallPos = wall.Position
	local wallSize = wall.Size
	local wallColor = wall.Color
	local fy = floorY or FLOOR_Y

	wall:Destroy()

	MansionBuilder.createWallWithDoorway(room, wallName, wallPos, wallSize, doorOffset or 0, wallColor, fy)
end

-- ============================================================
-- MAIN BUILD FUNCTION
-- ============================================================

function MansionBuilder.build()
	local mansion = Instance.new("Folder")
	mansion.Name = "Mansion"
	mansion.Parent = workspace

	-- Exterior
	MansionBuilder.buildExterior(mansion)

	-- Ground Floor
	MansionBuilder.buildLobby(mansion)
	MansionBuilder.buildCorridor(mansion)
	MansionBuilder.buildLivingRoom(mansion)
	MansionBuilder.buildKitchen(mansion)
	MansionBuilder.buildDramaRoom(mansion)
	MansionBuilder.buildConfessionBooth(mansion)
	MansionBuilder.buildEliminationRoom(mansion)
	MansionBuilder.buildElevator(mansion)

	-- Upper Floor — Bedrooms
	MansionBuilder.buildBedroomFloor(mansion)

	-- Rooftop
	MansionBuilder.buildRooftop(mansion)

	-- Outer Shell — wraps the entire mansion
	MansionBuilder.buildOuterShell(mansion)

	-- Roof over upper floor
	MansionBuilder.buildRoof(mansion)

	-- Add doorways between rooms and corridor
	MansionBuilder.addAllDoorways(mansion)

	-- Add windows to exterior walls
	MansionBuilder.addExteriorWindows(mansion)

	-- Lighting
	MansionBuilder.setupLighting()

	print("[MansionBuilder] Luxury mansion built!")
	return mansion
end

-- ============================================================
-- OUTER SHELL — 4 exterior walls wrapping both floors
-- ============================================================

function MansionBuilder.buildOuterShell(parent)
	local shell = Instance.new("Folder")
	shell.Name = "OuterShell"
	shell.Parent = parent

	local totalHeight = FLOOR2_Y + WALL_HEIGHT + 1 -- full height of both floors
	local cy = totalHeight / 2

	-- West wall (front entrance side) — has main entrance doorway
	MansionBuilder.createWallWithDoorway(shell, "OuterWallWest",
		Vector3.new(OUTER_X_MIN, cy, OUTER_CZ),
		Vector3.new(1.5, totalHeight, OUTER_DEPTH),
		0, -- door centered at Z=0 (lobby entrance)
		WALL_COLOR, FLOOR_Y)

	-- East wall (back side, elevator side)
	MansionBuilder.createPart(shell, "OuterWallEast",
		Vector3.new(OUTER_X_MAX, cy, OUTER_CZ),
		Vector3.new(1.5, totalHeight, OUTER_DEPTH), WALL_COLOR)

	-- North wall (positive Z side)
	MansionBuilder.createPart(shell, "OuterWallNorth",
		Vector3.new(OUTER_CX, cy, OUTER_Z_MAX),
		Vector3.new(OUTER_WIDTH, totalHeight, 1.5), WALL_COLOR)

	-- South wall (negative Z side)
	MansionBuilder.createPart(shell, "OuterWallSouth",
		Vector3.new(OUTER_CX, cy, OUTER_Z_MIN),
		Vector3.new(OUTER_WIDTH, totalHeight, 1.5), WALL_COLOR)
end

-- ============================================================
-- ROOF — Covers the entire upper floor
-- ============================================================

function MansionBuilder.buildRoof(parent)
	local roof = Instance.new("Folder")
	roof.Name = "Roof"
	roof.Parent = parent

	local roofY = FLOOR2_Y + WALL_HEIGHT + 1

	-- Main flat roof slab covering the building footprint
	-- Rooftop area is open-air, so the roof covers everything EXCEPT the rooftop zone
	-- Rooftop zone is cx=100, cz=0, 120x100 — at Y = roofY
	-- The rooftop buildRooftop already creates a floor at ry = FLOOR2_Y + WALL_HEIGHT + 2
	-- So the roof covers the area that ISN'T the rooftop

	-- Roof section west of rooftop (X from OUTER_X_MIN to 40)
	local westRoofWidth = 40 - OUTER_X_MIN
	if westRoofWidth > 1 then
		MansionBuilder.createPart(roof, "RoofWest",
			Vector3.new(OUTER_X_MIN + westRoofWidth / 2, roofY, OUTER_CZ),
			Vector3.new(westRoofWidth, 1.5, OUTER_DEPTH),
			Color3.fromHex("#1A1225"), Enum.Material.SmoothPlastic)
	end

	-- Roof section east of rooftop (X from 160 to OUTER_X_MAX)
	local eastRoofWidth = OUTER_X_MAX - 160
	if eastRoofWidth > 1 then
		MansionBuilder.createPart(roof, "RoofEast",
			Vector3.new(160 + eastRoofWidth / 2, roofY, OUTER_CZ),
			Vector3.new(eastRoofWidth, 1.5, OUTER_DEPTH),
			Color3.fromHex("#1A1225"), Enum.Material.SmoothPlastic)
	end

	-- Roof section north of rooftop (X from 40 to 160, Z from rooftop north edge to building north)
	local rooftopNorthZ = 50
	local northRoofDepth = OUTER_Z_MAX - rooftopNorthZ
	if northRoofDepth > 1 then
		MansionBuilder.createPart(roof, "RoofNorth",
			Vector3.new(100, roofY, rooftopNorthZ + northRoofDepth / 2),
			Vector3.new(120, 1.5, northRoofDepth),
			Color3.fromHex("#1A1225"), Enum.Material.SmoothPlastic)
	end

	-- Roof section south of rooftop (X from 40 to 160, Z from building south to rooftop south edge)
	local rooftopSouthZ = -50
	local southRoofDepth = rooftopSouthZ - OUTER_Z_MIN
	if southRoofDepth > 1 then
		MansionBuilder.createPart(roof, "RoofSouth",
			Vector3.new(100, roofY, OUTER_Z_MIN + southRoofDepth / 2),
			Vector3.new(120, 1.5, southRoofDepth),
			Color3.fromHex("#1A1225"), Enum.Material.SmoothPlastic)
	end

	-- Rooftop stairwell / elevator access enclosure
	-- Small enclosed room on the rooftop for elevator exit
	local encX, encZ = 195, 0
	local encW, encD = 16, 16
	local encH = 12
	MansionBuilder.createPart(roof, "StairEncN",
		Vector3.new(encX, roofY + encH / 2 + 1, encZ + encD / 2),
		Vector3.new(encW, encH, 1), WALL_COLOR)
	MansionBuilder.createPart(roof, "StairEncS",
		Vector3.new(encX, roofY + encH / 2 + 1, encZ - encD / 2),
		Vector3.new(encW, encH, 1), WALL_COLOR)
	MansionBuilder.createPart(roof, "StairEncE",
		Vector3.new(encX + encW / 2, roofY + encH / 2 + 1, encZ),
		Vector3.new(1, encH, encD), WALL_COLOR)
	-- West side has doorway to rooftop
	MansionBuilder.createWallWithDoorway(roof, "StairEncW",
		Vector3.new(encX - encW / 2, roofY + encH / 2 + 1, encZ),
		Vector3.new(1, encH, encD),
		0, WALL_COLOR, roofY + 1)
	-- Small roof on enclosure
	MansionBuilder.createPart(roof, "StairEncRoof",
		Vector3.new(encX, roofY + encH + 1.5, encZ),
		Vector3.new(encW + 2, 1, encD + 2),
		Color3.fromHex("#1A1225"), Enum.Material.SmoothPlastic)

	-- Gold trim along roof edge
	MansionBuilder.createNeon(roof, "RoofTrimN",
		Vector3.new(OUTER_CX, roofY + 0.8, OUTER_Z_MAX),
		Vector3.new(OUTER_WIDTH, 0.3, 1.5), GOLD)
	MansionBuilder.createNeon(roof, "RoofTrimS",
		Vector3.new(OUTER_CX, roofY + 0.8, OUTER_Z_MIN),
		Vector3.new(OUTER_WIDTH, 0.3, 1.5), GOLD)
	MansionBuilder.createNeon(roof, "RoofTrimE",
		Vector3.new(OUTER_X_MAX, roofY + 0.8, OUTER_CZ),
		Vector3.new(1.5, 0.3, OUTER_DEPTH), GOLD)
	MansionBuilder.createNeon(roof, "RoofTrimW",
		Vector3.new(OUTER_X_MIN, roofY + 0.8, OUTER_CZ),
		Vector3.new(1.5, 0.3, OUTER_DEPTH), GOLD)
end

-- ============================================================
-- ADD ALL DOORWAYS — Punch doorways between rooms and corridor
-- ============================================================

function MansionBuilder.addAllDoorways(mansion)
	-- The corridor runs at X=110, Z=0, stretching X from 10 to 210, width 18 (Z from -9 to 9)
	-- Rooms connect to the corridor via their walls facing the corridor

	-- Lobby (cx=20, cz=0, 50x50) — connects east to corridor
	-- The lobby's east wall faces the corridor. Remove it and add doorway.
	local lobby = mansion:FindFirstChild("Lobby")
	if lobby then
		MansionBuilder.addDoorwayToWall(lobby, "WallNorth", 0, FLOOR_Y)
		MansionBuilder.addDoorwayToWall(lobby, "WallSouth", 0, FLOOR_Y)
	end

	-- Living Room (cx=60, cz=30, 45x45) — south wall faces corridor (corridor Z=+9)
	local livingRoom = mansion:FindFirstChild("LivingRoom")
	if livingRoom then
		MansionBuilder.addDoorwayToWall(livingRoom, "WallSouth", 0, FLOOR_Y)
	end

	-- Kitchen (cx=100, cz=30, 45x45) — south wall faces corridor
	local kitchen = mansion:FindFirstChild("Kitchen")
	if kitchen then
		MansionBuilder.addDoorwayToWall(kitchen, "WallSouth", 0, FLOOR_Y)
	end

	-- Drama Room (cx=60, cz=-35, 45x45) — north wall faces corridor
	local dramaRoom = mansion:FindFirstChild("DramaRoom")
	if dramaRoom then
		MansionBuilder.addDoorwayToWall(dramaRoom, "WallNorth", 0, FLOOR_Y)
	end

	-- Confession Booth (cx=100, cz=-35, 25x25) — north wall faces corridor
	local confession = mansion:FindFirstChild("ConfessionBooth")
	if confession then
		MansionBuilder.addDoorwayToWall(confession, "WallNorth", 0, FLOOR_Y)
	end

	-- Elimination Room (cx=150, cz=-35, 50x50) — north wall faces corridor
	local elimination = mansion:FindFirstChild("EliminationRoom")
	if elimination then
		MansionBuilder.addDoorwayToWall(elimination, "WallNorth", 0, FLOOR_Y)
	end
end

-- ============================================================
-- ADD EXTERIOR WINDOWS — Glass windows on outer walls
-- ============================================================

function MansionBuilder.addExteriorWindows(mansion)
	local shell = mansion:FindFirstChild("OuterShell")
	if not shell then return end

	local winH = 6
	local winW = 8
	local winD = 0.5

	-- Kitchen windows on north outer wall (kitchen faces north, city views)
	-- Kitchen is at cx=100, cz=30, so windows on the north outer wall at Z=OUTER_Z_MAX
	for i = 1, 3 do
		local wx = 80 + (i - 1) * 15
		MansionBuilder.createWindow(shell,
			Vector3.new(wx, WALL_HEIGHT / 2 + 2, OUTER_Z_MAX - 0.2),
			Vector3.new(winW, winH, winD),
			"KitchenWin" .. i)
	end

	-- Living Room windows on north outer wall
	for i = 1, 2 do
		local wx = 45 + (i - 1) * 18
		MansionBuilder.createWindow(shell,
			Vector3.new(wx, WALL_HEIGHT / 2 + 2, OUTER_Z_MAX - 0.2),
			Vector3.new(winW, winH, winD),
			"LivingWin" .. i)
	end

	-- South wall windows (Drama Room, Elimination Room)
	for i = 1, 3 do
		local wx = 50 + (i - 1) * 20
		MansionBuilder.createWindow(shell,
			Vector3.new(wx, WALL_HEIGHT / 2 + 2, OUTER_Z_MIN + 0.2),
			Vector3.new(winW, winH, winD),
			"SouthWin" .. i)
	end

	-- Upper floor windows (bedrooms) — north side
	for i = 1, 4 do
		local wx = 50 + (i - 1) * 35
		MansionBuilder.createWindow(shell,
			Vector3.new(wx, FLOOR2_Y + WALL_HEIGHT / 2 + 2, OUTER_Z_MAX - 0.2),
			Vector3.new(winW, winH, winD),
			"UpperNorthWin" .. i)
	end

	-- Upper floor windows — south side
	for i = 1, 4 do
		local wx = 50 + (i - 1) * 35
		MansionBuilder.createWindow(shell,
			Vector3.new(wx, FLOOR2_Y + WALL_HEIGHT / 2 + 2, OUTER_Z_MIN + 0.2),
			Vector3.new(winW, winH, winD),
			"UpperSouthWin" .. i)
	end

	-- East wall windows
	for i = 1, 2 do
		local wz = -20 + (i - 1) * 40
		MansionBuilder.createWindow(shell,
			Vector3.new(OUTER_X_MAX - 0.2, WALL_HEIGHT / 2 + 2, wz),
			Vector3.new(winD, winH, winW),
			"EastWin" .. i)
	end
end

-- ============================================================
-- MANSION EXTERIOR
-- ============================================================

function MansionBuilder.buildExterior(parent)
	local ext = Instance.new("Folder")
	ext.Name = "Exterior"
	ext.Parent = parent

	-- Ground plane (large)
	MansionBuilder.createPart(ext, "Ground",
		Vector3.new(100, -1, 0),
		Vector3.new(400, 1, 400),
		Color3.fromHex("#1A1A1A"), Enum.Material.Concrete)

	-- Driveway
	MansionBuilder.createPart(ext, "Driveway",
		Vector3.new(-30, -0.4, 0),
		Vector3.new(60, 0.5, 20),
		Color3.fromHex("#2A2A2A"), Enum.Material.Concrete)

	-- Grand entrance columns (4 pairs)
	for i = 1, 4 do
		local zOff = (i - 2.5) * 8
		for side = -1, 1, 2 do
			local col = Instance.new("Part")
			col.Name = "Column" .. i .. "_" .. (side == 1 and "L" or "R")
			col.Shape = Enum.PartType.Cylinder
			col.Size = Vector3.new(FLOOR2_Y + WALL_HEIGHT + 5, 3, 3)
			col.Position = Vector3.new(-5, (FLOOR2_Y + WALL_HEIGHT + 5) / 2 - 0.5, zOff)
			col.Color = MARBLE_WHITE
			col.Material = Enum.Material.Marble
			col.Anchored = true
			col.Parent = ext
		end
	end

	-- Entrance facade wall
	MansionBuilder.createPart(ext, "Facade",
		Vector3.new(-8, (FLOOR2_Y + WALL_HEIGHT) / 2, 0),
		Vector3.new(2, FLOOR2_Y + WALL_HEIGHT + 2, 50),
		WALL_COLOR)

	-- "MANSION OF MAYHEM" entrance sign
	MansionBuilder.createSign(ext, "MANSION OF MAYHEM",
		Vector3.new(-9.5, FLOOR2_Y + WALL_HEIGHT - 2, 0), 18, GOLD_BRIGHT)

	-- Neon glow behind sign
	MansionBuilder.createNeon(ext, "SignGlow",
		Vector3.new(-8.5, FLOOR2_Y + WALL_HEIGHT - 2, 0),
		Vector3.new(20, 4, 0.5), GOLD)

	-- Fountain in front
	MansionBuilder.createFountain(ext, Vector3.new(-30, -0.5, 0))

	-- Tropical landscaping — palm trees
	local treePositions = {
		Vector3.new(-45, -0.5, 15),
		Vector3.new(-45, -0.5, -15),
		Vector3.new(-20, -0.5, 25),
		Vector3.new(-20, -0.5, -25),
		Vector3.new(5, -0.5, 30),
		Vector3.new(5, -0.5, -30),
	}
	for i, tPos in ipairs(treePositions) do
		MansionBuilder.createPlant(ext, tPos, 12 + (i % 3) * 2)
	end

	-- Bushes (green spheres low to ground)
	for i = 1, 8 do
		local bush = Instance.new("Part")
		bush.Name = "Bush" .. i
		bush.Shape = Enum.PartType.Ball
		bush.Size = Vector3.new(4, 3, 4)
		bush.Position = Vector3.new(-15 + (i - 1) * 4, 1, (i % 2 == 0) and 22 or -22)
		bush.Color = Color3.fromHex("#1B5E3B")
		bush.Material = Enum.Material.Grass
		bush.Anchored = true
		bush.Parent = ext
	end

	-- Night sky dome with stars
	local sky = Instance.new("Part")
	sky.Name = "NightSky"
	sky.Shape = Enum.PartType.Ball
	sky.Size = Vector3.new(600, 600, 600)
	sky.Position = Vector3.new(100, 100, 0)
	sky.Color = Color3.fromHex("#050510")
	sky.Material = Enum.Material.SmoothPlastic
	sky.Transparency = 0.3
	sky.Anchored = true
	sky.CanCollide = false
	sky.Parent = ext

	-- Stars
	for i = 1, 40 do
		local angle1 = math.random() * math.pi
		local angle2 = math.random() * 2 * math.pi
		local r = 280
		local sx = 100 + r * math.sin(angle1) * math.cos(angle2)
		local sy = 100 + math.abs(r * math.cos(angle1))
		local sz = r * math.sin(angle1) * math.sin(angle2)
		MansionBuilder.createNeon(ext, "Star" .. i,
			Vector3.new(sx, sy, sz),
			Vector3.new(0.5, 0.5, 0.5),
			Color3.new(1, 1, 1))
	end
end

-- ============================================================
-- THE LOBBY — Luxury entrance (NO spawn here — spawn is at Hollywood)
-- ============================================================

function MansionBuilder.buildLobby(parent)
	local lobby = Instance.new("Folder")
	lobby.Name = "Lobby"
	lobby.Parent = parent

	local cx, cz = 20, 0
	local roomW, roomD = 50, 50

	-- Floor (marble)
	MansionBuilder.createPart(lobby, "Floor",
		Vector3.new(cx, -0.5, cz),
		Vector3.new(roomW, 1, roomD),
		MARBLE_WHITE, Enum.Material.Marble)

	-- Ceiling
	MansionBuilder.createPart(lobby, "Ceiling",
		Vector3.new(cx, WALL_HEIGHT, cz),
		Vector3.new(roomW, 1, roomD), DARK)

	-- Walls (all 4 walls — doorways added later)
	MansionBuilder.createPart(lobby, "WallWest",
		Vector3.new(cx - roomW / 2, WALL_HEIGHT / 2, cz),
		Vector3.new(1, WALL_HEIGHT, roomD), WALL_COLOR)
	MansionBuilder.createPart(lobby, "WallNorth",
		Vector3.new(cx, WALL_HEIGHT / 2, cz + roomD / 2),
		Vector3.new(roomW, WALL_HEIGHT, 1), WALL_COLOR)
	MansionBuilder.createPart(lobby, "WallSouth",
		Vector3.new(cx, WALL_HEIGHT / 2, cz - roomD / 2),
		Vector3.new(roomW, WALL_HEIGHT, 1), WALL_COLOR)
	MansionBuilder.createPart(lobby, "WallEast",
		Vector3.new(cx + roomW / 2, WALL_HEIGHT / 2, cz),
		Vector3.new(1, WALL_HEIGHT, roomD), WALL_COLOR)

	-- Gold floor neon trim
	MansionBuilder.createNeon(lobby, "FloorTrimN", Vector3.new(cx, 0.1, cz + roomD / 2 - 1), Vector3.new(roomW - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(lobby, "FloorTrimS", Vector3.new(cx, 0.1, cz - roomD / 2 + 1), Vector3.new(roomW - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(lobby, "FloorTrimW", Vector3.new(cx - roomW / 2 + 1, 0.1, cz), Vector3.new(0.3, 0.2, roomD - 2), GOLD)
	MansionBuilder.createNeon(lobby, "FloorTrimE", Vector3.new(cx + roomW / 2 - 1, 0.1, cz), Vector3.new(0.3, 0.2, roomD - 2), GOLD)

	-- Gold ceiling cove trim
	MansionBuilder.createNeon(lobby, "CeilTrimN", Vector3.new(cx, WALL_HEIGHT - 0.3, cz + roomD / 2 - 1), Vector3.new(roomW - 2, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(lobby, "CeilTrimS", Vector3.new(cx, WALL_HEIGHT - 0.3, cz - roomD / 2 + 1), Vector3.new(roomW - 2, 0.2, 0.3), GOLD)

	-- Raised center platform (circular)
	local platform = Instance.new("Part")
	platform.Name = "CenterPlatform"
	platform.Shape = Enum.PartType.Cylinder
	platform.Size = Vector3.new(1.5, 20, 20)
	platform.Position = Vector3.new(cx, 0.75, cz)
	platform.Orientation = Vector3.new(0, 0, 90)
	platform.Color = MARBLE_WHITE
	platform.Material = Enum.Material.Marble
	platform.Anchored = true
	platform.Parent = lobby

	-- "Welcome to The Lobby" neon sign on back wall (pink/rose gold)
	MansionBuilder.createSign(lobby, "Welcome to The Lobby",
		Vector3.new(cx - roomW / 2 + 1, 10, cz), 14, ROSE_GOLD)
	MansionBuilder.createNeon(lobby, "SignGlow",
		Vector3.new(cx - roomW / 2 + 0.5, 10, cz),
		Vector3.new(0.3, 4, 16), NEON_PINK)

	-- Circular neon ring chandelier
	MansionBuilder.createChandelier(lobby, Vector3.new(cx, WALL_HEIGHT - 2, cz), 8, GOLD_BRIGHT)

	-- 4 curved cream couches arranged in circle facing center
	local couchPositions = {
		{pos = Vector3.new(cx, 0, cz + 12), rot = Vector3.new(0, 0, 0)},
		{pos = Vector3.new(cx, 0, cz - 12), rot = Vector3.new(0, 180, 0)},
		{pos = Vector3.new(cx + 12, 0, cz), rot = Vector3.new(0, -90, 0)},
		{pos = Vector3.new(cx - 10, 0, cz), rot = Vector3.new(0, 90, 0)},
	}

	for i, cData in ipairs(couchPositions) do
		MansionBuilder.createCouch(lobby, cData.pos + Vector3.new(0, 1.5, 0),
			Vector3.new(8, 2, 4), cData.rot, COUCH_CREAM)
	end

	-- Round glass coffee table with gold base (center)
	local tableBase = Instance.new("Part")
	tableBase.Name = "CoffeeTableBase"
	tableBase.Shape = Enum.PartType.Cylinder
	tableBase.Size = Vector3.new(2.5, 2, 2)
	tableBase.Position = Vector3.new(cx, 2.5, cz)
	tableBase.Color = GOLD
	tableBase.Material = Enum.Material.Metal
	tableBase.Anchored = true
	tableBase.Parent = lobby

	local tableTop = Instance.new("Part")
	tableTop.Name = "CoffeeTableTop"
	tableTop.Shape = Enum.PartType.Cylinder
	tableTop.Size = Vector3.new(1, 6, 6)
	tableTop.Position = Vector3.new(cx, 3.8, cz)
	tableTop.Orientation = Vector3.new(0, 0, 90)
	tableTop.Color = GLASS_BLUE
	tableTop.Material = Enum.Material.Glass
	tableTop.Transparency = 0.5
	tableTop.Anchored = true
	tableTop.Parent = lobby

	-- Bar area (east side)
	local barX = cx + 16
	local barZ = cz + 15
	-- Bar counter
	MansionBuilder.createPart(lobby, "BarCounter",
		Vector3.new(barX, 2, barZ),
		Vector3.new(12, 4, 3), MARBLE_WHITE, Enum.Material.Marble)
	-- Bar counter top accent
	MansionBuilder.createNeon(lobby, "BarTopGlow",
		Vector3.new(barX, 4.1, barZ),
		Vector3.new(12, 0.2, 3), GOLD)

	-- Bar back shelves
	MansionBuilder.createPart(lobby, "BarBackWall",
		Vector3.new(barX, 6, barZ + 3),
		Vector3.new(12, 8, 1), WALL_LIGHT)
	-- Shelves
	for s = 1, 3 do
		MansionBuilder.createPart(lobby, "BarShelf" .. s,
			Vector3.new(barX, 3.5 + s * 2.5, barZ + 2.5),
			Vector3.new(10, 0.3, 2), GOLD, Enum.Material.Metal)
	end
	-- Bottles (colored parts on shelves)
	local bottleColors = {NEON_PINK, GOLD_BRIGHT, PURPLE, SKY_BLUE, CRIMSON, AMBER}
	for s = 1, 3 do
		for b = 1, 4 do
			local bottle = Instance.new("Part")
			bottle.Name = "Bottle" .. s .. "_" .. b
			bottle.Size = Vector3.new(0.6, 1.8, 0.6)
			bottle.Position = Vector3.new(barX - 3.5 + b * 2, 4.5 + s * 2.5, barZ + 2.5)
			bottle.Color = bottleColors[((s + b - 2) % #bottleColors) + 1]
			bottle.Material = Enum.Material.Glass
			bottle.Transparency = 0.3
			bottle.Anchored = true
			bottle.CanCollide = false
			bottle.Parent = lobby
		end
	end

	-- Bar stools
	for i = 1, 4 do
		MansionBuilder.createBarStool(lobby, Vector3.new(barX - 4.5 + i * 3, 0, barZ - 3))
	end

	-- Tropical plants (4 corners-ish)
	MansionBuilder.createPlant(lobby, Vector3.new(cx - 20, 0, cz + 20), 8)
	MansionBuilder.createPlant(lobby, Vector3.new(cx - 20, 0, cz - 20), 9)
	MansionBuilder.createPlant(lobby, Vector3.new(cx + 20, 0, cz - 20), 7)
	MansionBuilder.createPlant(lobby, Vector3.new(cx + 20, 0, cz + 5), 8)

	-- Lobby teleport destination (where bus passengers arrive)
	-- No SpawnLocation here — spawn is at Hollywood station
	local arrivalMark = MansionBuilder.createPart(lobby, "ArrivalPoint",
		Vector3.new(cx, 0.1, cz),
		Vector3.new(8, 0.2, 8), GOLD, Enum.Material.Neon)
	arrivalMark.Transparency = 0.8
	arrivalMark.CanCollide = false
end

-- ============================================================
-- CONFESSIONAL BOOTH — Dark, moody, intimate
-- ============================================================

function MansionBuilder.buildConfessionBooth(parent)
	local cx, cz = 100, -35
	local roomW, roomD = 25, 25

	local room = MansionBuilder.createRoomShell(parent, "ConfessionBooth",
		cx, FLOOR_Y, cz, roomW, roomD, WALL_HEIGHT,
		PURPLE_DARK, Color3.fromHex("#120820"), DARK, Enum.Material.Marble)

	-- Override floor with dark dramatic marble
	MansionBuilder.createNeon(room, "PurpleFloorGlow",
		Vector3.new(cx, 0.15, cz),
		Vector3.new(roomW - 4, 0.2, roomD - 4), PURPLE)

	-- Large teal/dark green velvet couch
	MansionBuilder.createCouch(room,
		Vector3.new(cx, 1.5, cz + 5),
		Vector3.new(12, 3, 5), Vector3.new(0, 180, 0), COUCH_GREEN)

	-- Extra sequin/sparkle pillows on couch (gold + pink)
	MansionBuilder.createPart(room, "GoldPillow1",
		Vector3.new(cx - 4, 3.5, cz + 5),
		Vector3.new(1.5, 1, 1.2), GOLD_BRIGHT, Enum.Material.Foil)
	MansionBuilder.createPart(room, "PinkPillow1",
		Vector3.new(cx + 4, 3.5, cz + 5),
		Vector3.new(1.5, 1, 1.2), NEON_PINK, Enum.Material.Foil)
	MansionBuilder.createPart(room, "GoldPillow2",
		Vector3.new(cx - 1, 3.5, cz + 5),
		Vector3.new(1.2, 0.8, 1), ROSE_GOLD, Enum.Material.Foil)

	-- "Mansion Mayhem" neon sign on wall behind couch
	MansionBuilder.createSign(room, "Mansion Mayhem",
		Vector3.new(cx, 9, cz + roomD / 2 - 1), 12, NEON_PINK)
	MansionBuilder.createNeon(room, "SignBackGlow",
		Vector3.new(cx, 9, cz + roomD / 2 - 0.5),
		Vector3.new(14, 4, 0.3), NEON_PINK)

	-- Crown icon above text (gold neon)
	MansionBuilder.createNeon(room, "CrownBase",
		Vector3.new(cx, 12, cz + roomD / 2 - 1),
		Vector3.new(6, 0.5, 0.3), GOLD_BRIGHT)
	MansionBuilder.createNeon(room, "CrownPeak1",
		Vector3.new(cx - 2, 13, cz + roomD / 2 - 1),
		Vector3.new(0.5, 2, 0.3), GOLD_BRIGHT)
	MansionBuilder.createNeon(room, "CrownPeak2",
		Vector3.new(cx, 13.5, cz + roomD / 2 - 1),
		Vector3.new(0.5, 2.5, 0.3), GOLD_BRIGHT)
	MansionBuilder.createNeon(room, "CrownPeak3",
		Vector3.new(cx + 2, 13, cz + roomD / 2 - 1),
		Vector3.new(0.5, 2, 0.3), GOLD_BRIGHT)

	-- Two palm tree neon signs flanking (purple/blue)
	MansionBuilder.createNeon(room, "PalmLeftTrunk",
		Vector3.new(cx - 8, 8, cz + roomD / 2 - 1),
		Vector3.new(0.5, 6, 0.3), PURPLE)
	MansionBuilder.createNeon(room, "PalmLeftLeaf1",
		Vector3.new(cx - 9, 11.5, cz + roomD / 2 - 1),
		Vector3.new(3, 0.5, 0.3), SKY_BLUE)
	MansionBuilder.createNeon(room, "PalmLeftLeaf2",
		Vector3.new(cx - 7, 12, cz + roomD / 2 - 1),
		Vector3.new(3, 0.5, 0.3), SKY_BLUE)
	MansionBuilder.createNeon(room, "PalmRightTrunk",
		Vector3.new(cx + 8, 8, cz + roomD / 2 - 1),
		Vector3.new(0.5, 6, 0.3), PURPLE)
	MansionBuilder.createNeon(room, "PalmRightLeaf1",
		Vector3.new(cx + 9, 11.5, cz + roomD / 2 - 1),
		Vector3.new(3, 0.5, 0.3), SKY_BLUE)
	MansionBuilder.createNeon(room, "PalmRightLeaf2",
		Vector3.new(cx + 7, 12, cz + roomD / 2 - 1),
		Vector3.new(3, 0.5, 0.3), SKY_BLUE)

	-- Purple bead curtain at entrance (thin purple neon strips)
	local entranceZ = cz - roomD / 2
	for i = 1, 10 do
		local bx = cx - 5 + i
		MansionBuilder.createNeon(room, "BeadCurtain" .. i,
			Vector3.new(bx, WALL_HEIGHT / 2, entranceZ + 0.5),
			Vector3.new(0.15, WALL_HEIGHT - 2, 0.15), PURPLE)
	end
end

-- ============================================================
-- ROOFTOP — Open air party paradise
-- ============================================================

function MansionBuilder.buildRooftop(parent)
	local rooftop = Instance.new("Folder")
	rooftop.Name = "Rooftop"
	rooftop.Parent = parent

	local ry = FLOOR2_Y + WALL_HEIGHT + 2
	local cx, cz = 100, 0
	local roofW, roofD = 120, 100

	-- Floor (marble)
	MansionBuilder.createPart(rooftop, "Floor",
		Vector3.new(cx, ry - 0.5, cz),
		Vector3.new(roofW, 1, roofD),
		MARBLE_WHITE, Enum.Material.Marble)

	-- Low glass railing around edge
	for _, wall in ipairs({
		{"RailN", Vector3.new(cx, ry + 2, cz + roofD / 2), Vector3.new(roofW, 4, 1)},
		{"RailS", Vector3.new(cx, ry + 2, cz - roofD / 2), Vector3.new(roofW, 4, 1)},
		{"RailE", Vector3.new(cx + roofW / 2, ry + 2, cz), Vector3.new(1, 4, roofD)},
		{"RailW", Vector3.new(cx - roofW / 2, ry + 2, cz), Vector3.new(1, 4, roofD)},
	}) do
		local rail = MansionBuilder.createPart(rooftop, wall[1], wall[2], wall[3],
			GLASS_BLUE, Enum.Material.Glass)
		rail.Transparency = 0.6
	end

	-- Gold railing top trim
	MansionBuilder.createNeon(rooftop, "RailTopN", Vector3.new(cx, ry + 4.1, cz + roofD / 2), Vector3.new(roofW, 0.3, 1.2), GOLD)
	MansionBuilder.createNeon(rooftop, "RailTopS", Vector3.new(cx, ry + 4.1, cz - roofD / 2), Vector3.new(roofW, 0.3, 1.2), GOLD)
	MansionBuilder.createNeon(rooftop, "RailTopE", Vector3.new(cx + roofW / 2, ry + 4.1, cz), Vector3.new(1.2, 0.3, roofD), GOLD)
	MansionBuilder.createNeon(rooftop, "RailTopW", Vector3.new(cx - roofW / 2, ry + 4.1, cz), Vector3.new(1.2, 0.3, roofD), GOLD)

	-- Infinity pool
	local pool = Instance.new("Part")
	pool.Name = "Pool"
	pool.Shape = Enum.PartType.Cylinder
	pool.Size = Vector3.new(3, 35, 20)
	pool.Position = Vector3.new(cx + 20, ry + 0.8, cz + 15)
	pool.Orientation = Vector3.new(0, 0, 90)
	pool.Color = SKY_BLUE
	pool.Material = Enum.Material.Neon
	pool.Transparency = 0.4
	pool.Anchored = true
	pool.Parent = rooftop

	-- Pool border
	local poolBorder = Instance.new("Part")
	poolBorder.Name = "PoolBorder"
	poolBorder.Shape = Enum.PartType.Cylinder
	poolBorder.Size = Vector3.new(1, 37, 22)
	poolBorder.Position = Vector3.new(cx + 20, ry + 0.2, cz + 15)
	poolBorder.Orientation = Vector3.new(0, 0, 90)
	poolBorder.Color = MARBLE_WHITE
	poolBorder.Material = Enum.Material.Marble
	poolBorder.Anchored = true
	poolBorder.Parent = rooftop

	-- Circular fire pit in center
	local pitBase = Instance.new("Part")
	pitBase.Name = "FirePitBase"
	pitBase.Shape = Enum.PartType.Cylinder
	pitBase.Size = Vector3.new(2, 10, 10)
	pitBase.Position = Vector3.new(cx - 15, ry + 0.8, cz - 5)
	pitBase.Orientation = Vector3.new(0, 0, 90)
	pitBase.Color = Color3.fromHex("#3A3A3A")
	pitBase.Material = Enum.Material.Slate
	pitBase.Anchored = true
	pitBase.Parent = rooftop

	-- Fire glow
	local fire = MansionBuilder.createNeon(rooftop, "FireGlow",
		Vector3.new(cx - 15, ry + 2.5, cz - 5),
		Vector3.new(5, 3, 5), Color3.fromHex("#FF6600"))
	local firePL = Instance.new("PointLight")
	firePL.Color = Color3.fromHex("#FF8800")
	firePL.Brightness = 3
	firePL.Range = 35
	firePL.Parent = fire

	-- Curved lounge seating around fire pit (C-shape)
	local fireX, fireZ = cx - 15, cz - 5
	local loungeAngles = {0, 45, 90, 135, 180, 225, 270}
	for i, angle in ipairs(loungeAngles) do
		local rad = math.rad(angle)
		local lx = fireX + math.cos(rad) * 9
		local lz = fireZ + math.sin(rad) * 9
		local lounger = MansionBuilder.createPart(rooftop, "Lounger" .. i,
			Vector3.new(lx, ry + 1, lz),
			Vector3.new(5, 2, 3), COUCH_CREAM, Enum.Material.Fabric)
		lounger.Orientation = Vector3.new(0, -angle, 0)
	end

	-- Gold accent side tables
	for i = 1, 4 do
		local angle = math.rad((i - 1) * 90 + 45)
		local st = Instance.new("Part")
		st.Name = "SideTable" .. i
		st.Shape = Enum.PartType.Cylinder
		st.Size = Vector3.new(1.5, 2, 2)
		st.Position = Vector3.new(fireX + math.cos(angle) * 12, ry + 1.2, fireZ + math.sin(angle) * 12)
		st.Color = GOLD
		st.Material = Enum.Material.Metal
		st.Anchored = true
		st.Parent = rooftop
	end

	-- Palm trees on rooftop
	MansionBuilder.createPlant(rooftop, Vector3.new(cx - 50, ry, cz + 40), 10)
	MansionBuilder.createPlant(rooftop, Vector3.new(cx + 50, ry, cz + 40), 12)
	MansionBuilder.createPlant(rooftop, Vector3.new(cx - 50, ry, cz - 40), 11)
	MansionBuilder.createPlant(rooftop, Vector3.new(cx + 50, ry, cz - 40), 9)

	-- "Party" neon sign on building wall side
	MansionBuilder.createSign(rooftop, "PARTY",
		Vector3.new(cx - roofW / 2 + 2, ry + 6, cz), 10, NEON_PINK)

	MansionBuilder.createNeon(rooftop, "PartyGlow",
		Vector3.new(cx - roofW / 2 + 1, ry + 6, cz),
		Vector3.new(0.3, 4, 12), NEON_PINK)

	-- City skyline backdrop
	MansionBuilder.createSkyline(rooftop)

	-- Purple/pink ambient sky lighting
	local skyLight1 = MansionBuilder.createNeon(rooftop, "SkyGlow1",
		Vector3.new(cx, ry + 30, cz),
		Vector3.new(60, 0.5, 60), PURPLE)
	skyLight1.Transparency = 0.7
	local skyLight2 = MansionBuilder.createNeon(rooftop, "SkyGlow2",
		Vector3.new(cx, ry + 35, cz),
		Vector3.new(80, 0.5, 80), NEON_PINK)
	skyLight2.Transparency = 0.8
end

-- ============================================================
-- KITCHEN — Luxury marble & pendant lights
-- ============================================================

function MansionBuilder.buildKitchen(parent)
	local cx, cz = 100, 30
	local roomW, roomD = ROOM_SIZE, ROOM_SIZE

	local room = MansionBuilder.createRoomShell(parent, "Kitchen",
		cx, FLOOR_Y, cz, roomW, roomD, WALL_HEIGHT,
		MARBLE_WHITE, WALL_COLOR, DARK)

	-- Sign
	MansionBuilder.createSign(room, "THE KITCHEN",
		Vector3.new(cx, WALL_HEIGHT - 2, cz - roomD / 2 + 1), 10, GOLD)

	-- Large marble island (center)
	MansionBuilder.createPart(room, "Island",
		Vector3.new(cx, 2, cz),
		Vector3.new(16, 4, 5), MARBLE_WHITE, Enum.Material.Marble)
	-- Island top accent
	MansionBuilder.createNeon(room, "IslandTopGlow",
		Vector3.new(cx, 4.1, cz),
		Vector3.new(16, 0.15, 5), GOLD)

	-- 4 bar stools at island
	for i = 1, 4 do
		MansionBuilder.createBarStool(room, Vector3.new(cx - 6 + i * 3, 0, cz - 4))
	end

	-- 3 pendant lights above island
	for i = 1, 3 do
		MansionBuilder.createPendantLight(room,
			Vector3.new(cx - 5 + (i - 1) * 5, WALL_HEIGHT - 3, cz),
			AMBER, 1.5)
	end

	-- Marble counters along back wall
	MansionBuilder.createPart(room, "BackCounter",
		Vector3.new(cx, 2, cz + roomD / 2 - 2),
		Vector3.new(roomW - 4, 4, 3), MARBLE_WHITE, Enum.Material.Marble)
	-- Backsplash
	MansionBuilder.createPart(room, "Backsplash",
		Vector3.new(cx, 6, cz + roomD / 2 - 1),
		Vector3.new(roomW - 4, 4, 0.5), Color3.fromHex("#C8B8A8"), Enum.Material.Marble)

	-- Under-counter neon strip (gold)
	MansionBuilder.createNeon(room, "UnderCounterGlow",
		Vector3.new(cx, 0.3, cz + roomD / 2 - 2),
		Vector3.new(roomW - 6, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(room, "UnderIslandGlow",
		Vector3.new(cx, 0.3, cz),
		Vector3.new(16, 0.2, 0.3), GOLD)

	-- Neon heart sign on side wall (pink)
	MansionBuilder.createNeon(room, "HeartL",
		Vector3.new(cx - roomW / 2 + 1, 9, cz),
		Vector3.new(0.3, 2, 2), NEON_PINK)
	MansionBuilder.createNeon(room, "HeartR",
		Vector3.new(cx - roomW / 2 + 1, 9, cz + 2),
		Vector3.new(0.3, 2, 2), NEON_PINK)
	MansionBuilder.createNeon(room, "HeartV",
		Vector3.new(cx - roomW / 2 + 1, 7.5, cz + 1),
		Vector3.new(0.3, 1.5, 1), NEON_PINK)

	-- Flowers in vases on counter
	MansionBuilder.createFlowerVase(room, Vector3.new(cx - 8, 4, cz + roomD / 2 - 2))
	MansionBuilder.createFlowerVase(room, Vector3.new(cx + 8, 4, cz + roomD / 2 - 2))

	-- Wine glasses on counter (tiny transparent cylinders)
	for i = 1, 4 do
		local glass = Instance.new("Part")
		glass.Name = "WineGlass" .. i
		glass.Shape = Enum.PartType.Cylinder
		glass.Size = Vector3.new(1.5, 0.8, 0.8)
		glass.Position = Vector3.new(cx - 3 + i * 2, 4.8, cz + roomD / 2 - 2)
		glass.Color = Color3.new(1, 1, 1)
		glass.Material = Enum.Material.Glass
		glass.Transparency = 0.6
		glass.Anchored = true
		glass.CanCollide = false
		glass.Parent = room
	end
end

-- ============================================================
-- CORRIDOR — Grand hallway connecting rooms
-- ============================================================

function MansionBuilder.buildCorridor(parent)
	local corr = Instance.new("Folder")
	corr.Name = "Corridor"
	corr.Parent = parent

	local cx, cz = 110, 0
	local corrLen = 200
	local corrWidth = 18

	-- Floor (polished marble, reflective)
	MansionBuilder.createPart(corr, "Floor",
		Vector3.new(cx, -0.5, cz),
		Vector3.new(corrLen, 1, corrWidth),
		MARBLE_WHITE, Enum.Material.Marble)

	-- Ceiling
	MansionBuilder.createPart(corr, "Ceiling",
		Vector3.new(cx, WALL_HEIGHT, cz),
		Vector3.new(corrLen, 1, corrWidth), DARK)

	-- Corridor walls (north and south) — these are the interior corridor walls
	-- Rooms branch off from these walls via doorways
	MansionBuilder.createPart(corr, "WallNorth",
		Vector3.new(cx, WALL_HEIGHT / 2, cz + corrWidth / 2),
		Vector3.new(corrLen, WALL_HEIGHT, 1), WALL_COLOR)
	MansionBuilder.createPart(corr, "WallSouth",
		Vector3.new(cx, WALL_HEIGHT / 2, cz - corrWidth / 2),
		Vector3.new(corrLen, WALL_HEIGHT, 1), WALL_COLOR)

	-- Gold LED strips along ceiling edges
	MansionBuilder.createNeon(corr, "CeilStripN",
		Vector3.new(cx, WALL_HEIGHT - 0.3, cz + corrWidth / 2 - 0.5),
		Vector3.new(corrLen, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(corr, "CeilStripS",
		Vector3.new(cx, WALL_HEIGHT - 0.3, cz - corrWidth / 2 + 0.5),
		Vector3.new(corrLen, 0.2, 0.3), GOLD)

	-- Gold LED strips along floor edges
	MansionBuilder.createNeon(corr, "FloorStripN",
		Vector3.new(cx, 0.1, cz + corrWidth / 2 - 0.5),
		Vector3.new(corrLen, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(corr, "FloorStripS",
		Vector3.new(cx, 0.1, cz - corrWidth / 2 + 0.5),
		Vector3.new(corrLen, 0.2, 0.3), GOLD)

	-- Wall sconces every 15 studs
	local startX = cx - corrLen / 2 + 10
	local endX = cx + corrLen / 2 - 10
	for x = startX, endX, 15 do
		-- North wall sconce
		MansionBuilder.createSconce(corr,
			Vector3.new(x, 8, cz + corrWidth / 2 - 1),
			Vector3.new(0, 0, -1))
		-- South wall sconce
		MansionBuilder.createSconce(corr,
			Vector3.new(x, 8, cz - corrWidth / 2 + 1),
			Vector3.new(0, 0, 1))
	end

	-- Framed art on walls (every 20 studs)
	for x = startX + 7, endX, 20 do
		-- North wall art
		MansionBuilder.createArtFrame(corr,
			Vector3.new(x, 7, cz + corrWidth / 2 - 0.5),
			Vector3.new(5, 4, 0.3))
		-- South wall art
		MansionBuilder.createArtFrame(corr,
			Vector3.new(x, 7, cz - corrWidth / 2 + 0.5),
			Vector3.new(5, 4, 0.3))
	end

	-- Flower vase pedestals at intervals
	for x = startX + 15, endX, 30 do
		MansionBuilder.createFlowerVase(corr, Vector3.new(x, 0, cz + 5))
		MansionBuilder.createFlowerVase(corr, Vector3.new(x, 0, cz - 5))
	end

	-- Add doorways in corridor walls to connect to rooms
	-- Living Room is at Z=30, corridor north wall at Z=9 — doorway at X=60
	MansionBuilder.addDoorwayToWall(corr, "WallNorth", -50, FLOOR_Y) -- offset: 60 - 110 = -50

	-- Kitchen at Z=30, corridor north wall — doorway at X=100
	-- We need a second doorway in the north wall. Since addDoorwayToWall destroys the wall,
	-- we handle corridor doorways differently: we build the corridor walls with gaps

	-- Actually, let's rebuild corridor walls with multiple doorway openings
	-- Remove the solid north and south walls and replace with segmented walls

	local northWall = corr:FindFirstChild("WallNorth")
	local southWall = corr:FindFirstChild("WallSouth")

	if northWall then northWall:Destroy() end
	if southWall then southWall:Destroy() end

	-- North wall doorways: Living Room (X=60), Kitchen (X=100)
	local northDoors = {60, 100} -- X positions of doorway centers
	-- South wall doorways: Drama Room (X=60), Confession (X=100), Elimination (X=150)
	local southDoors = {60, 100, 150}

	-- Build north wall segments with doorway gaps
	MansionBuilder._buildSegmentedWall(corr, "CorrWallN",
		cx - corrLen / 2, cx + corrLen / 2,      -- X range
		WALL_HEIGHT / 2, cz + corrWidth / 2,     -- Y center, Z position
		WALL_HEIGHT, 1,                           -- height, thickness (Z)
		northDoors, DOORWAY_WIDTH, DOORWAY_HEIGHT,
		WALL_COLOR, true)                         -- isXWall=true

	-- Build south wall segments with doorway gaps
	MansionBuilder._buildSegmentedWall(corr, "CorrWallS",
		cx - corrLen / 2, cx + corrLen / 2,
		WALL_HEIGHT / 2, cz - corrWidth / 2,
		WALL_HEIGHT, 1,
		southDoors, DOORWAY_WIDTH, DOORWAY_HEIGHT,
		WALL_COLOR, true)
end

-- ============================================================
-- Helper: Build a wall along X with multiple doorway openings
-- ============================================================

function MansionBuilder._buildSegmentedWall(parent, baseName, xMin, xMax, yCen, zPos, wallH, wallThick, doorXPositions, doorW, doorH, wallColor, isXWall)
	-- Sort door positions
	table.sort(doorXPositions)

	local segIdx = 0
	local prevEnd = xMin

	for _, doorX in ipairs(doorXPositions) do
		local doorLeft = doorX - doorW / 2
		local doorRight = doorX + doorW / 2

		-- Segment before this door
		local segLen = doorLeft - prevEnd
		if segLen > 0.5 then
			segIdx = segIdx + 1
			local segCx = prevEnd + segLen / 2
			MansionBuilder.createPart(parent, baseName .. "_Seg" .. segIdx,
				Vector3.new(segCx, yCen, zPos),
				Vector3.new(segLen, wallH, wallThick),
				wallColor or WALL_COLOR)
		end

		-- Above-door segment
		local aboveH = wallH - doorH
		if aboveH > 0.5 then
			segIdx = segIdx + 1
			local aboveCy = yCen + wallH / 2 - aboveH / 2
			MansionBuilder.createPart(parent, baseName .. "_Above" .. segIdx,
				Vector3.new(doorX, aboveCy, zPos),
				Vector3.new(doorW, aboveH, wallThick),
				wallColor or WALL_COLOR)
		end

		-- Gold door frame
		local doorBottomY = yCen - wallH / 2
		-- Left jamb
		MansionBuilder.createPart(parent, baseName .. "_FrameL" .. segIdx,
			Vector3.new(doorLeft, doorBottomY + doorH / 2, zPos),
			Vector3.new(DOOR_FRAME_THICKNESS, doorH, wallThick + 0.4), GOLD, Enum.Material.Metal)
		-- Right jamb
		MansionBuilder.createPart(parent, baseName .. "_FrameR" .. segIdx,
			Vector3.new(doorRight, doorBottomY + doorH / 2, zPos),
			Vector3.new(DOOR_FRAME_THICKNESS, doorH, wallThick + 0.4), GOLD, Enum.Material.Metal)
		-- Top lintel
		MansionBuilder.createPart(parent, baseName .. "_FrameT" .. segIdx,
			Vector3.new(doorX, doorBottomY + doorH, zPos),
			Vector3.new(doorW + DOOR_FRAME_THICKNESS * 2, DOOR_FRAME_THICKNESS, wallThick + 0.4), GOLD, Enum.Material.Metal)

		prevEnd = doorRight
	end

	-- Final segment after last door
	local lastSegLen = xMax - prevEnd
	if lastSegLen > 0.5 then
		segIdx = segIdx + 1
		local segCx = prevEnd + lastSegLen / 2
		MansionBuilder.createPart(parent, baseName .. "_Seg" .. segIdx,
			Vector3.new(segCx, yCen, zPos),
			Vector3.new(lastSegLen, wallH, wallThick),
			wallColor or WALL_COLOR)
	end
end

-- ============================================================
-- ELIMINATION ROOM — Dark & dramatic
-- ============================================================

function MansionBuilder.buildEliminationRoom(parent)
	local cx, cz = 150, -35
	local roomW, roomD = 50, 50

	local room = MansionBuilder.createRoomShell(parent, "EliminationRoom",
		cx, FLOOR_Y, cz, roomW, roomD, WALL_HEIGHT,
		MARBLE_DARK, Color3.fromHex("#0A0610"), DARK, Enum.Material.Marble)

	-- Dark curtains around walls (tall thin parts)
	for i = 1, 12 do
		local angle = (i - 1) * (2 * math.pi / 12)
		local curtainX = cx + math.cos(angle) * (roomW / 2 - 2)
		local curtainZ = cz + math.sin(angle) * (roomD / 2 - 2)
		MansionBuilder.createPart(room, "Curtain" .. i,
			Vector3.new(curtainX, WALL_HEIGHT / 2, curtainZ),
			Vector3.new(3, WALL_HEIGHT - 2, 0.5),
			CURTAIN_DARK, Enum.Material.Fabric)
	end

	-- Center podium (dark metallic cylinder, narrow)
	local podium = Instance.new("Part")
	podium.Name = "Podium"
	podium.Shape = Enum.PartType.Cylinder
	podium.Size = Vector3.new(4, 5, 5)
	podium.Position = Vector3.new(cx, 2, cz)
	podium.Orientation = Vector3.new(0, 0, 0)
	podium.Color = Color3.fromHex("#1A0A12")
	podium.Material = Enum.Material.Metal
	podium.Anchored = true
	podium.Parent = room

	-- Dramatic spotlight from ceiling onto podium
	local spotPart = MansionBuilder.createPart(room, "SpotlightMount",
		Vector3.new(cx, WALL_HEIGHT - 1, cz),
		Vector3.new(2, 1, 2), DARK)
	spotPart.CanCollide = false
	local spot = Instance.new("SpotLight")
	spot.Face = Enum.NormalId.Bottom
	spot.Brightness = 5
	spot.Range = 30
	spot.Angle = 35
	spot.Color = Color3.new(1, 1, 1)
	spot.Parent = spotPart

	-- Pink neon rings on floor around podium (2 concentric)
	for ring = 1, 2 do
		local r = 5 + ring * 4
		for seg = 1, 12 do
			local a1 = (seg - 1) * (2 * math.pi / 12)
			local a2 = seg * (2 * math.pi / 12)
			local midA = (a1 + a2) / 2
			local nx = cx + math.cos(midA) * r
			local nz = cz + math.sin(midA) * r
			local segLen = 2 * r * math.sin(math.pi / 12)
			local neonSeg = MansionBuilder.createNeon(room, "Ring" .. ring .. "_" .. seg,
				Vector3.new(nx, 0.15, nz),
				Vector3.new(segLen, 0.3, 0.5), NEON_PINK)
			neonSeg.Orientation = Vector3.new(0, math.deg(midA), 0)
		end
	end

	-- 4 arched alcoves with warm amber lights
	local alcovePositions = {
		{x = cx - roomW / 2 + 3, z = cz - 10, dir = Vector3.new(1, 0, 0)},
		{x = cx - roomW / 2 + 3, z = cz + 10, dir = Vector3.new(1, 0, 0)},
		{x = cx + roomW / 2 - 3, z = cz - 10, dir = Vector3.new(-1, 0, 0)},
		{x = cx + roomW / 2 - 3, z = cz + 10, dir = Vector3.new(-1, 0, 0)},
	}
	for i, alc in ipairs(alcovePositions) do
		-- Arch frame
		MansionBuilder.createPart(room, "AlcoveL" .. i,
			Vector3.new(alc.x, 4, alc.z - 3),
			Vector3.new(1, 8, 1), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "AlcoveR" .. i,
			Vector3.new(alc.x, 4, alc.z + 3),
			Vector3.new(1, 8, 1), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "AlcoveTop" .. i,
			Vector3.new(alc.x, 8.5, alc.z),
			Vector3.new(1, 1, 7), GOLD, Enum.Material.Metal)

		-- Warm light
		local alcLight = MansionBuilder.createNeon(room, "AlcoveLight" .. i,
			Vector3.new(alc.x, 7, alc.z),
			Vector3.new(0.5, 0.5, 0.5), AMBER)
		local alcPL = Instance.new("PointLight")
		alcPL.Color = Color3.fromHex("#FFAA44")
		alcPL.Brightness = 2
		alcPL.Range = 20
		alcPL.Parent = alcLight

		-- Flower vase in alcove
		MansionBuilder.createFlowerVase(room, Vector3.new(alc.x, 0, alc.z))
	end

	-- Seating area (semi-circle facing podium)
	for i = 1, 8 do
		local angle = math.rad(180 + (i - 1) * 22.5)
		local seatR = 16
		local sx = cx + math.cos(angle) * seatR
		local sz = cz + math.sin(angle) * seatR
		MansionBuilder.createPart(room, "Seat" .. i,
			Vector3.new(sx, 1.5, sz),
			Vector3.new(3, 3, 3), COUCH_CREAM, Enum.Material.Fabric)
	end

	-- "ELIMINATION" sign
	MansionBuilder.createSign(room, "ELIMINATION",
		Vector3.new(cx, WALL_HEIGHT - 2, cz + roomD / 2 - 1), 14, CRIMSON)
	MansionBuilder.createNeon(room, "EliminationGlow",
		Vector3.new(cx, WALL_HEIGHT - 2, cz + roomD / 2 - 0.5),
		Vector3.new(16, 4, 0.3), CRIMSON)

	-- Fog/atmosphere effect (dark neon near floor for darkness)
	local fog = MansionBuilder.createNeon(room, "FloorFog",
		Vector3.new(cx, 0.1, cz),
		Vector3.new(roomW - 4, 0.15, roomD - 4), Color3.fromHex("#050208"))
	fog.Transparency = 0.5
end

-- ============================================================
-- LIVING ROOM — Multiple seating areas, Tea Wall
-- ============================================================

function MansionBuilder.buildLivingRoom(parent)
	local cx, cz = 60, 30
	local roomW, roomD = ROOM_SIZE, ROOM_SIZE

	local room = MansionBuilder.createRoomShell(parent, "LivingRoom",
		cx, FLOOR_Y, cz, roomW, roomD, WALL_HEIGHT,
		MARBLE_WHITE, WALL_COLOR, DARK)

	-- Sign
	MansionBuilder.createSign(room, "THE LIVING ROOM",
		Vector3.new(cx, WALL_HEIGHT - 2, cz - roomD / 2 + 1), 12, NEON_PINK)

	-- L-shaped sectional couch (cream/beige)
	MansionBuilder.createCouch(room,
		Vector3.new(cx - 10, 1.5, cz + 10),
		Vector3.new(14, 2.5, 5), Vector3.new(0, 0, 0), COUCH_CREAM)
	MansionBuilder.createCouch(room,
		Vector3.new(cx - 15, 1.5, cz + 4),
		Vector3.new(8, 2.5, 5), Vector3.new(0, 90, 0), COUCH_CREAM)

	-- Round rug under seating (circular thin part)
	local rug = Instance.new("Part")
	rug.Name = "Rug"
	rug.Shape = Enum.PartType.Cylinder
	rug.Size = Vector3.new(0.3, 18, 18)
	rug.Position = Vector3.new(cx - 8, 0.15, cz + 6)
	rug.Orientation = Vector3.new(0, 0, 90)
	rug.Color = Color3.fromHex("#3A2840")
	rug.Material = Enum.Material.Fabric
	rug.Anchored = true
	rug.CanCollide = false
	rug.Parent = room

	-- Tea Wall: Large flat screen TV on north wall
	local teaWall = MansionBuilder.createPart(room, "TeaWallTV",
		Vector3.new(cx - 5, 7, cz + roomD / 2 - 0.8),
		Vector3.new(20, 12, 0.5), Color3.fromHex("#0D0D0D"))

	-- SurfaceGui for confessions
	local tvGui = Instance.new("SurfaceGui")
	tvGui.Face = Enum.NormalId.Back
	tvGui.Parent = teaWall
	local tvLabel = Instance.new("TextLabel")
	tvLabel.Size = UDim2.new(1, 0, 1, 0)
	tvLabel.BackgroundColor3 = Color3.fromHex("#0D0D0D")
	tvLabel.Text = "TEA WALL\n\nConfessions will appear here..."
	tvLabel.TextColor3 = NEON_PINK
	tvLabel.TextScaled = true
	tvLabel.Font = Enum.Font.GothamBold
	tvLabel.Parent = tvGui

	-- "TEA WALL" neon sign above TV
	MansionBuilder.createSign(room, "TEA WALL",
		Vector3.new(cx - 5, 13.5, cz + roomD / 2 - 0.5), 8, GOLD_BRIGHT)

	-- TV frame (gold border)
	MansionBuilder.createNeon(room, "TVFrameTop",
		Vector3.new(cx - 5, 13.1, cz + roomD / 2 - 0.8), Vector3.new(20.5, 0.3, 0.6), GOLD)
	MansionBuilder.createNeon(room, "TVFrameBot",
		Vector3.new(cx - 5, 0.9, cz + roomD / 2 - 0.8), Vector3.new(20.5, 0.3, 0.6), GOLD)
	MansionBuilder.createNeon(room, "TVFrameL",
		Vector3.new(cx - 15.2, 7, cz + roomD / 2 - 0.8), Vector3.new(0.3, 12.5, 0.6), GOLD)
	MansionBuilder.createNeon(room, "TVFrameR",
		Vector3.new(cx + 5.2, 7, cz + roomD / 2 - 0.8), Vector3.new(0.3, 12.5, 0.6), GOLD)

	-- Gold frame mirror on west wall
	MansionBuilder.createArtFrame(room,
		Vector3.new(cx - roomW / 2 + 0.5, 7, cz + 5),
		Vector3.new(0.3, 6, 4))
	local mirror = MansionBuilder.createPart(room, "Mirror",
		Vector3.new(cx - roomW / 2 + 0.8, 7, cz + 5),
		Vector3.new(0.2, 5.5, 3.5), Color3.new(0.8, 0.85, 0.9), Enum.Material.Glass)
	mirror.Reflectance = 0.8
	mirror.Transparency = 0.1

	-- Bookshelf/display shelf on east side
	MansionBuilder.createPart(room, "BookshelfBack",
		Vector3.new(cx + roomW / 2 - 2, 5, cz - 5),
		Vector3.new(3, 10, 8), WALL_LIGHT)
	for s = 1, 4 do
		MansionBuilder.createPart(room, "Shelf" .. s,
			Vector3.new(cx + roomW / 2 - 2, 1.5 + s * 2.2, cz - 5),
			Vector3.new(3.2, 0.3, 8.2), GOLD, Enum.Material.Metal)
	end
	-- Books (colored rectangles)
	local bookColors = {CRIMSON, PURPLE, SKY_BLUE, GOLD_BRIGHT, NEON_PINK}
	for s = 1, 3 do
		for b = 1, 5 do
			MansionBuilder.createPart(room, "Book" .. s .. "_" .. b,
				Vector3.new(cx + roomW / 2 - 2, 2.2 + s * 2.2, cz - 8 + b * 1.5),
				Vector3.new(1.2, 1.8, 0.8),
				bookColors[((s + b - 2) % #bookColors) + 1])
		end
	end

	-- Plants in corners
	MansionBuilder.createPlant(room, Vector3.new(cx + roomW / 2 - 3, 0, cz + roomD / 2 - 3), 7)
	MansionBuilder.createPlant(room, Vector3.new(cx - roomW / 2 + 3, 0, cz - roomD / 2 + 3), 6)

	-- Neon accent strips along floor
	MansionBuilder.createNeon(room, "AccentGlow",
		Vector3.new(cx, 0.1, cz),
		Vector3.new(10, 0.15, 10), NEON_PINK)

	-- Coffee table
	MansionBuilder.createPart(room, "CoffeeTable",
		Vector3.new(cx - 8, 1.5, cz + 4),
		Vector3.new(5, 1.5, 3), GOLD, Enum.Material.Metal)
	local ctTop = MansionBuilder.createPart(room, "CoffeeTableTop",
		Vector3.new(cx - 8, 2.4, cz + 4),
		Vector3.new(5.5, 0.3, 3.5), GLASS_BLUE, Enum.Material.Glass)
	ctTop.Transparency = 0.4
end

-- ============================================================
-- DRAMA ROOM — Red/crimson themed confrontation arena
-- ============================================================

function MansionBuilder.buildDramaRoom(parent)
	local cx, cz = 60, -35
	local roomW, roomD = ROOM_SIZE, ROOM_SIZE

	local room = MansionBuilder.createRoomShell(parent, "DramaRoom",
		cx, FLOOR_Y, cz, roomW, roomD, WALL_HEIGHT,
		MARBLE_DARK, Color3.fromHex("#1A0A0A"), DARK, Enum.Material.Marble)

	-- "THE DRAMA ROOM" neon sign
	MansionBuilder.createSign(room, "THE DRAMA ROOM",
		Vector3.new(cx, WALL_HEIGHT - 2, cz + roomD / 2 - 1), 14, CRIMSON)
	MansionBuilder.createNeon(room, "DramaSignGlow",
		Vector3.new(cx, WALL_HEIGHT - 2, cz + roomD / 2 - 0.5),
		Vector3.new(16, 4, 0.3), CRIMSON)

	-- Dramatic red lighting (floor glow)
	MansionBuilder.createNeon(room, "RedFloorGlow",
		Vector3.new(cx, 0.15, cz),
		Vector3.new(roomW - 6, 0.2, roomD - 6), CRIMSON)

	-- Stage/platform area (raised)
	MansionBuilder.createPart(room, "Stage",
		Vector3.new(cx, 1, cz + 5),
		Vector3.new(18, 2, 18), Color3.fromHex("#1A0A0A"), Enum.Material.Marble)

	-- Boxing ring-style roped area for confrontations
	local ringCx, ringCz = cx, cz + 5
	local ringHalf = 8
	local postPositions = {
		Vector3.new(ringCx - ringHalf, 4, ringCz - ringHalf),
		Vector3.new(ringCx + ringHalf, 4, ringCz - ringHalf),
		Vector3.new(ringCx + ringHalf, 4, ringCz + ringHalf),
		Vector3.new(ringCx - ringHalf, 4, ringCz + ringHalf),
	}
	for i, ppos in ipairs(postPositions) do
		local post = Instance.new("Part")
		post.Name = "RingPost" .. i
		post.Shape = Enum.PartType.Cylinder
		post.Size = Vector3.new(6, 1.5, 1.5)
		post.Position = ppos
		post.Color = GOLD
		post.Material = Enum.Material.Metal
		post.Anchored = true
		post.Parent = room
	end

	-- Ropes between posts (3 levels)
	local ropeConnections = {{1, 2}, {2, 3}, {3, 4}, {4, 1}}
	for _, conn in ipairs(ropeConnections) do
		local p1 = postPositions[conn[1]]
		local p2 = postPositions[conn[2]]
		local mid = (p1 + p2) / 2
		local diff = p2 - p1
		local length = diff.Magnitude
		local angle = math.deg(math.atan2(diff.X, diff.Z))

		for ropeLevel = 1, 3 do
			local ropeY = 2.5 + ropeLevel * 1.2
			local rope = MansionBuilder.createNeon(room, "Rope" .. conn[1] .. conn[2] .. "_" .. ropeLevel,
				Vector3.new(mid.X, ropeY, mid.Z),
				Vector3.new(length, 0.3, 0.3), CRIMSON)
			rope.Orientation = Vector3.new(0, angle, 0)
		end
	end

	-- Audience seating (rows of seats)
	for row = 1, 3 do
		for seat = 1, 6 do
			local sx = cx - 12 + seat * 4
			local sz = cz - 10 - row * 3
			MansionBuilder.createPart(room, "AudienceSeat_R" .. row .. "S" .. seat,
				Vector3.new(sx, 1.2 + row * 0.5, sz),
				Vector3.new(3, 2.5, 2.5), COUCH_CREAM, Enum.Material.Fabric)
		end
	end

	-- Dramatic red spotlights on ring
	for i = 1, 2 do
		local slX = cx + (i == 1 and -5 or 5)
		local slPart = MansionBuilder.createPart(room, "RedSpot" .. i,
			Vector3.new(slX, WALL_HEIGHT - 1, cz + 5),
			Vector3.new(1.5, 1, 1.5), CRIMSON, Enum.Material.Neon)
		slPart.CanCollide = false
		local sl = Instance.new("SpotLight")
		sl.Face = Enum.NormalId.Bottom
		sl.Brightness = 4
		sl.Range = 25
		sl.Angle = 45
		sl.Color = CRIMSON
		sl.Parent = slPart
	end
end

-- ============================================================
-- ELEVATOR — Glass, gold-framed, TweenService powered
-- ============================================================

function MansionBuilder.buildElevator(parent)
	local elev = Instance.new("Folder")
	elev.Name = "Elevator"
	elev.Parent = parent

	local ex, ez = 195, 0
	local shaftW, shaftD = 12, 12
	local shaftHeight = FLOOR2_Y + WALL_HEIGHT + 10

	-- Elevator shaft walls (glass + gold frame)
	-- Back wall
	local shaftBack = MansionBuilder.createPart(elev, "ShaftBack",
		Vector3.new(ex, shaftHeight / 2, ez + shaftD / 2),
		Vector3.new(shaftW, shaftHeight, 0.5),
		GLASS_BLUE, Enum.Material.Glass)
	shaftBack.Transparency = 0.5

	-- Left wall
	local shaftLeft = MansionBuilder.createPart(elev, "ShaftLeft",
		Vector3.new(ex - shaftW / 2, shaftHeight / 2, ez),
		Vector3.new(0.5, shaftHeight, shaftD),
		GLASS_BLUE, Enum.Material.Glass)
	shaftLeft.Transparency = 0.5

	-- Right wall
	local shaftRight = MansionBuilder.createPart(elev, "ShaftRight",
		Vector3.new(ex + shaftW / 2, shaftHeight / 2, ez),
		Vector3.new(0.5, shaftHeight, shaftD),
		GLASS_BLUE, Enum.Material.Glass)
	shaftRight.Transparency = 0.5

	-- Gold frame edges (vertical)
	local framePositions = {
		Vector3.new(ex - shaftW / 2, shaftHeight / 2, ez - shaftD / 2),
		Vector3.new(ex + shaftW / 2, shaftHeight / 2, ez - shaftD / 2),
		Vector3.new(ex - shaftW / 2, shaftHeight / 2, ez + shaftD / 2),
		Vector3.new(ex + shaftW / 2, shaftHeight / 2, ez + shaftD / 2),
	}
	for i, fpos in ipairs(framePositions) do
		MansionBuilder.createPart(elev, "Frame" .. i, fpos,
			Vector3.new(0.8, shaftHeight, 0.8), GOLD, Enum.Material.Metal)
	end

	-- Moving platform
	local platform = MansionBuilder.createPart(elev, "ElevatorPlatform",
		Vector3.new(ex, 0.5, ez),
		Vector3.new(shaftW - 1, 1, shaftD - 1), MARBLE_WHITE, Enum.Material.Marble)

	-- Floor indicator signs
	MansionBuilder.createSign(elev, "G", Vector3.new(ex - shaftW / 2 - 1, 3, ez), 3, GOLD)
	MansionBuilder.createSign(elev, "2", Vector3.new(ex - shaftW / 2 - 1, FLOOR2_Y + 3, ez), 3, GOLD)
	MansionBuilder.createSign(elev, "R", Vector3.new(ex - shaftW / 2 - 1, FLOOR2_Y + WALL_HEIGHT + 5, ez), 3, GOLD)

	-- "ELEVATOR" sign
	MansionBuilder.createSign(elev, "ELEVATOR",
		Vector3.new(ex, 10, ez - shaftD / 2 - 1), 6, GOLD)

	-- Call buttons at each floor level
	local floorYPositions = {
		{y = 3, name = "CallGround"},
		{y = FLOOR2_Y + 2, name = "CallFloor2"},
		{y = FLOOR2_Y + WALL_HEIGHT + 4, name = "CallRooftop"},
	}
	for _, floorData in ipairs(floorYPositions) do
		local button = MansionBuilder.createPart(elev, floorData.name,
			Vector3.new(ex - shaftW / 2 - 1.5, floorData.y, ez),
			Vector3.new(1, 1.5, 1.5), GOLD, Enum.Material.Metal)

		local click = Instance.new("ClickDetector")
		click.MaxActivationDistance = 15
		click.Parent = button

		-- Neon indicator
		MansionBuilder.createNeon(elev, floorData.name .. "Light",
			Vector3.new(ex - shaftW / 2 - 1.5, floorData.y + 1, ez),
			Vector3.new(0.5, 0.5, 0.5), GOLD_BRIGHT)
	end

	-- Interior light
	local elevLight = MansionBuilder.createNeon(elev, "InteriorLight",
		Vector3.new(ex, shaftHeight - 2, ez),
		Vector3.new(4, 0.3, 4), GOLD_BRIGHT)
	local elevPL = Instance.new("PointLight")
	elevPL.Color = Color3.fromHex("#FFEEDD")
	elevPL.Brightness = 1.5
	elevPL.Range = 20
	elevPL.Parent = elevLight

	-- Wire elevator movement directly (no Script.Source needed)
	local TweenService = game:GetService("TweenService")
	local elevPlatform = elev:FindFirstChild("ElevatorPlatform")

	local FLOOR_POSITIONS = {
		Ground = 0.5,
		Floor2 = FLOOR2_Y + 0.5,
		Rooftop = FLOOR2_Y + WALL_HEIGHT + 2.5,
	}

	local isMoving = false
	local currentFloor = "Ground"

	local function moveToFloor(targetFloor)
		if isMoving then return end
		if currentFloor == targetFloor then return end
		isMoving = true

		local targetY = FLOOR_POSITIONS[targetFloor]
		if elevPlatform then
			local tweenInfo = TweenInfo.new(3, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)
			local tween = TweenService:Create(elevPlatform, tweenInfo, {
				Position = Vector3.new(elevPlatform.Position.X, targetY, elevPlatform.Position.Z)
			})
			tween:Play()
			tween.Completed:Wait()
		end
		currentFloor = targetFloor
		isMoving = false
	end

	-- Connect call buttons
	task.spawn(function()
		local callGround = elev:FindFirstChild("CallGround")
		local callFloor2 = elev:FindFirstChild("CallFloor2")
		local callRooftop = elev:FindFirstChild("CallRooftop")

		if callGround then
			local cd = callGround:FindFirstChildOfClass("ClickDetector")
			if cd then cd.MouseClick:Connect(function() moveToFloor("Ground") end) end
		end
		if callFloor2 then
			local cd = callFloor2:FindFirstChildOfClass("ClickDetector")
			if cd then cd.MouseClick:Connect(function() moveToFloor("Floor2") end) end
		end
		if callRooftop then
			local cd = callRooftop:FindFirstChildOfClass("ClickDetector")
			if cd then cd.MouseClick:Connect(function() moveToFloor("Rooftop") end) end
		end
	end)
end

-- ============================================================
-- BEDROOMS (Upper Floor) — Enhanced with luxury furnishings
-- ============================================================

function MansionBuilder.buildBedroomFloor(parent)
	local floor2 = Instance.new("Folder")
	floor2.Name = "BedroomFloor"
	floor2.Parent = parent

	-- Upper floor corridor base
	MansionBuilder.createPart(floor2, "Floor",
		Vector3.new(110, FLOOR2_Y - 0.5, 0),
		Vector3.new(170, 1, 18), MARBLE_WHITE, Enum.Material.Marble)
	MansionBuilder.createPart(floor2, "Ceiling",
		Vector3.new(110, FLOOR2_Y + WALL_HEIGHT, 0),
		Vector3.new(170, 1, 18), DARK)

	-- Upper corridor walls (north and south) with doorways to bedrooms
	-- Rooms 1-5 are north (positive Z), rooms 6-10 are south (negative Z)
	-- Bedroom positions: col = (roomNum-1) for 1-5, (roomNum-6) for 6-10
	-- cx = 40 + col * 32

	local northDoorPositions = {}
	local southDoorPositions = {}
	for i = 1, 10 do
		local col = i <= 5 and (i - 1) or (i - 6)
		local doorX = 40 + col * 32
		if i <= 5 then
			table.insert(northDoorPositions, doorX)
		else
			table.insert(southDoorPositions, doorX)
		end
	end

	-- Build north corridor wall with doorways
	MansionBuilder._buildSegmentedWall(floor2, "UpperCorrN",
		25, 195,           -- X range
		FLOOR2_Y + WALL_HEIGHT / 2, 9,  -- Y center, Z position (north side of 18-wide corridor)
		WALL_HEIGHT, 1,
		northDoorPositions, DOORWAY_WIDTH, DOORWAY_HEIGHT,
		WALL_COLOR, true)

	-- Build south corridor wall with doorways
	MansionBuilder._buildSegmentedWall(floor2, "UpperCorrS",
		25, 195,
		FLOOR2_Y + WALL_HEIGHT / 2, -9,
		WALL_HEIGHT, 1,
		southDoorPositions, DOORWAY_WIDTH, DOORWAY_HEIGHT,
		WALL_COLOR, true)

	-- Upper corridor gold trim
	MansionBuilder.createNeon(floor2, "UpperTrimN",
		Vector3.new(110, FLOOR2_Y + 0.1, 8.5),
		Vector3.new(170, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(floor2, "UpperTrimS",
		Vector3.new(110, FLOOR2_Y + 0.1, -8.5),
		Vector3.new(170, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(floor2, "UpperCeilTrimN",
		Vector3.new(110, FLOOR2_Y + WALL_HEIGHT - 0.3, 8.5),
		Vector3.new(170, 0.2, 0.3), GOLD)
	MansionBuilder.createNeon(floor2, "UpperCeilTrimS",
		Vector3.new(110, FLOOR2_Y + WALL_HEIGHT - 0.3, -8.5),
		Vector3.new(170, 0.2, 0.3), GOLD)

	-- "BEDROOMS" sign
	MansionBuilder.createSign(floor2, "BEDROOMS",
		Vector3.new(30, FLOOR2_Y + 8, 0), 12, GOLD)

	-- Wall sconces in upper corridor
	for x = 35, 190, 20 do
		MansionBuilder.createSconce(floor2, Vector3.new(x, FLOOR2_Y + 8, 8), Vector3.new(0, 0, -1))
		MansionBuilder.createSconce(floor2, Vector3.new(x, FLOOR2_Y + 8, -8), Vector3.new(0, 0, 1))
	end

	-- Build 10 bedrooms (5 north, 5 south)
	for i = 1, 10 do
		MansionBuilder.buildBedroom(floor2, i)
	end
end

function MansionBuilder.buildBedroom(parent, roomNum)
	local config = Config.BEDROOM_NAMES[roomNum]
	if not config then return end

	local room = Instance.new("Folder")
	room.Name = "Bedroom_" .. roomNum
	room.Parent = parent

	-- Position: rooms 1-5 north, 6-10 south
	local col = roomNum <= 5 and (roomNum - 1) or (roomNum - 6)
	local side = roomNum <= 5 and 1 or -1
	local cx = 40 + col * 32
	local cz = side * 25
	local bw, bd = 28, 22

	-- Room shell
	local floorColor = config.exile and Color3.new(0.08, 0.08, 0.08) or MARBLE_WHITE
	local wallCol = config.exile and Color3.fromHex("#0A0A0A") or WALL_COLOR

	MansionBuilder.createPart(room, "Floor",
		Vector3.new(cx, FLOOR2_Y - 0.5, cz),
		Vector3.new(bw, 1, bd), floorColor, Enum.Material.Marble)
	MansionBuilder.createPart(room, "Ceiling",
		Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT, cz),
		Vector3.new(bw, 1, bd), DARK)
	MansionBuilder.createPart(room, "WallBack",
		Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT / 2, cz + side * bd / 2),
		Vector3.new(bw, WALL_HEIGHT, 1), wallCol)
	MansionBuilder.createPart(room, "WallLeft",
		Vector3.new(cx - bw / 2, FLOOR2_Y + WALL_HEIGHT / 2, cz),
		Vector3.new(1, WALL_HEIGHT, bd), wallCol)
	MansionBuilder.createPart(room, "WallRight",
		Vector3.new(cx + bw / 2, FLOOR2_Y + WALL_HEIGHT / 2, cz),
		Vector3.new(1, WALL_HEIGHT, bd), wallCol)

	-- Front wall (corridor side) — has doorway, built by the corridor wall segments
	-- So we do NOT add a front wall here; the corridor wall handles it

	-- Room-colored accent wall (back wall overlay strip)
	MansionBuilder.createPart(room, "AccentWall",
		Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT / 2, cz + side * (bd / 2 - 0.3)),
		Vector3.new(bw - 2, WALL_HEIGHT - 2, 0.3), config.color)

	-- Room name sign
	MansionBuilder.createSign(room, config.name,
		Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT - 2, cz - side * (bd / 2 - 1)), 10, config.color)
	-- Room number
	MansionBuilder.createSign(room, "#" .. roomNum,
		Vector3.new(cx - bw / 2 + 3, FLOOR2_Y + 5, cz - side * (bd / 2 - 1)), 3, GOLD)

	-- Accent neon strip along floor
	MansionBuilder.createNeon(room, "Accent",
		Vector3.new(cx, FLOOR2_Y + 0.1, cz + side * (bd / 2 - 1)),
		Vector3.new(bw - 2, 0.2, 0.3), config.color)

	-- Rug under beds
	local rug = Instance.new("Part")
	rug.Name = "Rug"
	rug.Shape = Enum.PartType.Cylinder
	rug.Size = Vector3.new(0.3, 16, 10)
	rug.Position = Vector3.new(cx, FLOOR2_Y + 0.15, cz + side * 4)
	rug.Orientation = Vector3.new(0, 0, 90)
	rug.Color = config.exile and Color3.new(0.1, 0.1, 0.1) or Color3.fromHex("#3A2840")
	rug.Material = Enum.Material.Fabric
	rug.Anchored = true
	rug.CanCollide = false
	rug.Parent = room

	if config.master then
		-- ===== CROWN SUITE: Extra large, golden everything =====
		MansionBuilder.createPart(room, "BedFrame",
			Vector3.new(cx, FLOOR2_Y + 1, cz + side * 5),
			Vector3.new(12, 2, 10), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "Mattress",
			Vector3.new(cx, FLOOR2_Y + 2.5, cz + side * 5),
			Vector3.new(11, 1.5, 9), CREAM, Enum.Material.Fabric)
		MansionBuilder.createPart(room, "Headboard",
			Vector3.new(cx, FLOOR2_Y + 5, cz + side * 9.5),
			Vector3.new(12, 6, 1), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "Pillow1",
			Vector3.new(cx - 3, FLOOR2_Y + 3.5, cz + side * 8),
			Vector3.new(3, 1, 2), GOLD_BRIGHT, Enum.Material.Fabric)
		MansionBuilder.createPart(room, "Pillow2",
			Vector3.new(cx + 3, FLOOR2_Y + 3.5, cz + side * 8),
			Vector3.new(3, 1, 2), CREAM, Enum.Material.Fabric)

		-- Throne chair
		MansionBuilder.createPart(room, "ThroneBase",
			Vector3.new(cx - 8, FLOOR2_Y + 1.5, cz - side * 2),
			Vector3.new(4, 3, 4), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "ThroneBack",
			Vector3.new(cx - 8, FLOOR2_Y + 5, cz - side * 3.5),
			Vector3.new(4, 6, 1), GOLD, Enum.Material.Metal)
		MansionBuilder.createPart(room, "ThroneCushion",
			Vector3.new(cx - 8, FLOOR2_Y + 3.2, cz - side * 2),
			Vector3.new(3.5, 0.8, 3.5), CRIMSON, Enum.Material.Fabric)

		-- Chandelier
		MansionBuilder.createChandelier(room,
			Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT - 2, cz + side * 3), 5, GOLD_BRIGHT)

		-- Nightstands with lamps (both sides)
		for ns = -1, 1, 2 do
			MansionBuilder.createPart(room, "Nightstand" .. (ns == -1 and "L" or "R"),
				Vector3.new(cx + ns * 8, FLOOR2_Y + 1, cz + side * 5),
				Vector3.new(2.5, 2, 2.5), GOLD, Enum.Material.Metal)
			local lamp = MansionBuilder.createPart(room, "Lamp" .. (ns == -1 and "L" or "R"),
				Vector3.new(cx + ns * 8, FLOOR2_Y + 3, cz + side * 5),
				Vector3.new(1, 2, 1), AMBER, Enum.Material.Neon)
			lamp.CanCollide = false
			local lpl = Instance.new("PointLight")
			lpl.Color = Color3.fromHex("#FFEEDD")
			lpl.Brightness = 1
			lpl.Range = 15
			lpl.Parent = lamp
		end

		-- Crown neon glow
		MansionBuilder.createNeon(room, "CrownGlow",
			Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT - 1, cz + side * 3),
			Vector3.new(10, 0.3, 10), GOLD_BRIGHT)

		-- Mirror
		local crownMirror = MansionBuilder.createPart(room, "Mirror",
			Vector3.new(cx + bw / 2 - 1, FLOOR2_Y + 6, cz),
			Vector3.new(0.3, 5, 4), Color3.new(0.8, 0.85, 0.9), Enum.Material.Glass)
		crownMirror.Reflectance = 0.8

	elseif config.exile then
		-- ===== DOG HOUSE: Bare, cold, single dim light =====
		MansionBuilder.createPart(room, "Mattress1",
			Vector3.new(cx - 5, FLOOR2_Y + 0.3, cz + side * 4),
			Vector3.new(4, 0.5, 7), Color3.new(0.15, 0.15, 0.15), Enum.Material.Fabric)
		MansionBuilder.createPart(room, "Mattress2",
			Vector3.new(cx + 5, FLOOR2_Y + 0.3, cz + side * 4),
			Vector3.new(4, 0.5, 7), Color3.new(0.15, 0.15, 0.15), Enum.Material.Fabric)

		MansionBuilder.createPart(room, "SadPillow1",
			Vector3.new(cx - 5, FLOOR2_Y + 0.7, cz + side * 7),
			Vector3.new(2, 0.3, 1.5), Color3.new(0.25, 0.25, 0.25), Enum.Material.Fabric)
		MansionBuilder.createPart(room, "SadPillow2",
			Vector3.new(cx + 5, FLOOR2_Y + 0.7, cz + side * 7),
			Vector3.new(2, 0.3, 1.5), Color3.new(0.25, 0.25, 0.25), Enum.Material.Fabric)

		local dimBulb = MansionBuilder.createPart(room, "DimBulb",
			Vector3.new(cx, FLOOR2_Y + WALL_HEIGHT - 1, cz),
			Vector3.new(1, 1, 1), Color3.new(0.3, 0.3, 0.2), Enum.Material.Neon)
		dimBulb.CanCollide = false
		local dimLight = Instance.new("PointLight")
		dimLight.Color = Color3.new(0.4, 0.35, 0.2)
		dimLight.Brightness = 0.3
		dimLight.Range = 15
		dimLight.Parent = dimBulb

		MansionBuilder.createSign(room, "You know what you did.",
			Vector3.new(cx, FLOOR2_Y + 5, cz + side * (bd / 2 - 1.5)), 10, Color3.new(0.3, 0.3, 0.3))

	else
		-- ===== STANDARD LUXURY BEDROOM =====
		for bedI = -1, 1, 2 do
			local bx = cx + bedI * 6

			MansionBuilder.createPart(room, "BedFrame" .. (bedI == -1 and "1" or "2"),
				Vector3.new(bx, FLOOR2_Y + 0.8, cz + side * 5),
				Vector3.new(6, 1.5, 9), config.color, Enum.Material.SmoothPlastic)
			MansionBuilder.createPart(room, "Mattress" .. (bedI == -1 and "1" or "2"),
				Vector3.new(bx, FLOOR2_Y + 2, cz + side * 5),
				Vector3.new(5.5, 1, 8.5), CREAM, Enum.Material.Fabric)
			MansionBuilder.createPart(room, "Headboard" .. (bedI == -1 and "1" or "2"),
				Vector3.new(bx, FLOOR2_Y + 4, cz + side * 9),
				Vector3.new(6, 4, 0.8), config.color, Enum.Material.SmoothPlastic)
			MansionBuilder.createPart(room, "Pillow" .. (bedI == -1 and "1" or "2"),
				Vector3.new(bx, FLOOR2_Y + 2.8, cz + side * 8),
				Vector3.new(3, 0.6, 2), Color3.new(1, 1, 1), Enum.Material.Fabric)
		end

		-- Nightstand between beds with lamp
		MansionBuilder.createPart(room, "Nightstand",
			Vector3.new(cx, FLOOR2_Y + 1, cz + side * 5),
			Vector3.new(2.5, 2, 2.5), GOLD, Enum.Material.Metal)
		local lamp = MansionBuilder.createPart(room, "Lamp",
			Vector3.new(cx, FLOOR2_Y + 3, cz + side * 5),
			Vector3.new(1, 2, 1), AMBER, Enum.Material.Neon)
		lamp.CanCollide = false
		local lpl = Instance.new("PointLight")
		lpl.Color = Color3.fromHex("#FFEEDD")
		lpl.Brightness = 1
		lpl.Range = 18
		lpl.Parent = lamp

		-- Mirror on wall
		local bedroomMirror = MansionBuilder.createPart(room, "Mirror",
			Vector3.new(cx - bw / 2 + 1, FLOOR2_Y + 6, cz - side * 2),
			Vector3.new(0.3, 4, 3), Color3.new(0.8, 0.85, 0.9), Enum.Material.Glass)
		bedroomMirror.Reflectance = 0.7
		MansionBuilder.createPart(room, "MirrorFrame",
			Vector3.new(cx - bw / 2 + 1, FLOOR2_Y + 6, cz - side * 2),
			Vector3.new(0.35, 4.5, 3.5), GOLD, Enum.Material.Metal)
	end
end

-- ============================================================
-- LIGHTING SETUP
-- ============================================================

function MansionBuilder.setupLighting()
	local lighting = game:GetService("Lighting")
	lighting.ClockTime = 21
	lighting.Ambient = Color3.fromHex("#2A1E35")
	lighting.OutdoorAmbient = Color3.fromHex("#1A1225")
	lighting.Brightness = 1.5
	lighting.FogEnd = 1000
	lighting.FogColor = Color3.fromHex("#0A0610")
	lighting.GlobalShadows = true
	lighting.EnvironmentDiffuseScale = 0.5
	lighting.EnvironmentSpecularScale = 0.3

	-- Bloom for that lush neon glow
	local bloom = Instance.new("BloomEffect")
	bloom.Intensity = 0.5
	bloom.Size = 30
	bloom.Threshold = 0.65
	bloom.Parent = lighting

	-- Color correction for warm luxury mood
	local cc = Instance.new("ColorCorrectionEffect")
	cc.Saturation = 0.3
	cc.Contrast = 0.1
	cc.TintColor = Color3.fromHex("#F0E0FF")
	cc.Parent = lighting

	-- Atmosphere for outdoor depth
	local atmo = Instance.new("Atmosphere")
	atmo.Density = 0.15
	atmo.Offset = 0.5
	atmo.Color = Color3.fromHex("#1A1030")
	atmo.Decay = Color3.fromHex("#2A1E40")
	atmo.Glare = 0.2
	atmo.Haze = 2
	atmo.Parent = lighting

	-- Depth of field for cinematic feel
	local dof = Instance.new("DepthOfFieldEffect")
	dof.FarIntensity = 0.05
	dof.FocusDistance = 50
	dof.InFocusRadius = 30
	dof.NearIntensity = 0
	dof.Parent = lighting

	-- Sun rays for drama
	local rays = Instance.new("SunRaysEffect")
	rays.Intensity = 0.05
	rays.Spread = 0.3
	rays.Parent = lighting
end

-- ============================================================
-- ROOM LIGHTS — Add ceiling PointLights to rooms
-- ============================================================

function MansionBuilder.addRoomLights(parent, cx, cy, cz, color, range)
	local light = Instance.new("Part")
	light.Name = "CeilingLight"
	light.Size = Vector3.new(3, 0.3, 3)
	light.Position = Vector3.new(cx, cy - 1.5, cz)
	light.Color = color or GOLD
	light.Material = Enum.Material.Neon
	light.Anchored = true
	light.CanCollide = false
	light.Parent = parent

	local pl = Instance.new("PointLight")
	pl.Color = color or Color3.fromHex("#FFEEDD")
	pl.Brightness = 1.8
	pl.Range = range or 40
	pl.Parent = light
end

-- ============================================================
-- ADD ALL LIGHTS — Master lighting pass after build
-- ============================================================

function MansionBuilder.addAllLights(mansion)
	-- Ground floor lights
	MansionBuilder.addRoomLights(mansion, 20, WALL_HEIGHT, 0, GOLD, 55)          -- Lobby
	MansionBuilder.addRoomLights(mansion, 60, WALL_HEIGHT, 30, NEON_PINK, 45)    -- Living Room
	MansionBuilder.addRoomLights(mansion, 100, WALL_HEIGHT, 30, GOLD, 45)         -- Kitchen
	MansionBuilder.addRoomLights(mansion, 60, WALL_HEIGHT, -35, CRIMSON, 45)     -- Drama Room
	MansionBuilder.addRoomLights(mansion, 100, WALL_HEIGHT, -35, PURPLE, 40)     -- Confession
	MansionBuilder.addRoomLights(mansion, 150, WALL_HEIGHT, -35, CRIMSON, 50)    -- Elimination

	-- Corridor lights (every 25 studs)
	for x = 20, 200, 25 do
		MansionBuilder.addRoomLights(mansion, x, WALL_HEIGHT, 0, GOLD, 30)
	end

	-- Bedroom lights
	for i = 1, 10 do
		local col = i <= 5 and (i - 1) or (i - 6)
		local side = i <= 5 and 1 or -1
		local cx = 40 + col * 32
		local cz = side * 25
		local bConfig = Config.BEDROOM_NAMES[i]
		if bConfig then
			if bConfig.exile then
				-- Dog house gets minimal light (already handled in buildBedroom)
			else
				MansionBuilder.addRoomLights(mansion, cx, FLOOR2_Y + WALL_HEIGHT, cz, bConfig.color, 35)
			end
		end
	end

	-- Rooftop lights
	local ry = FLOOR2_Y + WALL_HEIGHT + 2
	MansionBuilder.addRoomLights(mansion, 80, ry + 10, 0, GOLD, 70)
	MansionBuilder.addRoomLights(mansion, 120, ry + 10, 15, SKY_BLUE, 60)
	MansionBuilder.addRoomLights(mansion, 100, ry + 10, -20, NEON_PINK, 50)

	-- Exterior entrance lights
	MansionBuilder.addRoomLights(mansion, -10, 15, 0, GOLD, 50)
	MansionBuilder.addRoomLights(mansion, -30, 8, 10, GOLD, 40)
	MansionBuilder.addRoomLights(mansion, -30, 8, -10, GOLD, 40)

	print("[MansionBuilder] All luxury lights installed!")
end

return MansionBuilder
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="17">
        <Properties>
          <string name="Name">MonetizationSystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- MONETIZATION SYSTEM — Game Passes + Dev Products for Mansion Mayhem
-- Handles purchases, perks, and receipt processing
-- ============================================================

local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Config = require(ReplicatedStorage.Shared.Config)

local MonetizationSystem = {}

-- ============================================================
-- GAME PASS DEFINITIONS (one-time purchases)
-- Replace 0 with actual Roblox Game Pass IDs after creation
-- ============================================================

MonetizationSystem.GAME_PASSES = {
	VIP = {
		id = 1760523514,
		name = "VIP Pass",
		description = "Gold name tag, VIP lounge access, exclusive outfit colors",
		price = 499,
	},
	DoubleXP = {
		id = 1761417564,
		name = "Double XP",
		description = "2x XP from all activities",
		price = 299,
	},
	ExtraVote = {
		id = 1759833647,
		name = "Extra Vote",
		description = "Cast 2 votes during elimination instead of 1",
		price = 399,
	},
	CustomRoom = {
		id = 1761267496,
		name = "Custom Room",
		description = "Decorate your bedroom with exclusive items",
		price = 199,
	},
}

-- ============================================================
-- DEV PRODUCT DEFINITIONS (repeatable purchases)
-- Replace 0 with actual Roblox Developer Product IDs after creation
-- ============================================================

MonetizationSystem.DEV_PRODUCTS = {
	ImmunityToken = {
		id = 3561185320,
		name = "Immunity Token",
		description = "Buy 1 immunity token to survive elimination",
		price = 149,
	},
	Coins50 = {
		id = 3561185719,
		name = "50 Coins",
		description = "In-game currency for the Mansion",
		price = 49,
	},
	RoomUpgrade = {
		id = 3561186318,
		name = "Room Upgrade",
		description = "Upgrade your bedroom temporarily",
		price = 99,
	},
	ConfettiBomb = {
		id = 3561186942,
		name = "Confetti Bomb",
		description = "Throw confetti on yourself (flex)",
		price = 29,
	},
}

-- State
MonetizationSystem._gamePassCache = {} -- { [userId] = { [passName] = true/false } }
MonetizationSystem._pendingReceipts = {} -- track processed receipts

-- ============================================================
-- INITIALIZATION
-- ============================================================

function MonetizationSystem.init()
	print("[MonetizationSystem] Initializing monetization...")

	-- Set up ProcessReceipt callback for dev products
	MarketplaceService.ProcessReceipt = MonetizationSystem.processReceipt

	-- Listen for game pass purchase completion to update cache
	MarketplaceService.PromptGamePassPurchaseFinished:Connect(function(player, gamePassId, wasPurchased)
		if wasPurchased then
			MonetizationSystem._onGamePassPurchased(player, gamePassId)
		end
	end)

	-- Pre-cache game passes for existing players
	for _, player in Players:GetPlayers() do
		task.spawn(function()
			MonetizationSystem._cacheGamePasses(player)
		end)
	end

	-- Cache game passes for new players
	Players.PlayerAdded:Connect(function(player)
		task.spawn(function()
			MonetizationSystem._cacheGamePasses(player)
		end)
	end)

	-- Clean up on leave
	Players.PlayerRemoving:Connect(function(player)
		MonetizationSystem._gamePassCache[player.UserId] = nil
	end)

	print("[MonetizationSystem] Monetization ready!")
end

-- ============================================================
-- GAME PASS FUNCTIONS
-- ============================================================

function MonetizationSystem._cacheGamePasses(player)
	MonetizationSystem._gamePassCache[player.UserId] = {}

	for passName, passData in MonetizationSystem.GAME_PASSES do
		if passData.id ~= 0 then
			local success, owns = pcall(function()
				return MarketplaceService:UserOwnsGamePassAsync(player.UserId, passData.id)
			end)
			if success then
				MonetizationSystem._gamePassCache[player.UserId][passName] = owns
				if owns then
					print("[MonetizationSystem]", player.Name, "owns game pass:", passName)
				end
			else
				MonetizationSystem._gamePassCache[player.UserId][passName] = false
			end
		else
			MonetizationSystem._gamePassCache[player.UserId][passName] = false
		end
	end
end

function MonetizationSystem._onGamePassPurchased(player, gamePassId)
	if not player then return end

	for passName, passData in MonetizationSystem.GAME_PASSES do
		if passData.id == gamePassId then
			if not MonetizationSystem._gamePassCache[player.UserId] then
				MonetizationSystem._gamePassCache[player.UserId] = {}
			end
			MonetizationSystem._gamePassCache[player.UserId][passName] = true
			print("[MonetizationSystem]", player.Name, "purchased game pass:", passName)

			-- Apply immediate perks
			if passName == "VIP" then
				MonetizationSystem._applyVIPTag(player)
			end

			break
		end
	end
end

function MonetizationSystem.hasGamePass(player, passName)
	if not player then return false end
	local cache = MonetizationSystem._gamePassCache[player.UserId]
	if cache then
		return cache[passName] == true
	end
	return false
end

function MonetizationSystem.promptPurchase(player, passName)
	if not player then return end

	-- Check game passes first
	local passData = MonetizationSystem.GAME_PASSES[passName]
	if passData then
		if passData.id ~= 0 then
			MarketplaceService:PromptGamePassPurchase(player, passData.id)
		else
			warn("[MonetizationSystem] Game pass ID is 0 (placeholder) for:", passName)
		end
		return
	end

	-- Check dev products
	local productData = MonetizationSystem.DEV_PRODUCTS[passName]
	if productData then
		if productData.id ~= 0 then
			MarketplaceService:PromptProductPurchase(player, productData.id)
		else
			warn("[MonetizationSystem] Dev product ID is 0 (placeholder) for:", passName)
		end
		return
	end

	warn("[MonetizationSystem] Unknown purchase name:", passName)
end

-- ============================================================
-- DEV PRODUCT RECEIPT PROCESSING
-- ============================================================

function MonetizationSystem.processReceipt(receiptInfo)
	local playerId = receiptInfo.PlayerId
	local productId = receiptInfo.ProductId
	local purchaseId = receiptInfo.PurchaseId

	-- Prevent duplicate processing
	if MonetizationSystem._pendingReceipts[purchaseId] then
		return Enum.ProductPurchaseDecision.PurchaseGranted
	end
	MonetizationSystem._pendingReceipts[purchaseId] = true

	local player = Players:GetPlayerByUserId(playerId)
	if not player then
		MonetizationSystem._pendingReceipts[purchaseId] = nil
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	-- Find which product was purchased
	local productName = nil
	for name, data in MonetizationSystem.DEV_PRODUCTS do
		if data.id == productId then
			productName = name
			break
		end
	end

	if not productName then
		warn("[MonetizationSystem] Unknown product ID:", productId)
		MonetizationSystem._pendingReceipts[purchaseId] = nil
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end

	print("[MonetizationSystem] Processing dev product:", productName, "for", player.Name)

	local success = pcall(function()
		MonetizationSystem._grantDevProduct(player, productName)
	end)

	if success then
		return Enum.ProductPurchaseDecision.PurchaseGranted
	else
		MonetizationSystem._pendingReceipts[purchaseId] = nil
		return Enum.ProductPurchaseDecision.NotProcessedYet
	end
end

function MonetizationSystem._grantDevProduct(player, productName)
	-- Get GameManager reference for player data
	local gameManager = nil
	local ok, gm = pcall(function()
		return require(script.Parent.GameManager)
	end)
	if ok then gameManager = gm end

	if productName == "ImmunityToken" then
		-- Grant 1 immunity token
		if gameManager and gameManager.immunitySystem then
			gameManager.immunitySystem.awardToken(player.UserId, 1, "purchase", gameManager)
		end
		print("[MonetizationSystem]", player.Name, "received 1 Immunity Token")

	elseif productName == "Coins50" then
		-- Add 50 coins
		if gameManager then
			local playerData = gameManager.playerMap[player.UserId]
			if playerData then
				playerData.coins = (playerData.coins or 0) + 50
			end
		end
		print("[MonetizationSystem]", player.Name, "received 50 coins")

	elseif productName == "RoomUpgrade" then
		-- Room upgrade — flag for this session
		if gameManager then
			local playerData = gameManager.playerMap[player.UserId]
			if playerData then
				playerData.roomUpgraded = true
			end
		end
		print("[MonetizationSystem]", player.Name, "upgraded their room")

	elseif productName == "ConfettiBomb" then
		-- Fire confetti effect for the player
		MonetizationSystem._fireConfetti(player)
		print("[MonetizationSystem]", player.Name, "threw a confetti bomb!")
	end
end

-- ============================================================
-- VIP FEATURES
-- ============================================================

function MonetizationSystem.getVIPPlayers()
	local vips = {}
	for userId, cache in MonetizationSystem._gamePassCache do
		if cache.VIP == true then
			table.insert(vips, userId)
		end
	end
	return vips
end

function MonetizationSystem._applyVIPTag(player)
	local character = player.Character
	if not character then
		player.CharacterAdded:Once(function(char)
			MonetizationSystem._createVIPTag(char)
		end)
		return
	end
	MonetizationSystem._createVIPTag(character)
end

function MonetizationSystem._createVIPTag(character)
	local head = character:FindFirstChild("Head")
	if not head then return end

	-- Remove existing tag if any
	local existing = head:FindFirstChild("VIPTag")
	if existing then existing:Destroy() end

	local bg = Instance.new("BillboardGui")
	bg.Name = "VIPTag"
	bg.Size = UDim2.new(0, 80, 0, 20)
	bg.StudsOffset = Vector3.new(0, 2.2, 0)
	bg.AlwaysOnTop = true
	bg.Parent = head

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundColor3 = Config.Colors.Gold
	label.BackgroundTransparency = 0.2
	label.Text = "VIP"
	label.TextColor3 = Config.Colors.Background
	label.TextSize = 12
	label.Font = Enum.Font.GothamBold
	label.Parent = bg

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 4)
	corner.Parent = label
end

-- ============================================================
-- XP MULTIPLIER
-- ============================================================

function MonetizationSystem.getXPMultiplier(player)
	if MonetizationSystem.hasGamePass(player, "DoubleXP") then
		return 2
	end
	return 1
end

-- ============================================================
-- VOTE COUNT (Extra Vote pass)
-- ============================================================

function MonetizationSystem.getVoteCount(player)
	if MonetizationSystem.hasGamePass(player, "ExtraVote") then
		return 2
	end
	return 1
end

-- ============================================================
-- CONFETTI EFFECT
-- ============================================================

function MonetizationSystem._fireConfetti(player)
	local character = player.Character
	if not character then return end
	local hrp = character:FindFirstChild("HumanoidRootPart")
	if not hrp then return end

	-- Create confetti particles
	local attachment = Instance.new("Attachment")
	attachment.Name = "ConfettiAttachment"
	attachment.Parent = hrp

	local emitter = Instance.new("ParticleEmitter")
	emitter.Name = "Confetti"
	emitter.Rate = 100
	emitter.Lifetime = NumberRange.new(1, 3)
	emitter.Speed = NumberRange.new(5, 15)
	emitter.SpreadAngle = Vector2.new(180, 180)
	emitter.RotSpeed = NumberRange.new(-360, 360)
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.3),
		NumberSequenceKeypoint.new(1, 0.1),
	})
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Config.Colors.Gold),
		ColorSequenceKeypoint.new(0.25, Config.Colors.Pink),
		ColorSequenceKeypoint.new(0.5, Config.Colors.Purple),
		ColorSequenceKeypoint.new(0.75, Config.Colors.Blue),
		ColorSequenceKeypoint.new(1, Config.Colors.Green),
	})
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(0.8, 0),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.Parent = attachment

	-- Director announcement
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("DirectorAnnounce")
	if remote then
		remote:FireAllClients(player.DisplayName .. " just threw a CONFETTI BOMB!")
	end

	-- Clean up after 4 seconds
	task.delay(4, function()
		if attachment and attachment.Parent then
			attachment:Destroy()
		end
	end)
end

return MonetizationSystem
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="18">
        <Properties>
          <string name="Name">NPCSystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- NPC SYSTEM — Crew members that patrol the Mansion
-- Director, Security Officers, Camera Operators, House Manager
-- Walk between waypoints, respond to events (fights, eliminations)
-- ============================================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local NPCSystem = {}

-- State
NPCSystem.npcs = {} -- { [name] = { model, config, currentWaypoint, patrolTask } }
NPCSystem.mansion = nil

-- ============================================================
-- NPC CONFIGURATIONS
-- ============================================================

local NPC_CONFIGS = {
	{
		name = "THE DIRECTOR",
		displayName = "THE DIRECTOR",
		labelColor = Color3.fromHex("#FFD700"),
		bodyColor = Color3.fromHex("#0A0A0A"), -- black outfit
		accentColor = Color3.fromHex("#FFD700"), -- gold sunglasses
		hasAccent = true,
		waypoints = {
			Vector3.new(135, 1, -25), -- Elimination Room center
			Vector3.new(120, 1, -20), -- Elimination Room edge
			Vector3.new(75, 1, 0),    -- Main corridor
			Vector3.new(55, 1, -15),  -- Near Drama Room
			Vector3.new(95, 1, 0),    -- Mid corridor
			Vector3.new(135, 1, -25), -- Back to Elimination Room
		},
		walkSpeed = 8,
		idleTime = 6,
	},
	{
		name = "OFFICER KANE",
		displayName = "OFFICER KANE",
		labelColor = Color3.fromHex("#F8F4F0"),
		bodyColor = Color3.fromHex("#1A3A6B"), -- blue security uniform
		accentColor = nil,
		hasAccent = false,
		waypoints = {
			Vector3.new(55, 1, 0),    -- Near lobby-corridor junction
			Vector3.new(75, 1, 0),    -- Main corridor
			Vector3.new(55, 1, -20),  -- Drama Room entrance
			Vector3.new(55, 1, 15),   -- Living Room entrance
			Vector3.new(35, 1, 0),    -- Lobby area
			Vector3.new(55, 1, 0),    -- Back to start
		},
		walkSpeed = 10,
		idleTime = 4,
	},
	{
		name = "OFFICER REYES",
		displayName = "OFFICER REYES",
		labelColor = Color3.fromHex("#F8F4F0"),
		bodyColor = Color3.fromHex("#1A3A6B"), -- blue security uniform
		accentColor = nil,
		hasAccent = false,
		waypoints = {
			Vector3.new(95, 1, 0),    -- Mid corridor
			Vector3.new(110, 1, 0),   -- Near Elimination/Kitchen
			Vector3.new(95, 1, 15),   -- Kitchen entrance
			Vector3.new(95, 1, -15),  -- Confession Booth entrance
			Vector3.new(120, 1, -10), -- Near Elimination Room
			Vector3.new(95, 1, 0),    -- Back to start
		},
		walkSpeed = 10,
		idleTime = 4,
	},
	{
		name = "LENS",
		displayName = "\xF0\x9F\x93\xB7 LENS",
		labelColor = Color3.fromHex("#F8F4F0"),
		bodyColor = Color3.fromHex("#333333"), -- dark gray crew outfit
		accentColor = Color3.fromHex("#808080"), -- camera prop (gray box)
		hasAccent = true,
		waypoints = {
			Vector3.new(55, 1, 15),   -- Living Room
			Vector3.new(35, 1, 5),    -- Lobby
			Vector3.new(55, 1, -20),  -- Drama Room
			Vector3.new(75, 1, 0),    -- Corridor
		},
		walkSpeed = 12,
		idleTime = 3,
	},
	{
		name = "FLASH",
		displayName = "\xF0\x9F\x93\xB7 FLASH",
		labelColor = Color3.fromHex("#F8F4F0"),
		bodyColor = Color3.fromHex("#333333"), -- dark gray crew outfit
		accentColor = Color3.fromHex("#808080"), -- camera prop
		hasAccent = true,
		waypoints = {
			Vector3.new(95, 1, 15),   -- Kitchen area
			Vector3.new(135, 1, -25), -- Elimination Room
			Vector3.new(95, 1, -15),  -- Confession Booth
			Vector3.new(110, 1, 0),   -- Corridor near kitchen
		},
		walkSpeed = 12,
		idleTime = 3,
	},
	{
		name = "MS. STERLING",
		displayName = "MS. STERLING",
		labelColor = Color3.fromHex("#F8F4F0"),
		bodyColor = Color3.fromHex("#6A0DAD"), -- purple elegant outfit
		accentColor = nil,
		hasAccent = false,
		waypoints = {
			Vector3.new(25, 1, 5),    -- Lobby entrance
			Vector3.new(35, 1, 0),    -- Lobby center
			Vector3.new(55, 1, 15),   -- Near Living Room
			Vector3.new(95, 1, 15),   -- Kitchen area
			Vector3.new(55, 1, 0),    -- Corridor
			Vector3.new(25, 1, 5),    -- Back to lobby
		},
		walkSpeed = 7,
		idleTime = 5,
	},
}

-- ============================================================
-- INITIALIZATION
-- ============================================================

function NPCSystem.init(mansion)
	NPCSystem.mansion = mansion or workspace:FindFirstChild("Mansion")

	print("[NPCSystem] Spawning NPC crew members...")

	for _, config in NPC_CONFIGS do
		NPCSystem.spawnNPC(config.name, config)
	end

	print("[NPCSystem] All NPCs spawned:", #NPC_CONFIGS, "crew members")
end

-- ============================================================
-- NPC MODEL CREATION
-- ============================================================

function NPCSystem.spawnNPC(name, config)
	-- Create the NPC model
	local model = Instance.new("Model")
	model.Name = "NPC_" .. name:gsub(" ", "_")

	-- Create Humanoid
	local humanoid = Instance.new("Humanoid")
	humanoid.DisplayDistanceType = Enum.HumanoidDisplayDistanceType.None
	humanoid.WalkSpeed = config.walkSpeed or 10
	humanoid.Health = 100
	humanoid.MaxHealth = 100
	humanoid.Parent = model

	-- Body dimensions
	local torsoSize = Vector3.new(2, 2.5, 1)
	local headSize = Vector3.new(1.4, 1.4, 1.4)
	local armSize = Vector3.new(0.8, 2.4, 0.8)
	local legSize = Vector3.new(0.8, 2.4, 0.8)

	local spawnPos = config.waypoints[1] or Vector3.new(50, 1, 0)
	local baseY = spawnPos.Y + legSize.Y + torsoSize.Y / 2

	-- Torso (HumanoidRootPart)
	local torso = Instance.new("Part")
	torso.Name = "HumanoidRootPart"
	torso.Size = torsoSize
	torso.CFrame = CFrame.new(spawnPos.X, baseY, spawnPos.Z)
	torso.Color = config.bodyColor
	torso.Material = Enum.Material.SmoothPlastic
	torso.Anchored = false
	torso.CanCollide = true
	torso.Parent = model

	-- Head
	local head = Instance.new("Part")
	head.Name = "Head"
	head.Size = headSize
	head.Shape = Enum.PartType.Ball
	head.Color = Color3.fromHex("#D2A679") -- skin tone
	head.Material = Enum.Material.SmoothPlastic
	head.Anchored = false
	head.CanCollide = false
	head.Parent = model

	local headWeld = Instance.new("WeldConstraint")
	headWeld.Part0 = torso
	headWeld.Part1 = head
	headWeld.Parent = head
	head.CFrame = torso.CFrame * CFrame.new(0, torsoSize.Y / 2 + headSize.Y / 2, 0)

	-- Left Arm
	local leftArm = Instance.new("Part")
	leftArm.Name = "LeftArm"
	leftArm.Size = armSize
	leftArm.Color = config.bodyColor
	leftArm.Material = Enum.Material.SmoothPlastic
	leftArm.Anchored = false
	leftArm.CanCollide = false
	leftArm.Parent = model

	local leftArmWeld = Instance.new("WeldConstraint")
	leftArmWeld.Part0 = torso
	leftArmWeld.Part1 = leftArm
	leftArmWeld.Parent = leftArm
	leftArm.CFrame = torso.CFrame * CFrame.new(-(torsoSize.X / 2 + armSize.X / 2), 0, 0)

	-- Right Arm
	local rightArm = Instance.new("Part")
	rightArm.Name = "RightArm"
	rightArm.Size = armSize
	rightArm.Color = config.bodyColor
	rightArm.Material = Enum.Material.SmoothPlastic
	rightArm.Anchored = false
	rightArm.CanCollide = false
	rightArm.Parent = model

	local rightArmWeld = Instance.new("WeldConstraint")
	rightArmWeld.Part0 = torso
	rightArmWeld.Part1 = rightArm
	rightArmWeld.Parent = rightArm
	rightArm.CFrame = torso.CFrame * CFrame.new(torsoSize.X / 2 + armSize.X / 2, 0, 0)

	-- Left Leg
	local leftLeg = Instance.new("Part")
	leftLeg.Name = "LeftLeg"
	leftLeg.Size = legSize
	leftLeg.Color = config.bodyColor
	leftLeg.Material = Enum.Material.SmoothPlastic
	leftLeg.Anchored = false
	leftLeg.CanCollide = false
	leftLeg.Parent = model

	local leftLegWeld = Instance.new("WeldConstraint")
	leftLegWeld.Part0 = torso
	leftLegWeld.Part1 = leftLeg
	leftLegWeld.Parent = leftLeg
	leftLeg.CFrame = torso.CFrame * CFrame.new(-0.5, -(torsoSize.Y / 2 + legSize.Y / 2), 0)

	-- Right Leg
	local rightLeg = Instance.new("Part")
	rightLeg.Name = "RightLeg"
	rightLeg.Size = legSize
	rightLeg.Color = config.bodyColor
	rightLeg.Material = Enum.Material.SmoothPlastic
	rightLeg.Anchored = false
	rightLeg.CanCollide = false
	rightLeg.Parent = model

	local rightLegWeld = Instance.new("WeldConstraint")
	rightLegWeld.Part0 = torso
	rightLegWeld.Part1 = rightLeg
	rightLegWeld.Parent = rightLeg
	rightLeg.CFrame = torso.CFrame * CFrame.new(0.5, -(torsoSize.Y / 2 + legSize.Y / 2), 0)

	-- Accent piece (sunglasses for Director, camera for Lens/Flash)
	if config.hasAccent and config.accentColor then
		local accent = Instance.new("Part")
		accent.Name = "Accent"
		accent.CanCollide = false
		accent.Anchored = false
		accent.Color = config.accentColor
		accent.Material = Enum.Material.Neon

		-- Camera operators get a shoulder-mounted box
		if name == "LENS" or name == "FLASH" then
			accent.Size = Vector3.new(0.6, 0.5, 0.8)
			accent.Material = Enum.Material.Metal
			local accentWeld = Instance.new("WeldConstraint")
			accentWeld.Part0 = rightArm
			accentWeld.Part1 = accent
			accentWeld.Parent = accent
			accent.CFrame = rightArm.CFrame * CFrame.new(0, armSize.Y / 2 + 0.3, 0.3)
		else
			-- Director gets gold sunglasses (small bar across eyes)
			accent.Size = Vector3.new(1.2, 0.2, 0.2)
			local accentWeld = Instance.new("WeldConstraint")
			accentWeld.Part0 = head
			accentWeld.Part1 = accent
			accentWeld.Parent = accent
			accent.CFrame = head.CFrame * CFrame.new(0, 0.1, -headSize.Z / 2 - 0.05)
		end

		accent.Parent = model
	end

	-- BillboardGui name tag
	local billboard = Instance.new("BillboardGui")
	billboard.Name = "NameTag"
	billboard.Size = UDim2.new(0, 150, 0, 30)
	billboard.StudsOffset = Vector3.new(0, headSize.Y + 1.5, 0)
	billboard.AlwaysOnTop = true
	billboard.MaxDistance = 80
	billboard.Parent = head

	local nameLabel = Instance.new("TextLabel")
	nameLabel.Name = "NameLabel"
	nameLabel.Size = UDim2.new(1, 0, 1, 0)
	nameLabel.BackgroundColor3 = Color3.fromHex("#0A0610")
	nameLabel.BackgroundTransparency = 0.4
	nameLabel.Text = config.displayName
	nameLabel.TextColor3 = config.labelColor
	nameLabel.TextSize = 14
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextScaled = false
	nameLabel.Parent = billboard

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = nameLabel

	local stroke = Instance.new("UIStroke")
	stroke.Color = config.labelColor
	stroke.Thickness = 1
	stroke.Transparency = 0.5
	stroke.Parent = nameLabel

	-- Set PrimaryPart
	model.PrimaryPart = torso

	-- Parent to workspace
	local npcFolder = workspace:FindFirstChild("NPCs")
	if not npcFolder then
		npcFolder = Instance.new("Folder")
		npcFolder.Name = "NPCs"
		npcFolder.Parent = workspace
	end
	model.Parent = npcFolder

	-- Store NPC data
	NPCSystem.npcs[name] = {
		model = model,
		config = config,
		currentWaypoint = 1,
		patrolTask = nil,
		dispatched = false,
	}

	-- Start patrol
	NPCSystem.patrol(name, config.waypoints)

	print("[NPCSystem] Spawned:", name)
	return model
end

-- ============================================================
-- PATROL SYSTEM
-- ============================================================

function NPCSystem.patrol(name, waypoints)
	local npcData = NPCSystem.npcs[name]
	if not npcData then return end

	-- Cancel existing patrol
	if npcData.patrolTask then
		task.cancel(npcData.patrolTask)
		npcData.patrolTask = nil
	end

	npcData.dispatched = false

	npcData.patrolTask = task.spawn(function()
		while true do
			local model = npcData.model
			if not model or not model.Parent then break end

			local humanoid = model:FindFirstChildOfClass("Humanoid")
			local rootPart = model:FindFirstChild("HumanoidRootPart")
			if not humanoid or not rootPart or humanoid.Health <= 0 then break end

			-- Get current waypoint
			local waypointIndex = npcData.currentWaypoint
			local targetPos = waypoints[waypointIndex]
			if not targetPos then
				npcData.currentWaypoint = 1
				targetPos = waypoints[1]
			end

			-- If dispatched to a different location, stop normal patrol
			if npcData.dispatched then
				task.wait(1)
				continue
			end

			-- Move to waypoint
			humanoid:MoveTo(targetPos)

			-- Wait for arrival or timeout
			local reached = humanoid.MoveToFinished:Wait()

			-- Idle at waypoint
			local idleTime = npcData.config.idleTime or 4
			task.wait(idleTime)

			-- Advance to next waypoint
			npcData.currentWaypoint = (waypointIndex % #waypoints) + 1
		end
	end)
end

-- ============================================================
-- TELEPORT NPC
-- ============================================================

function NPCSystem.teleportNPC(name, position)
	local npcData = NPCSystem.npcs[name]
	if not npcData then return end

	local model = npcData.model
	if not model or not model.Parent then return end

	local rootPart = model:FindFirstChild("HumanoidRootPart")
	if not rootPart then return end

	rootPart.CFrame = CFrame.new(position)
	print("[NPCSystem] Teleported", name, "to", tostring(position))
end

-- ============================================================
-- DISPATCH SECURITY
-- ============================================================

function NPCSystem.dispatchSecurity(position)
	print("[NPCSystem] Dispatching security to", tostring(position))

	local securityNames = { "OFFICER KANE", "OFFICER REYES" }

	for _, officerName in securityNames do
		local npcData = NPCSystem.npcs[officerName]
		if not npcData then continue end

		local model = npcData.model
		if not model or not model.Parent then continue end

		local humanoid = model:FindFirstChildOfClass("Humanoid")
		if not humanoid then continue end

		-- Mark as dispatched (pauses normal patrol)
		npcData.dispatched = true

		-- Move security to the fight location
		humanoid:MoveTo(position)

		-- After arriving and waiting, resume patrol
		task.spawn(function()
			humanoid.MoveToFinished:Wait()

			-- Stay at location for a while
			task.wait(15)

			-- Resume normal patrol
			npcData.dispatched = false
			npcData.currentWaypoint = 1
			NPCSystem.patrol(officerName, npcData.config.waypoints)
		end)
	end
end

-- ============================================================
-- DISPATCH CAMERA CREW
-- ============================================================

function NPCSystem.dispatchCamera(position)
	print("[NPCSystem] Dispatching camera crew to", tostring(position))

	local cameraNames = { "LENS", "FLASH" }

	for _, camName in cameraNames do
		local npcData = NPCSystem.npcs[camName]
		if not npcData then continue end

		local model = npcData.model
		if not model or not model.Parent then continue end

		local humanoid = model:FindFirstChildOfClass("Humanoid")
		if not humanoid then continue end

		-- Mark as dispatched
		npcData.dispatched = true

		-- Move camera crew to the action
		humanoid:MoveTo(position)

		-- After filming, resume patrol
		task.spawn(function()
			humanoid.MoveToFinished:Wait()

			-- "Film" for a while
			task.wait(10)

			-- Resume normal patrol
			npcData.dispatched = false
			npcData.currentWaypoint = 1
			NPCSystem.patrol(camName, npcData.config.waypoints)
		end)
	end
end

-- ============================================================
-- UTILITIES
-- ============================================================

function NPCSystem.getNPC(name)
	local data = NPCSystem.npcs[name]
	if data then
		return data.model
	end
	return nil
end

function NPCSystem.getNPCPosition(name)
	local data = NPCSystem.npcs[name]
	if data and data.model then
		local rootPart = data.model:FindFirstChild("HumanoidRootPart")
		if rootPart then
			return rootPart.Position
		end
	end
	return nil
end

return NPCSystem
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="19">
        <Properties>
          <string name="Name">QueenSystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- QUEEN SYSTEM — Queen of the Week: crowning, privileges, tracking
-- Queen gets master suite, 1.5x vote weight, immunity for first week
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SupabaseAPI = require(script.Parent.SupabaseAPI)
local Config = require(ReplicatedStorage.Shared.Config)

local QueenSystem = {}

-- State
QueenSystem.currentQueen = nil -- { userId, name, crownedAt, weekNumber, approvalRating }
QueenSystem.queenHistory = {} -- { { userId, name, weekNumber, approvalRating } }
QueenSystem.approvalVotes = {} -- { [voterId] = "approve" | "disapprove" }
QueenSystem.queenPrivileges = {
	masterSuite = true,
	roomAssignment = true,
	voteWeight = 1.5,
	immunityFirstWeek = true,
}

-- ============================================================
-- CROWNING CEREMONY
-- ============================================================

function QueenSystem.crownQueen(userId, gameManager)
	local player = Players:GetPlayerByUserId(userId)
	if not player then
		warn("[QueenSystem] Cannot crown — player not found:", userId)
		return false
	end

	local playerName = player.DisplayName or player.Name
	local weekNumber = 0
	if gameManager and gameManager.seasonData and gameManager.seasonData.week then
		weekNumber = gameManager.seasonData.week.week_number or 0
	end

	-- Store previous queen in history
	if QueenSystem.currentQueen then
		table.insert(QueenSystem.queenHistory, {
			userId = QueenSystem.currentQueen.userId,
			name = QueenSystem.currentQueen.name,
			weekNumber = QueenSystem.currentQueen.weekNumber,
			approvalRating = QueenSystem.currentQueen.approvalRating,
		})
	end

	-- Set new queen
	QueenSystem.currentQueen = {
		userId = userId,
		name = playerName,
		crownedAt = os.time(),
		weekNumber = weekNumber,
		approvalRating = 100, -- starts at 100%
	}

	-- Reset approval votes
	QueenSystem.approvalVotes = {}

	print("[QueenSystem] QUEEN CROWNED:", playerName, "— Week", weekNumber)

	-- Run crowning ceremony
	QueenSystem._runCrowningCeremony(player, gameManager)

	-- Sync to Supabase
	if gameManager and gameManager.seasonData then
		local seasonId = gameManager.seasonData.season and gameManager.seasonData.season.id
		if seasonId then
			task.spawn(function()
				SupabaseAPI.crownQueen(seasonId, tostring(userId), weekNumber)
			end)
		end
	end

	return true
end

function QueenSystem._runCrowningCeremony(player, gameManager)
	-- Step 1: Director announcement
	if gameManager then
		gameManager.directorAnnounce("ATTENTION HOUSEMATES! It is time to crown this week's QUEEN OF THE MANSION!")
	end

	task.wait(3)

	-- Step 2: Teleport queen to stage/throne area (Elimination Room stage)
	local character = player.Character
	if character then
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(135, 3, -25) -- Elimination Room stage center
		end
	end

	-- Step 3: Apply crown visual effect
	QueenSystem._applyCrownEffect(player)

	-- Step 4: Notify all clients of crowning
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("QueenCrowned")
	if remote then
		remote:FireAllClients({
			queenUserId = player.UserId,
			queenName = player.DisplayName or player.Name,
			weekNumber = QueenSystem.currentQueen.weekNumber,
			privileges = {
				"Master Suite (The Crown Suite)",
				"Room Assignment Power",
				"1.5x Vote Weight",
				"Immunity (first week as Queen)",
			},
		})
	end

	task.wait(3)

	-- Step 5: Director describes privileges
	if gameManager then
		gameManager.directorAnnounce(
			player.DisplayName .. " now has the CROWN SUITE, the power to ASSIGN ROOMS, " ..
			"a 1.5x VOTE WEIGHT, and IMMUNITY for this week! Use your power wisely... or don't."
		)
	end

	-- Step 6: Move queen to Crown Suite
	task.wait(5)
	if character then
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if hrp then
			-- Crown Suite position (Room 1 on upper floor)
			hrp.CFrame = CFrame.new(40, 21, 22)
		end
	end

	if gameManager then
		gameManager.directorAnnounce(player.DisplayName .. " has moved into THE CROWN SUITE. Long live the Queen.")
	end
end

function QueenSystem._applyCrownEffect(player)
	local character = player.Character
	if not character then return end

	local head = character:FindFirstChild("Head")
	if not head then return end

	-- Remove existing crown
	local existing = head:FindFirstChild("CrownEffect")
	if existing then existing:Destroy() end

	-- Create crown glow (golden neon part above head)
	local crown = Instance.new("Part")
	crown.Name = "CrownEffect"
	crown.Shape = Enum.PartType.Ball
	crown.Size = Vector3.new(1.5, 0.8, 1.5)
	crown.Color = Config.Colors.Gold
	crown.Material = Enum.Material.Neon
	crown.Transparency = 0.2
	crown.CanCollide = false
	crown.Anchored = false
	crown.Massless = true
	crown.Parent = head

	-- Weld to head
	local weld = Instance.new("WeldConstraint")
	weld.Part0 = head
	weld.Part1 = crown
	weld.Parent = crown

	crown.CFrame = head.CFrame * CFrame.new(0, 1.2, 0)

	-- Add golden PointLight
	local light = Instance.new("PointLight")
	light.Color = Config.Colors.Gold
	light.Brightness = 2
	light.Range = 15
	light.Parent = crown

	-- Add BillboardGui with "QUEEN" label
	local bg = Instance.new("BillboardGui")
	bg.Name = "QueenLabel"
	bg.Size = UDim2.new(0, 80, 0, 25)
	bg.StudsOffset = Vector3.new(0, 3.5, 0)
	bg.AlwaysOnTop = true
	bg.Parent = head

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundColor3 = Config.Colors.Gold
	label.BackgroundTransparency = 0.3
	label.Text = "QUEEN"
	label.TextColor3 = Config.Colors.Background
	label.TextSize = 14
	label.Font = Enum.Font.GothamBold
	label.Parent = bg

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = label
end

function QueenSystem._removeCrownEffect(userId)
	local player = Players:GetPlayerByUserId(userId)
	if not player or not player.Character then return end

	local head = player.Character:FindFirstChild("Head")
	if not head then return end

	local crown = head:FindFirstChild("CrownEffect")
	if crown then crown:Destroy() end

	local queenLabel = head:FindFirstChild("QueenLabel")
	if queenLabel then queenLabel:Destroy() end
end

-- ============================================================
-- QUEEN PRIVILEGES
-- ============================================================

function QueenSystem.getCurrentQueenId()
	if QueenSystem.currentQueen then
		return QueenSystem.currentQueen.userId
	end
	return nil
end

function QueenSystem.getCurrentQueenName()
	if QueenSystem.currentQueen then
		return QueenSystem.currentQueen.name
	end
	return nil
end

function QueenSystem.isQueen(userId)
	return QueenSystem.currentQueen ~= nil and QueenSystem.currentQueen.userId == userId
end

function QueenSystem.getVoteWeight(userId)
	if QueenSystem.isQueen(userId) then
		return QueenSystem.queenPrivileges.voteWeight
	end
	return 1
end

function QueenSystem.hasImmunity(userId)
	if not QueenSystem.isQueen(userId) then return false end
	-- Queen has immunity only in her first week as queen
	return QueenSystem.queenPrivileges.immunityFirstWeek
end

-- ============================================================
-- APPROVAL RATING
-- ============================================================

function QueenSystem.submitApproval(voterPlayer, approve)
	if not voterPlayer or not QueenSystem.currentQueen then return end

	-- Queen cannot vote on herself
	if voterPlayer.UserId == QueenSystem.currentQueen.userId then return end

	AllianceSystem_approvalVotes = AllianceSystem_approvalVotes or {}
	QueenSystem.approvalVotes[voterPlayer.UserId] = approve and "approve" or "disapprove"

	-- Recalculate approval rating
	local approveCount = 0
	local totalCount = 0
	for _, vote in QueenSystem.approvalVotes do
		totalCount += 1
		if vote == "approve" then
			approveCount += 1
		end
	end

	if totalCount > 0 then
		QueenSystem.currentQueen.approvalRating = math.floor((approveCount / totalCount) * 100)
	end

	print("[QueenSystem] Approval rating:", QueenSystem.currentQueen.approvalRating .. "%")

	-- Notify queen of new approval rating
	local queenPlayer = Players:GetPlayerByUserId(QueenSystem.currentQueen.userId)
	if queenPlayer then
		local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("QueenApproval")
		if remote then
			remote:FireClient(queenPlayer, {
				approvalRating = QueenSystem.currentQueen.approvalRating,
				totalVotes = totalCount,
			})
		end
	end
end

function QueenSystem.getApprovalRating()
	if QueenSystem.currentQueen then
		return QueenSystem.currentQueen.approvalRating
	end
	return 0
end

-- ============================================================
-- ROOM ASSIGNMENT (Queen's power)
-- ============================================================

function QueenSystem.assignRoom(queenPlayer, targetUserId, roomNumber, gameManager)
	if not queenPlayer then return { success = false, reason = "invalid_player" } end

	-- Verify this player is the queen
	if not QueenSystem.isQueen(queenPlayer.UserId) then
		return { success = false, reason = "not_queen" }
	end

	-- Validate room number
	if roomNumber < 1 or roomNumber > Config.BEDROOMS then
		return { success = false, reason = "invalid_room" }
	end

	-- Verify target player exists
	local targetPlayer = Players:GetPlayerByUserId(targetUserId)
	if not targetPlayer then
		return { success = false, reason = "player_not_found" }
	end

	-- Update room assignment in GameManager
	if gameManager then
		local playerData = gameManager.playerMap[targetUserId]
		if playerData then
			playerData.room = roomNumber
		end
	end

	local roomConfig = Config.BEDROOM_NAMES[roomNumber]
	local roomName = roomConfig and roomConfig.name or ("Room " .. roomNumber)

	print("[QueenSystem] Queen assigned", targetPlayer.DisplayName, "to", roomName)

	-- Notify the target
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("RoomAssignment")
	if remote then
		remote:FireClient(targetPlayer, {
			roomNumber = roomNumber,
			roomName = roomName,
			assignedBy = "queen",
			queenName = queenPlayer.DisplayName or queenPlayer.Name,
		})
	end

	-- Director commentary on interesting assignments
	if roomConfig and roomConfig.exile and gameManager then
		gameManager.directorAnnounce(
			"The Queen has sent " .. targetPlayer.DisplayName .. " to THE DOG HOUSE. Cold. Ice cold."
		)
	end

	return { success = true, roomNumber = roomNumber, roomName = roomName }
end

-- ============================================================
-- DETHRONE (end of queen's reign)
-- ============================================================

function QueenSystem.dethroneQueen(gameManager)
	if not QueenSystem.currentQueen then return end

	local queenName = QueenSystem.currentQueen.name
	local queenUserId = QueenSystem.currentQueen.userId

	-- Remove crown effect
	QueenSystem._removeCrownEffect(queenUserId)

	-- Move to history
	table.insert(QueenSystem.queenHistory, {
		userId = QueenSystem.currentQueen.userId,
		name = QueenSystem.currentQueen.name,
		weekNumber = QueenSystem.currentQueen.weekNumber,
		approvalRating = QueenSystem.currentQueen.approvalRating,
	})

	QueenSystem.currentQueen = nil
	QueenSystem.approvalVotes = {}

	if gameManager then
		gameManager.directorAnnounce(queenName .. "'s reign has ended. A new Queen will be crowned.")
	end

	print("[QueenSystem] Queen dethroned:", queenName)
end

-- ============================================================
-- QUEEN SELECTION (determine who becomes queen)
-- ============================================================

function QueenSystem.selectQueenByXP(gameManager)
	-- Queen = player with highest XP who hasn't been queen this season
	if not gameManager then return nil end

	local bestPlayer = nil
	local bestXP = -1

	for userId, data in gameManager.playerMap do
		if data.eliminated then continue end

		-- Check if already been queen
		local wasQueen = false
		for _, h in QueenSystem.queenHistory do
			if h.userId == userId then
				wasQueen = true
				break
			end
		end
		if QueenSystem.currentQueen and QueenSystem.currentQueen.userId == userId then
			wasQueen = true
		end

		if not wasQueen then
			local xp = data.xp or 0
			if xp > bestXP then
				bestXP = xp
				bestPlayer = userId
			end
		end
	end

	-- If everyone has been queen, allow repeats
	if not bestPlayer then
		for userId, data in gameManager.playerMap do
			if data.eliminated then continue end
			local xp = data.xp or 0
			if xp > bestXP then
				bestXP = xp
				bestPlayer = userId
			end
		end
	end

	return bestPlayer
end

-- ============================================================
-- CLEANUP
-- ============================================================

function QueenSystem.onPlayerLeave(player)
	-- If the queen leaves, dethrone
	if QueenSystem.currentQueen and QueenSystem.currentQueen.userId == player.UserId then
		QueenSystem.dethroneQueen(nil)
	end
	-- Remove approval vote
	QueenSystem.approvalVotes[player.UserId] = nil
end

function QueenSystem.getQueenInfo()
	if not QueenSystem.currentQueen then
		return nil
	end
	return {
		userId = QueenSystem.currentQueen.userId,
		name = QueenSystem.currentQueen.name,
		weekNumber = QueenSystem.currentQueen.weekNumber,
		approvalRating = QueenSystem.currentQueen.approvalRating,
		privileges = QueenSystem.queenPrivileges,
	}
end

function QueenSystem.getQueenHistory()
	return QueenSystem.queenHistory
end

return QueenSystem
]]></string>
        </Properties>
