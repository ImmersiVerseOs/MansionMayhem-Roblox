          <string name="Name">Client</string>
          <string name="Source"><![CDATA[-- ============================================================
-- MANSION MAYHEM ROBLOX — Client Entry Point
-- Initializes all UI systems and handles server communication
-- ============================================================

local LoadingScreen = require(script.Parent.LoadingScreen)
local MainUI = require(script.Parent.MainUI)
local ParticleEffects = require(script.Parent.ParticleEffects)
local CinematicCamera = require(script.Parent.CinematicCamera)
local TutorialSystem = require(script.Parent.TutorialSystem)

-- Show loading screen FIRST (before anything else)
LoadingScreen.show()

-- Initialize UI after character loads
local player = game.Players.LocalPlayer
player.CharacterAdded:Wait()
task.wait(1)

-- Initialize core systems
MainUI.init()
ParticleEffects.init()
CinematicCamera.init()

-- Store references for MainUI event handlers
MainUI._particleEffects = ParticleEffects
MainUI._cinematicCamera = CinematicCamera

-- Hide loading screen with fade now that everything is ready
LoadingScreen.hide()

-- Show tutorial for first-time players
if TutorialSystem.shouldShow() then
	task.wait(0.5)
	TutorialSystem.show()
end

print("[Client] Mansion Mayhem UI ready for", player.DisplayName)
]]></string>
        </Properties>
        <Item class="ModuleScript" referent="25">
          <Properties>
            <string name="Name">CinematicCamera</string>
            <string name="Source"><![CDATA[-- ============================================================
-- CINEMATIC CAMERA — Dramatic camera control for key moments
-- Elimination ceremonies, Queen crowning, fights, announcements
-- ============================================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer

local CinematicCamera = {}

-- State
CinematicCamera._isLocked = false
CinematicCamera._originalCameraType = nil
CinematicCamera._activeTween = nil
CinematicCamera._activeConnection = nil
CinematicCamera._darkenFrame = nil

-- ============================================================
-- INITIALIZATION
-- ============================================================

function CinematicCamera.init()
	-- Pre-create the screen darken frame for dramatic reveals
	local playerGui = player:WaitForChild("PlayerGui")
	local sg = playerGui:FindFirstChild("MansionUI")
	if sg then
		local darken = Instance.new("Frame")
		darken.Name = "CinematicDarken"
		darken.Size = UDim2.new(1, 0, 1, 0)
		darken.Position = UDim2.new(0, 0, 0, 0)
		darken.BackgroundColor3 = Color3.new(0, 0, 0)
		darken.BackgroundTransparency = 1 -- fully transparent by default
		darken.BorderSizePixel = 0
		darken.ZIndex = 100
		darken.Visible = false
		darken.Parent = sg

		CinematicCamera._darkenFrame = darken
	end

	print("[CinematicCamera] Initialized")
end

-- ============================================================
-- LOCK / UNLOCK CAMERA
-- ============================================================

function CinematicCamera.lockCamera()
	if CinematicCamera._isLocked then return end

	local camera = workspace.CurrentCamera
	CinematicCamera._originalCameraType = camera.CameraType
	camera.CameraType = Enum.CameraType.Scriptable
	CinematicCamera._isLocked = true
end

function CinematicCamera.unlockCamera()
	if not CinematicCamera._isLocked then return end

	-- Stop any active connections
	CinematicCamera._stopActive()

	local camera = workspace.CurrentCamera
	camera.CameraType = CinematicCamera._originalCameraType or Enum.CameraType.Custom
	CinematicCamera._isLocked = false

	-- Hide darken
	if CinematicCamera._darkenFrame then
		CinematicCamera._darkenFrame.Visible = false
		CinematicCamera._darkenFrame.BackgroundTransparency = 1
	end
end

function CinematicCamera._stopActive()
	if CinematicCamera._activeTween then
		CinematicCamera._activeTween:Cancel()
		CinematicCamera._activeTween = nil
	end
	if CinematicCamera._activeConnection then
		CinematicCamera._activeConnection:Disconnect()
		CinematicCamera._activeConnection = nil
	end
end

-- ============================================================
-- PAN TO — Smooth camera pan to a target position
-- ============================================================

function CinematicCamera.panTo(targetPosition, duration)
	duration = duration or 2

	CinematicCamera.lockCamera()
	CinematicCamera._stopActive()

	local camera = workspace.CurrentCamera
	local startCFrame = camera.CFrame
	local lookAt = targetPosition

	-- Calculate a good camera position (slightly above and behind)
	local direction = (targetPosition - startCFrame.Position).Unit
	local cameraTarget = targetPosition - direction * 10 + Vector3.new(0, 5, 0)
	local endCFrame = CFrame.new(cameraTarget, lookAt)

	-- Tween the camera
	local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
	local startTime = os.clock()

	CinematicCamera._activeConnection = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		local alpha = math.clamp(elapsed / duration, 0, 1)

		-- Smooth ease in-out
		local smoothAlpha = alpha * alpha * (3 - 2 * alpha)

		camera.CFrame = startCFrame:Lerp(endCFrame, smoothAlpha)

		if alpha >= 1 then
			CinematicCamera._stopActive()
		end
	end)
end

-- ============================================================
-- ZOOM ON PLAYER — Close-up on a specific player
-- ============================================================

function CinematicCamera.zoomOnPlayer(targetPlayer, distance, duration)
	distance = distance or 6
	duration = duration or 1.5

	CinematicCamera.lockCamera()
	CinematicCamera._stopActive()

	local camera = workspace.CurrentCamera

	-- Find target character
	local character = nil
	if typeof(targetPlayer) == "Instance" and targetPlayer:IsA("Player") then
		character = targetPlayer.Character
	elseif typeof(targetPlayer) == "number" then
		local p = Players:GetPlayerByUserId(targetPlayer)
		if p then character = p.Character end
	end

	if not character then
		CinematicCamera.unlockCamera()
		return
	end

	local head = character:FindFirstChild("Head")
	if not head then
		CinematicCamera.unlockCamera()
		return
	end

	local startCFrame = camera.CFrame
	local startTime = os.clock()

	CinematicCamera._activeConnection = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		local alpha = math.clamp(elapsed / duration, 0, 1)
		local smoothAlpha = alpha * alpha * (3 - 2 * alpha)

		-- Target: slightly in front of and above the player's head
		local headPos = head.Position
		local lookDir = head.CFrame.LookVector
		local cameraPos = headPos + lookDir * distance + Vector3.new(0, 1.5, 0)
		local endCFrame = CFrame.new(cameraPos, headPos)

		camera.CFrame = startCFrame:Lerp(endCFrame, smoothAlpha)

		if alpha >= 1 then
			-- Keep following head after zoom
			if CinematicCamera._activeConnection then
				CinematicCamera._activeConnection:Disconnect()
			end
			CinematicCamera._activeConnection = RunService.RenderStepped:Connect(function()
				if not head or not head.Parent then
					CinematicCamera._stopActive()
					return
				end
				local hp = head.Position
				local ld = head.CFrame.LookVector
				local cp = hp + ld * distance + Vector3.new(0, 1.5, 0)
				camera.CFrame = CFrame.new(cp, hp)
			end)
		end
	end)
end

-- ============================================================
-- ORBIT AROUND — Orbit camera around a center point
-- ============================================================

function CinematicCamera.orbitAround(center, radius, duration, height)
	radius = radius or 15
	duration = duration or 8
	height = height or 8

	CinematicCamera.lockCamera()
	CinematicCamera._stopActive()

	local camera = workspace.CurrentCamera
	local startTime = os.clock()

	CinematicCamera._activeConnection = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		if elapsed > duration then
			CinematicCamera._stopActive()
			return
		end

		local progress = elapsed / duration
		local angle = progress * math.pi * 2 -- full orbit

		local x = center.X + math.cos(angle) * radius
		local z = center.Z + math.sin(angle) * radius
		local y = center.Y + height

		camera.CFrame = CFrame.new(Vector3.new(x, y, z), center)
	end)
end

-- ============================================================
-- DRAMATIC REVEAL — Slow zoom in with screen darken
-- ============================================================

function CinematicCamera.dramaticReveal(targetPosition)
	CinematicCamera.lockCamera()
	CinematicCamera._stopActive()

	local camera = workspace.CurrentCamera

	-- Darken the screen
	if CinematicCamera._darkenFrame then
		CinematicCamera._darkenFrame.Visible = true
		CinematicCamera._darkenFrame.BackgroundTransparency = 1

		local darkenTween = TweenService:Create(
			CinematicCamera._darkenFrame,
			TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
			{ BackgroundTransparency = 0.6 }
		)
		darkenTween:Play()
	end

	-- Start far away and zoom in slowly
	local startDistance = 30
	local endDistance = 8
	local duration = 4
	local height = 10

	local startPos = targetPosition + Vector3.new(startDistance, height, 0)
	camera.CFrame = CFrame.new(startPos, targetPosition)

	local startTime = os.clock()

	CinematicCamera._activeConnection = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		local alpha = math.clamp(elapsed / duration, 0, 1)
		local smoothAlpha = alpha * alpha * (3 - 2 * alpha)

		local currentDistance = startDistance + (endDistance - startDistance) * smoothAlpha
		local currentHeight = height * (1 - smoothAlpha * 0.3)
		local angle = smoothAlpha * math.pi * 0.3 -- slight orbit during zoom

		local x = targetPosition.X + math.cos(angle) * currentDistance
		local z = targetPosition.Z + math.sin(angle) * currentDistance
		local y = targetPosition.Y + currentHeight

		camera.CFrame = CFrame.new(Vector3.new(x, y, z), targetPosition)

		if alpha >= 1 then
			CinematicCamera._stopActive()

			-- Lighten screen back
			if CinematicCamera._darkenFrame then
				task.delay(2, function()
					local lightenTween = TweenService:Create(
						CinematicCamera._darkenFrame,
						TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
						{ BackgroundTransparency = 1 }
					)
					lightenTween:Play()
					lightenTween.Completed:Connect(function()
						CinematicCamera._darkenFrame.Visible = false
					end)
				end)
			end
		end
	end)
end

return CinematicCamera
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="26">
          <Properties>
            <string name="Name">LoadingScreen</string>
            <string name="Source"><![CDATA[-- ============================================================
-- LOADING SCREEN — Branded loading screen for Mansion Mayhem
-- Shows while game assets load, with animated tips and effects
-- ============================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local LoadingScreen = {}

-- Loading tips that cycle every 3 seconds
local TIPS = {
	"Form alliances to survive longer...",
	"The Queen chooses who sleeps where...",
	"Check in daily for immunity shards...",
	"Post confessions on the Tea Wall...",
	"The Director is always watching...",
	"3 immunity shards = 1 immunity token...",
	"Win challenges for XP and coins...",
	"The Dog House is no place for a winner...",
}

local _screenGui = nil
local _tipIndex = 1
local _dotCount = 0
local _running = false
local _tipConnection = nil
local _dotConnection = nil

-- ============================================================
-- SHOW — Creates and displays the loading screen
-- ============================================================

function LoadingScreen.show()
	if _screenGui then return end
	_running = true

	local sg = Instance.new("ScreenGui")
	sg.Name = "LoadingScreen"
	sg.ResetOnSpawn = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.DisplayOrder = 100 -- Render above everything
	sg.IgnoreGuiInset = true
	sg.Parent = playerGui
	_screenGui = sg

	-- Full screen dark purple background
	local bg = Instance.new("Frame")
	bg.Name = "Background"
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.Position = UDim2.new(0, 0, 0, 0)
	bg.BackgroundColor3 = Color3.fromHex("#0A0610")
	bg.BorderSizePixel = 0
	bg.Parent = sg

	-- Pink neon border glow (outer frame with gradient)
	local glowBorder = Instance.new("Frame")
	glowBorder.Name = "GlowBorder"
	glowBorder.Size = UDim2.new(1, -20, 1, -20)
	glowBorder.Position = UDim2.new(0, 10, 0, 10)
	glowBorder.BackgroundTransparency = 1
	glowBorder.BorderSizePixel = 0
	glowBorder.Parent = bg

	local borderStroke = Instance.new("UIStroke")
	borderStroke.Color = Color3.fromHex("#FF1493")
	borderStroke.Thickness = 3
	borderStroke.Transparency = 0.3
	borderStroke.Parent = glowBorder

	local borderCorner = Instance.new("UICorner")
	borderCorner.CornerRadius = UDim.new(0, 16)
	borderCorner.Parent = glowBorder

	-- Outer glow layer (softer, larger)
	local glowOuter = Instance.new("Frame")
	glowOuter.Name = "GlowOuter"
	glowOuter.Size = UDim2.new(1, -14, 1, -14)
	glowOuter.Position = UDim2.new(0, 7, 0, 7)
	glowOuter.BackgroundTransparency = 1
	glowOuter.BorderSizePixel = 0
	glowOuter.Parent = bg

	local outerStroke = Instance.new("UIStroke")
	outerStroke.Color = Color3.fromHex("#FF1493")
	outerStroke.Thickness = 6
	outerStroke.Transparency = 0.7
	outerStroke.Parent = glowOuter

	local outerCorner = Instance.new("UICorner")
	outerCorner.CornerRadius = UDim.new(0, 20)
	outerCorner.Parent = glowOuter

	-- Animate the glow border pulsing
	task.spawn(function()
		while _running and borderStroke and borderStroke.Parent do
			TweenService:Create(borderStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				Transparency = 0.1,
			}):Play()
			TweenService:Create(outerStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				Transparency = 0.5,
			}):Play()
			task.wait(1.5)
			if not _running then break end
			TweenService:Create(borderStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				Transparency = 0.5,
			}):Play()
			TweenService:Create(outerStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {
				Transparency = 0.85,
			}):Play()
			task.wait(1.5)
		end
	end)

	-- Center container for content
	local center = Instance.new("Frame")
	center.Name = "CenterContainer"
	center.Size = UDim2.new(0.8, 0, 0.6, 0)
	center.Position = UDim2.new(0.1, 0, 0.15, 0)
	center.BackgroundTransparency = 1
	center.Parent = bg

	-- Crown symbol above title
	local crown = Instance.new("TextLabel")
	crown.Name = "Crown"
	crown.Size = UDim2.new(1, 0, 0, 60)
	crown.Position = UDim2.new(0, 0, 0.15, 0)
	crown.BackgroundTransparency = 1
	crown.Text = "\xF0\x9F\x91\x91" -- Crown emoji
	crown.TextColor3 = Color3.fromHex("#FFD700")
	crown.TextSize = 48
	crown.Font = Enum.Font.GothamBold
	crown.Parent = center

	-- Main title: MANSION OF MAYHEM
	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(1, 0, 0, 60)
	title.Position = UDim2.new(0, 0, 0.32, 0)
	title.BackgroundTransparency = 1
	title.Text = "MANSION OF MAYHEM"
	title.TextColor3 = Color3.fromHex("#FFD700")
	title.TextSize = 42
	title.Font = Enum.Font.GothamBold
	title.TextScaled = true
	title.Parent = center

	-- Gold stroke on title for extra pop
	local titleStroke = Instance.new("UIStroke")
	titleStroke.Color = Color3.fromHex("#B8860B")
	titleStroke.Thickness = 1
	titleStroke.Transparency = 0.5
	titleStroke.Parent = title

	-- Tagline
	local tagline = Instance.new("TextLabel")
	tagline.Name = "Tagline"
	tagline.Size = UDim2.new(1, 0, 0, 30)
	tagline.Position = UDim2.new(0, 0, 0.48, 0)
	tagline.BackgroundTransparency = 1
	tagline.Text = "20 players. 10 bedrooms. 1 survivor."
	tagline.TextColor3 = Color3.fromHex("#FF1493")
	tagline.TextSize = 20
	tagline.Font = Enum.Font.GothamBold
	tagline.Parent = center

	-- Loading dots text
	local loadingLabel = Instance.new("TextLabel")
	loadingLabel.Name = "LoadingLabel"
	loadingLabel.Size = UDim2.new(1, 0, 0, 30)
	loadingLabel.Position = UDim2.new(0, 0, 0.62, 0)
	loadingLabel.BackgroundTransparency = 1
	loadingLabel.Text = "Loading"
	loadingLabel.TextColor3 = Color3.fromHex("#F8F4F0")
	loadingLabel.TextSize = 16
	loadingLabel.Font = Enum.Font.Gotham
	loadingLabel.Parent = center

	-- Tip label
	local tipLabel = Instance.new("TextLabel")
	tipLabel.Name = "TipLabel"
	tipLabel.Size = UDim2.new(0.8, 0, 0, 30)
	tipLabel.Position = UDim2.new(0.1, 0, 0.78, 0)
	tipLabel.BackgroundTransparency = 1
	tipLabel.Text = TIPS[1]
	tipLabel.TextColor3 = Color3.fromHex("#808080")
	tipLabel.TextSize = 14
	tipLabel.Font = Enum.Font.GothamMedium
	tipLabel.TextWrapped = true
	tipLabel.Parent = center

	-- Tip prefix
	local tipPrefix = Instance.new("TextLabel")
	tipPrefix.Name = "TipPrefix"
	tipPrefix.Size = UDim2.new(0.8, 0, 0, 20)
	tipPrefix.Position = UDim2.new(0.1, 0, 0.73, 0)
	tipPrefix.BackgroundTransparency = 1
	tipPrefix.Text = "TIP:"
	tipPrefix.TextColor3 = Color3.fromHex("#FF1493")
	tipPrefix.TextSize = 12
	tipPrefix.Font = Enum.Font.GothamBold
	tipPrefix.Parent = center

	-- Animate loading dots
	_dotCount = 0
	task.spawn(function()
		while _running do
			_dotCount = (_dotCount % 3) + 1
			local dots = string.rep(".", _dotCount)
			if loadingLabel and loadingLabel.Parent then
				loadingLabel.Text = "Loading" .. dots
			end
			task.wait(0.5)
		end
	end)

	-- Cycle tips every 3 seconds
	_tipIndex = 1
	task.spawn(function()
		while _running do
			task.wait(3)
			if not _running then break end
			_tipIndex = (_tipIndex % #TIPS) + 1
			if tipLabel and tipLabel.Parent then
				-- Fade out
				TweenService:Create(tipLabel, TweenInfo.new(0.3), {
					TextTransparency = 1,
				}):Play()
				task.wait(0.3)
				if not _running then break end
				tipLabel.Text = TIPS[_tipIndex]
				-- Fade in
				TweenService:Create(tipLabel, TweenInfo.new(0.3), {
					TextTransparency = 0,
				}):Play()
			end
		end
	end)

	print("[LoadingScreen] Displayed")
end

-- ============================================================
-- UPDATE TIP — Manually cycle to next tip
-- ============================================================

function LoadingScreen.updateTip()
	if not _screenGui then return end
	_tipIndex = (_tipIndex % #TIPS) + 1

	local center = _screenGui:FindFirstChild("Background")
	if not center then return end
	center = center:FindFirstChild("CenterContainer")
	if not center then return end
	local tipLabel = center:FindFirstChild("TipLabel")
	if tipLabel then
		tipLabel.Text = TIPS[_tipIndex]
	end
end

-- ============================================================
-- HIDE — Fade out and destroy loading screen
-- ============================================================

function LoadingScreen.hide()
	_running = false

	if not _screenGui then return end

	local bg = _screenGui:FindFirstChild("Background")
	if bg then
		-- Fade out the entire background
		local fadeInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		local fadeTween = TweenService:Create(bg, fadeInfo, {
			BackgroundTransparency = 1,
		})

		-- Also fade all children
		for _, desc in bg:GetDescendants() do
			if desc:IsA("TextLabel") then
				TweenService:Create(desc, fadeInfo, {
					TextTransparency = 1,
				}):Play()
			elseif desc:IsA("Frame") then
				TweenService:Create(desc, fadeInfo, {
					BackgroundTransparency = 1,
				}):Play()
			elseif desc:IsA("UIStroke") then
				TweenService:Create(desc, fadeInfo, {
					Transparency = 1,
				}):Play()
			end
		end

		fadeTween:Play()
		fadeTween.Completed:Wait()
	end

	-- Destroy
	if _screenGui then
		_screenGui:Destroy()
		_screenGui = nil
	end

	print("[LoadingScreen] Hidden and destroyed")
end

return LoadingScreen
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="27">
          <Properties>
            <string name="Name">MainUI</string>
            <string name="Source"><![CDATA[-- ============================================================
-- MAIN UI — Client-side HUD and interactive screens
-- Voting, Elimination, Fight alerts, Alliances, Challenges,
-- Immunity, Season info, Leaderboard
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local GuiService = game:GetService("GuiService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- Wait for shared config
local Config = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Config"))
local SoundSystem = require(script.Parent.SoundSystem)
local ShopUI = require(script.Parent.ShopUI)
local SpectatorSystem = require(script.Parent.SpectatorSystem)

local MainUI = {}

-- Track open panels
MainUI._teaOpen = false
MainUI._activePanelName = nil

-- Platform detection
local isTouch = UserInputService.TouchEnabled
local isGamepad = UserInputService.GamepadEnabled

-- Adaptive scaling based on platform
local BASE_TEXT_SCALE = isTouch and 1.25 or 1.0
local MIN_BUTTON_SIZE = isTouch and 48 or 30
local NAV_HEIGHT = isTouch and 72 or 60
local HUD_HEIGHT = isTouch and 60 or 50

-- ============================================================
-- HELPERS
-- ============================================================

local function createCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 10)
	corner.Parent = parent
	return corner
end

local function createStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or Config.Colors.Border
	stroke.Thickness = thickness or 1
	stroke.Parent = parent
	return stroke
end

local function tweenIn(frame, targetPos, duration)
	TweenService:Create(frame, TweenInfo.new(duration or 0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
		Position = targetPos,
	}):Play()
end

local function tweenOut(frame, targetPos, duration)
	TweenService:Create(frame, TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
		Position = targetPos,
	}):Play()
end

local function createCloseButton(parent, callback)
	local closeBtnSize = math.max(MIN_BUTTON_SIZE, 30)
	local btn = Instance.new("TextButton")
	btn.Name = "CloseBtn"
	btn.Size = UDim2.new(0, closeBtnSize, 0, closeBtnSize)
	btn.Position = UDim2.new(1, -(closeBtnSize + 5), 0, 5)
	btn.BackgroundTransparency = 1
	btn.Text = "X"
	btn.TextColor3 = Config.Colors.TextMuted
	btn.TextSize = math.floor(16 * BASE_TEXT_SCALE)
	btn.Font = Enum.Font.GothamBold
	btn.Parent = parent
	btn.MouseButton1Click:Connect(function()
		SoundSystem.play("ui_click")
		callback()
	end)
	return btn
end

-- ============================================================
-- INITIALIZATION
-- ============================================================

function MainUI.init()
	-- Initialize sound system
	SoundSystem.init()

	local sg = Instance.new("ScreenGui")
	sg.Name = "MansionUI"
	sg.ResetOnSpawn = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.Parent = playerGui

	-- Core UI
	MainUI.createHUD(sg)
	MainUI.createBottomNav(sg)
	MainUI.createTeaPanel(sg)
	MainUI.createDirectorOverlay(sg)
	MainUI.createCheckInPopup(sg)

	-- New panels
	MainUI.createVotingScreen(sg)
	MainUI.createEliminationOverlay(sg)
	MainUI.createFightAlertPopup(sg)
	MainUI.createAlliancePanel(sg)
	MainUI.createChallengePanel(sg)
	MainUI.createImmunityHUD(sg)
	MainUI.createSeasonInfoPanel(sg)
	MainUI.createLeaderboardPanel(sg)

	-- Bus UI elements
	MainUI.createBusUI(sg)

	-- Shop panel
	ShopUI.createShopPanel(sg)

	-- Initialize spectator system
	SpectatorSystem.init()

	-- Gamepad support: create selection highlight
	if isGamepad then
		MainUI._setupGamepadNav(sg)
	end

	-- Listen for server events
	MainUI.listenForEvents()

	-- Start ambient background music
	SoundSystem.playMusic("mansion_ambient")

	print("[MainUI] UI initialized")
end

-- ============================================================
-- GAMEPAD NAVIGATION SUPPORT
-- ============================================================

function MainUI._setupGamepadNav(sg)
	-- Add gamepad prompts overlay
	local promptFrame = Instance.new("Frame")
	promptFrame.Name = "GamepadPrompts"
	promptFrame.Size = UDim2.new(0, 200, 0, 30)
	promptFrame.Position = UDim2.new(1, -210, 1, -(NAV_HEIGHT + 35))
	promptFrame.BackgroundTransparency = 1
	promptFrame.Parent = sg

	local aPrompt = Instance.new("TextLabel")
	aPrompt.Name = "APrompt"
	aPrompt.Size = UDim2.new(0.5, 0, 1, 0)
	aPrompt.BackgroundTransparency = 1
	aPrompt.Text = "[A] Confirm"
	aPrompt.TextColor3 = Config.Colors.Green
	aPrompt.TextSize = math.floor(11 * BASE_TEXT_SCALE)
	aPrompt.Font = Enum.Font.GothamBold
	aPrompt.TextXAlignment = Enum.TextXAlignment.Right
	aPrompt.Parent = promptFrame

	local bPrompt = Instance.new("TextLabel")
	bPrompt.Name = "BPrompt"
	bPrompt.Size = UDim2.new(0.5, 0, 1, 0)
	bPrompt.Position = UDim2.new(0.5, 0, 0, 0)
	bPrompt.BackgroundTransparency = 1
	bPrompt.Text = "[B] Back"
	bPrompt.TextColor3 = Config.Colors.Red
	bPrompt.TextSize = math.floor(11 * BASE_TEXT_SCALE)
	bPrompt.Font = Enum.Font.GothamBold
	bPrompt.TextXAlignment = Enum.TextXAlignment.Right
	bPrompt.Parent = promptFrame

	-- Set initial selected object to bottom nav first button when gamepad connects
	task.defer(function()
		local nav = sg:FindFirstChild("BottomNav")
		if nav then
			local firstBtn = nav:FindFirstChildWhichIsA("TextButton")
			if firstBtn then
				GuiService.SelectedObject = firstBtn
			end
		end
	end)

	-- B button closes current panel
	UserInputService.InputBegan:Connect(function(input, processed)
		if processed then return end
		if input.KeyCode == Enum.KeyCode.ButtonB then
			MainUI._closeAllPanels()
		end
	end)
end

-- ============================================================
-- HUD (Top Bar)
-- ============================================================

function MainUI.createHUD(parent)
	local hud = Instance.new("Frame")
	hud.Name = "HUD"
	hud.Size = UDim2.new(1, 0, 0, HUD_HEIGHT)
	hud.Position = UDim2.new(0, 0, 0, 0)
	hud.BackgroundColor3 = Config.Colors.Background
	hud.BackgroundTransparency = 0.2
	hud.BorderSizePixel = 0
	hud.Parent = parent

	-- Season title
	local title = Instance.new("TextLabel")
	title.Name = "SeasonTitle"
	title.Size = UDim2.new(0.4, 0, 1, 0)
	title.Position = UDim2.new(0, 12, 0, 0)
	title.BackgroundTransparency = 1
	title.Text = "MANSION OF MAYHEM"
	title.TextColor3 = Config.Colors.Gold
	title.TextSize = math.floor(16 * BASE_TEXT_SCALE)
	title.Font = Enum.Font.GothamBold
	title.TextXAlignment = Enum.TextXAlignment.Left
	title.Parent = hud

	-- Phase indicator
	local phase = Instance.new("TextLabel")
	phase.Name = "PhaseLabel"
	phase.Size = UDim2.new(0.25, 0, 1, 0)
	phase.Position = UDim2.new(0.4, 0, 0, 0)
	phase.BackgroundTransparency = 1
	phase.Text = "MOVE IN"
	phase.TextColor3 = Config.Colors.Pink
	phase.TextSize = math.floor(12 * BASE_TEXT_SCALE)
	phase.Font = Enum.Font.GothamBold
	phase.Parent = hud

	-- Invite Friends button
	local inviteBtnSize = math.max(MIN_BUTTON_SIZE, 30)
	local inviteBtn = Instance.new("TextButton")
	inviteBtn.Name = "InviteBtn"
	inviteBtn.Size = UDim2.new(0, 80, 0, inviteBtnSize)
	inviteBtn.Position = UDim2.new(0.65, 0, 0.5, -(inviteBtnSize / 2))
	inviteBtn.BackgroundColor3 = Config.Colors.Pink
	inviteBtn.BackgroundTransparency = 0.3
	inviteBtn.Text = "Invite"
	inviteBtn.TextColor3 = Config.Colors.Text
	inviteBtn.TextSize = math.floor(12 * BASE_TEXT_SCALE)
	inviteBtn.Font = Enum.Font.GothamBold
	inviteBtn.Parent = hud
	createCorner(inviteBtn, 6)
	createStroke(inviteBtn, Config.Colors.Pink, 1)

	inviteBtn.MouseButton1Click:Connect(function()
		SoundSystem.play("ui_click")
		local SocialService = game:GetService("SocialService")
		local success, canInvite = pcall(function()
			return SocialService:CanSendGameInviteAsync(player)
		end)
		if success and canInvite then
			SocialService:PromptGameInvite(player)
		end
	end)

	-- Bottom border neon
	local border = Instance.new("Frame")
	border.Size = UDim2.new(1, 0, 0, 2)
	border.Position = UDim2.new(0, 0, 1, -2)
	border.BackgroundColor3 = Config.Colors.Pink
	border.BorderSizePixel = 0
	border.Parent = hud
end

-- ============================================================
-- IMMUNITY HUD (shard counter — always visible)
-- ============================================================

function MainUI.createImmunityHUD(parent)
	local frame = Instance.new("Frame")
	frame.Name = "ImmunityHUD"
	frame.Size = UDim2.new(0, 140, 0, 40)
	frame.Position = UDim2.new(1, -155, 0, 5)
	frame.BackgroundColor3 = Config.Colors.Surface
	frame.BackgroundTransparency = 0.3
	frame.BorderSizePixel = 0
	frame.Parent = parent

	createCorner(frame, 8)

	-- Shield icon + shard count
	local shardLabel = Instance.new("TextLabel")
	shardLabel.Name = "ShardLabel"
	shardLabel.Size = UDim2.new(0.5, 0, 1, 0)
	shardLabel.Position = UDim2.new(0, 5, 0, 0)
	shardLabel.BackgroundTransparency = 1
	shardLabel.Text = "0/3"
	shardLabel.TextColor3 = Config.Colors.Blue
	shardLabel.TextSize = 12
	shardLabel.Font = Enum.Font.GothamBold
	shardLabel.TextXAlignment = Enum.TextXAlignment.Left
	shardLabel.Parent = frame

	-- Token count
	local tokenLabel = Instance.new("TextLabel")
	tokenLabel.Name = "TokenLabel"
	tokenLabel.Size = UDim2.new(0.5, 0, 1, 0)
	tokenLabel.Position = UDim2.new(0.5, 0, 0, 0)
	tokenLabel.BackgroundTransparency = 1
	tokenLabel.Text = "0 tokens"
	tokenLabel.TextColor3 = Config.Colors.Gold
	tokenLabel.TextSize = 12
	tokenLabel.Font = Enum.Font.GothamBold
	tokenLabel.TextXAlignment = Enum.TextXAlignment.Right
	tokenLabel.Parent = frame
end

function MainUI.updateImmunityHUD(shards, tokens)
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end
	local frame = sg:FindFirstChild("ImmunityHUD")
	if not frame then return end

	frame.ShardLabel.Text = tostring(shards or 0) .. "/3"
	frame.TokenLabel.Text = tostring(tokens or 0) .. " tokens"
end

-- ============================================================
-- BOTTOM NAV
-- ============================================================

function MainUI.createBottomNav(parent)
	local nav = Instance.new("Frame")
	nav.Name = "BottomNav"
	nav.Size = UDim2.new(1, 0, 0, NAV_HEIGHT)
	nav.Position = UDim2.new(0, 0, 1, -NAV_HEIGHT)
	nav.BackgroundColor3 = Config.Colors.Surface
	nav.BackgroundTransparency = 0.1
	nav.BorderSizePixel = 0
	nav.Parent = parent

	local topBorder = Instance.new("Frame")
	topBorder.Size = UDim2.new(1, 0, 0, 1)
	topBorder.BackgroundColor3 = Config.Colors.Border
	topBorder.BorderSizePixel = 0
	topBorder.Parent = nav

	local tabs = {
		{ text = "Home",       emoji = "HOME" },
		{ text = "Tea",        emoji = "TEA" },
		{ text = "Check In",   emoji = "CHECK" },
		{ text = "Vote",       emoji = "VOTE" },
		{ text = "Alliance",   emoji = "ALLY" },
		{ text = "Challenge",  emoji = "QUEST" },
		{ text = "Shop",       emoji = "\xF0\x9F\x92\x8E" },
		{ text = "Season",     emoji = "INFO" },
		{ text = "Ranks",      emoji = "RANK" },
	}

	local tabTextSize = math.floor(8 * BASE_TEXT_SCALE)
	if isTouch then tabTextSize = math.max(tabTextSize, 10) end

	for i, tab in tabs do
		local btn = Instance.new("TextButton")
		btn.Name = "Tab_" .. tab.text
		btn.Size = UDim2.new(1 / #tabs, 0, 1, -5)
		btn.Position = UDim2.new((i - 1) / #tabs, 0, 0, 5)
		btn.BackgroundTransparency = 1
		btn.Text = tab.emoji .. "\n" .. tab.text
		btn.TextColor3 = Config.Colors.TextMuted
		btn.TextSize = tabTextSize
		btn.Font = Enum.Font.GothamBold
		btn.Parent = nav

		-- Gamepad selection highlighting
		if isGamepad then
			btn.SelectionImageObject = MainUI._createSelectionHighlight()
		end

		btn.MouseButton1Click:Connect(function()
			SoundSystem.play("ui_click")
			MainUI.onTabClick(tab.text)
			for _, child in nav:GetChildren() do
				if child:IsA("TextButton") then
					child.TextColor3 = Config.Colors.TextMuted
				end
			end
			btn.TextColor3 = Config.Colors.Pink
		end)
	end
end

function MainUI._createSelectionHighlight()
	local highlight = Instance.new("ImageLabel")
	highlight.Name = "SelectionHighlight"
	highlight.Size = UDim2.new(1, 4, 1, 4)
	highlight.Position = UDim2.new(0, -2, 0, -2)
	highlight.BackgroundColor3 = Config.Colors.Pink
	highlight.BackgroundTransparency = 0.7
	highlight.BorderSizePixel = 0
	highlight.Image = ""
	createCorner(highlight, 6)
	createStroke(highlight, Config.Colors.Pink, 2)
	return highlight
end

function MainUI.onTabClick(tabName)
	-- Close any open panel first
	MainUI._closeAllPanels()

	if tabName == "Tea" then
		MainUI.toggleTeaPanel()
	elseif tabName == "Check In" then
		MainUI.showCheckIn()
	elseif tabName == "Vote" then
		-- Voting handled by server push
	elseif tabName == "Alliance" then
		MainUI.togglePanel("AlliancePanel")
	elseif tabName == "Challenge" then
		MainUI.togglePanel("ChallengePanel")
	elseif tabName == "Season" then
		MainUI.togglePanel("SeasonInfoPanel")
		-- Request fresh data
		local remotes = ReplicatedStorage:FindFirstChild("Remotes")
		if remotes then
			local req = remotes:FindFirstChild("SeasonInfoRequest")
			if req then req:FireServer() end
		end
	elseif tabName == "Shop" then
		MainUI.togglePanel("ShopPanel")
	elseif tabName == "Ranks" then
		MainUI.togglePanel("LeaderboardPanel")
		local remotes = ReplicatedStorage:FindFirstChild("Remotes")
		if remotes then
			local req = remotes:FindFirstChild("LeaderboardRequest")
			if req then req:FireServer() end
		end
	end
end

function MainUI._closeAllPanels()
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	local panels = { "AlliancePanel", "ChallengePanel", "SeasonInfoPanel", "LeaderboardPanel", "ShopPanel" }
	for _, name in panels do
		local panel = sg:FindFirstChild(name)
		if panel and panel.Visible then
			panel.Visible = false
		end
	end

	if MainUI._teaOpen then
		MainUI.toggleTeaPanel()
	end

	MainUI._activePanelName = nil
end

function MainUI.togglePanel(panelName)
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	local panel = sg:FindFirstChild(panelName)
	if not panel then return end

	if MainUI._activePanelName == panelName then
		panel.Visible = false
		MainUI._activePanelName = nil
	else
		panel.Visible = true
		MainUI._activePanelName = panelName
	end
end

