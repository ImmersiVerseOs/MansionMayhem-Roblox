      <Item class="ModuleScript" referent="11">
        <Properties>
          <string name="Name">DataStoreBackup</string>
          <string name="Source"><![CDATA[-- ============================================================
-- DATASTORE BACKUP — Roblox DataStoreService fallback for Supabase
-- Persists critical player data locally in case Supabase is down
-- ============================================================

local Players = game:GetService("Players")
local DataStoreService = game:GetService("DataStoreService")

local DataStoreBackup = {}

-- State
DataStoreBackup.dataStore = nil
DataStoreBackup.lastSaveTime = {} -- { [userId] = os.clock() timestamp }
DataStoreBackup._autoSaveConnection = nil

-- Config
local SAVE_DEBOUNCE = 30 -- minimum seconds between saves per player
local AUTO_SAVE_INTERVAL = 60 -- seconds between auto-save cycles
local DATA_STORE_NAME = "MansionMayhemPlayerData"

-- ============================================================
-- INITIALIZATION
-- ============================================================

function DataStoreBackup.init()
	local success, store = pcall(function()
		return DataStoreService:GetDataStore(DATA_STORE_NAME)
	end)

	if success then
		DataStoreBackup.dataStore = store
		print("[DataStoreBackup] DataStore initialized:", DATA_STORE_NAME)
	else
		warn("[DataStoreBackup] Failed to get DataStore:", store)
	end
end

-- ============================================================
-- SAVE PLAYER DATA
-- ============================================================

function DataStoreBackup.savePlayer(userId, data)
	if not DataStoreBackup.dataStore then return false end
	if not userId or not data then return false end

	-- Debounce: max once per 30 seconds per player
	local now = os.clock()
	if DataStoreBackup.lastSaveTime[userId] and (now - DataStoreBackup.lastSaveTime[userId]) < SAVE_DEBOUNCE then
		return false -- too soon, skip
	end

	local key = "player_" .. tostring(userId)

	-- Build the data table with only the fields we want to persist
	local saveData = {
		xp = data.xp or 0,
		coins = data.coins or 0,
		immunityShards = data.immunityShards or 0,
		immunityTokens = data.immunityTokens or 0,
		fightsWon = data.fightsWon or 0,
		fightsLost = data.fightsLost or 0,
		allianceCount = data.allianceCount or 0,
		betrayalCount = data.betrayalCount or 0,
		checkedInToday = data.checkedInToday or false,
		lastCheckIn = data.lastCheckIn or "",
		eliminated = data.eliminated or false,
		queenCount = data.queenCount or 0,
		savedAt = os.date("!%Y-%m-%dT%H:%M:%SZ"),
	}

	local success, err = pcall(function()
		DataStoreBackup.dataStore:SetAsync(key, saveData)
	end)

	if success then
		DataStoreBackup.lastSaveTime[userId] = now
		return true
	else
		warn("[DataStoreBackup] Save failed for", userId, ":", err)
		return false
	end
end

-- ============================================================
-- LOAD PLAYER DATA
-- ============================================================

function DataStoreBackup.loadPlayer(userId)
	if not DataStoreBackup.dataStore then return nil end
	if not userId then return nil end

	local key = "player_" .. tostring(userId)

	local success, data = pcall(function()
		return DataStoreBackup.dataStore:GetAsync(key)
	end)

	if success and data then
		print("[DataStoreBackup] Loaded data for player", userId)
		return data
	elseif not success then
		warn("[DataStoreBackup] Load failed for", userId, ":", data)
	end

	return nil
end

-- ============================================================
-- DELETE PLAYER DATA
-- ============================================================

function DataStoreBackup.deletePlayer(userId)
	if not DataStoreBackup.dataStore then return false end
	if not userId then return false end

	local key = "player_" .. tostring(userId)

	local success, err = pcall(function()
		DataStoreBackup.dataStore:RemoveAsync(key)
	end)

	if success then
		print("[DataStoreBackup] Deleted data for player", userId)
		DataStoreBackup.lastSaveTime[userId] = nil
		return true
	else
		warn("[DataStoreBackup] Delete failed for", userId, ":", err)
		return false
	end
end

-- ============================================================
-- AUTO-SAVE ALL ACTIVE PLAYERS
-- ============================================================

function DataStoreBackup.autoSave(gameManager)
	if not DataStoreBackup.dataStore then return end
	if not gameManager or not gameManager.playerMap then return end

	local savedCount = 0

	for userId, playerData in gameManager.playerMap do
		-- Build a complete data snapshot from playerMap + subsystem state
		local fullData = DataStoreBackup._buildFullPlayerData(userId, playerData, gameManager)

		local saved = DataStoreBackup.savePlayer(userId, fullData)
		if saved then
			savedCount += 1
		end
	end

	if savedCount > 0 then
		print("[DataStoreBackup] Auto-save complete:", savedCount, "player(s) saved")
	end
end

-- ============================================================
-- ON PLAYER LEAVE — Save before disconnect
-- ============================================================

function DataStoreBackup.onPlayerLeave(player, gameManager)
	if not player or not gameManager then return end

	local userId = player.UserId
	local playerData = gameManager.playerMap[userId]
	if not playerData then return end

	-- Force save (bypass debounce by clearing last save time)
	DataStoreBackup.lastSaveTime[userId] = nil

	local fullData = DataStoreBackup._buildFullPlayerData(userId, playerData, gameManager)
	local saved = DataStoreBackup.savePlayer(userId, fullData)

	if saved then
		print("[DataStoreBackup] Saved data for departing player:", player.Name)
	end
end

-- ============================================================
-- MERGE LOADED DATA INTO PLAYER MAP ENTRY
-- ============================================================

function DataStoreBackup.mergeIntoPlayerData(playerData, savedData)
	if not playerData or not savedData then return playerData end

	-- Only merge numeric/persistent fields, don't override fresh session state
	playerData.xp = math.max(playerData.xp or 0, savedData.xp or 0)
	playerData.coins = math.max(playerData.coins or 0, savedData.coins or 0)
	playerData.fightsWon = math.max(playerData.fightsWon or 0, savedData.fightsWon or 0)
	playerData.fightsLost = math.max(playerData.fightsLost or 0, savedData.fightsLost or 0)
	playerData.queenCount = math.max(playerData.queenCount or 0, savedData.queenCount or 0)

	-- Carry forward elimination status
	if savedData.eliminated then
		playerData.eliminated = true
	end

	return playerData
end

-- ============================================================
-- INTERNAL: Build full data snapshot
-- ============================================================

function DataStoreBackup._buildFullPlayerData(userId, playerData, gameManager)
	local data = {
		xp = playerData.xp or 0,
		coins = playerData.coins or 0,
		fightsWon = playerData.fightsWon or 0,
		fightsLost = playerData.fightsLost or 0,
		eliminated = playerData.eliminated or false,
		queenCount = playerData.queenCount or 0,
		checkedInToday = playerData.checkedIn or false,
		lastCheckIn = playerData.lastCheckIn or "",
	}

	-- Pull immunity data from ImmunitySystem
	if gameManager.immunitySystem then
		data.immunityShards = gameManager.immunitySystem.getShards(userId)
		data.immunityTokens = gameManager.immunitySystem.getTokens(userId)
	else
		data.immunityShards = 0
		data.immunityTokens = 0
	end

	-- Pull alliance stats from AllianceSystem
	if gameManager.allianceSystem then
		local stats = gameManager.allianceSystem.getPlayerStats(userId)
		data.allianceCount = stats.alliance_count or 0
		data.betrayalCount = stats.betrayal_count or 0
	else
		data.allianceCount = 0
		data.betrayalCount = 0
	end

	return data
end

-- ============================================================
-- START AUTO-SAVE LOOP
-- ============================================================

function DataStoreBackup.startAutoSaveLoop(gameManager)
	DataStoreBackup._autoSaveConnection = task.spawn(function()
		while true do
			task.wait(AUTO_SAVE_INTERVAL)
			DataStoreBackup.autoSave(gameManager)
		end
	end)
	print("[DataStoreBackup] Auto-save loop started (every", AUTO_SAVE_INTERVAL, "seconds)")
end

return DataStoreBackup
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="12">
        <Properties>
          <string name="Name">EliminationSystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- ELIMINATION SYSTEM — Dramatic ceremony + removal for Mansion Mayhem
-- Teleports players to Elimination Room, reveals votes, eliminates
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local SupabaseAPI = require(script.Parent.SupabaseAPI)
local Config = require(ReplicatedStorage.Shared.Config)

local EliminationSystem = {}

-- State
EliminationSystem.isActive = false
EliminationSystem.eliminatedPlayers = {} -- { [userId] = { name, week, round } }
EliminationSystem.spectators = {} -- { [userId] = true }

-- Elimination Room location (matches MansionBuilder)
local ELIMINATION_ROOM_CENTER = Vector3.new(135, 1, -25)
local STAGE_CENTER = Vector3.new(135, 2, -25)
local AUDIENCE_START = Vector3.new(125, 1, -15)

-- ============================================================
-- ELIMINATION CEREMONY
-- ============================================================

function EliminationSystem.startCeremony(gameManager)
	if EliminationSystem.isActive then
		warn("[EliminationSystem] Ceremony already in progress")
		return false
	end

	EliminationSystem.isActive = true
	print("[EliminationSystem] Starting Elimination Ceremony...")

	-- Director announcement
	if gameManager then
		gameManager.directorAnnounce("Everyone to the Elimination Room. NOW.")
	end

	task.wait(3)

	-- Teleport all active players to the Elimination Room
	EliminationSystem._teleportAllToEliminationRoom(gameManager)

	task.wait(2)

	-- Dim the lights effect (notify clients)
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("EliminationStart")
	if remote then
		remote:FireAllClients({
			phase = "gathering",
			message = "The votes have been cast. The Director will now reveal the results.",
		})
	end

	task.wait(3)

	if gameManager then
		gameManager.directorAnnounce("Let the elimination begin.")
	end

	return true
end

function EliminationSystem._teleportAllToEliminationRoom(gameManager)
	local index = 0
	for _, player in Players:GetPlayers() do
		-- Skip spectators
		if EliminationSystem.spectators[player.UserId] then continue end

		local character = player.Character
		if character then
			local humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
			if humanoidRootPart then
				-- Arrange in a semicircle around the stage
				local angle = math.rad(180 + (index * 18) - 80)
				local radius = 12
				local pos = Vector3.new(
					STAGE_CENTER.X + math.cos(angle) * radius,
					STAGE_CENTER.Y,
					STAGE_CENTER.Z + math.sin(angle) * radius
				)
				humanoidRootPart.CFrame = CFrame.new(pos, STAGE_CENTER)
				index += 1
			end
		end
	end

	print("[EliminationSystem] Teleported", index, "players to Elimination Room")
end

-- ============================================================
-- DRAMATIC REVEAL SEQUENCE
-- ============================================================

function EliminationSystem.runDramaticReveal(nominees, results, gameManager)
	if not EliminationSystem.isActive then return end

	print("[EliminationSystem] Running dramatic reveal sequence...")

	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("EliminationReveal")

	-- Step 1: Spotlight on each nominee with a pause
	for i, nominee in nominees do
		if gameManager then
			gameManager.directorAnnounce(nominee.name .. "... step forward.")
		end

		-- Move nominee to stage
		local nomineePlayer = Players:GetPlayerByUserId(nominee.userId)
		if nomineePlayer and nomineePlayer.Character then
			local hrp = nomineePlayer.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local stageAngle = math.rad(90 + (i - 1) * (180 / math.max(#nominees - 1, 1)))
				local stagePos = Vector3.new(
					STAGE_CENTER.X + math.cos(stageAngle) * 4,
					STAGE_CENTER.Y + 1,
					STAGE_CENTER.Z + math.sin(stageAngle) * 4
				)
				hrp.CFrame = CFrame.new(stagePos, STAGE_CENTER)
			end
		end

		if remote then
			remote:FireAllClients({
				phase = "spotlight",
				nomineeIndex = i,
				nomineeName = nominee.name,
				nomineeUserId = nominee.userId,
			})
		end

		task.wait(3)
	end

	-- Step 2: Countdown
	if gameManager then
		gameManager.directorAnnounce("The person leaving the Mansion tonight is...")
	end

	if remote then
		remote:FireAllClients({
			phase = "countdown",
			duration = 5,
		})
	end

	-- Dramatic countdown
	for i = 5, 1, -1 do
		task.wait(1)
		if remote then
			remote:FireAllClients({
				phase = "countdown_tick",
				number = i,
			})
		end
	end

	task.wait(1)

	-- Step 3: Reveal the eliminated player
	local eliminated = results[1] -- highest votes
	if eliminated then
		if gameManager then
			gameManager.directorAnnounce(eliminated.name .. "... your time in the Mansion is OVER.")
		end

		if remote then
			remote:FireAllClients({
				phase = "eliminated",
				name = eliminated.name,
				userId = eliminated.userId,
				voteCount = eliminated.voteCount,
				results = results,
			})
		end

		task.wait(5)
	end

	return eliminated
end

-- ============================================================
-- PROCESS ELIMINATION
-- ============================================================

function EliminationSystem.eliminatePlayer(userId, gameManager)
	local player = Players:GetPlayerByUserId(userId)
	local playerName = "Unknown"

	if player then
		playerName = player.DisplayName or player.Name
	end

	print("[EliminationSystem] Eliminating:", playerName, "(", userId, ")")

	-- Record locally
	local currentWeek = 0
	if gameManager and gameManager.seasonData and gameManager.seasonData.week then
		currentWeek = gameManager.seasonData.week.week_number or 0
	end

	EliminationSystem.eliminatedPlayers[userId] = {
		name = playerName,
		week = currentWeek,
		round = gameManager and gameManager.votingSystem and gameManager.votingSystem.currentRound or 0,
	}

	-- Update player data in GameManager
	if gameManager then
		local playerData = gameManager.playerMap[userId]
		if playerData then
			playerData.eliminated = true
			playerData.eliminatedWeek = currentWeek
		end
	end

	-- Move to spectator mode
	EliminationSystem.spectators[userId] = true

	-- Update Supabase
	if gameManager and gameManager.seasonData then
		local seasonId = gameManager.seasonData.season and gameManager.seasonData.season.id
		if seasonId then
			SupabaseAPI.eliminatePlayer(seasonId, tostring(userId), currentWeek)
		end
	end

	-- Apply spectator mode to the player
	if player then
		EliminationSystem._applySpectatorMode(player, gameManager)
	end

	-- Director farewell
	if gameManager then
		task.wait(3)
		gameManager.directorAnnounce(playerName .. " has left the Mansion. " .. EliminationSystem._getEliminationQuote())
	end

	-- Notify all clients
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("EliminationComplete")
	if remote then
		remote:FireAllClients({
			eliminatedName = playerName,
			eliminatedUserId = userId,
			remainingPlayers = EliminationSystem._countActivePlayers(gameManager),
		})
	end

	EliminationSystem.isActive = false
end

function EliminationSystem._applySpectatorMode(player, gameManager)
	-- Make the player invisible and unable to interact
	local character = player.Character
	if character then
		-- Make transparent
		for _, part in character:GetDescendants() do
			if part:IsA("BasePart") then
				part.Transparency = 0.7
				part.CanCollide = false
			end
		end

		-- Add a "SPECTATOR" overhead label
		local head = character:FindFirstChild("Head")
		if head then
			local existing = head:FindFirstChild("SpectatorGui")
			if not existing then
				local bg = Instance.new("BillboardGui")
				bg.Name = "SpectatorGui"
				bg.Size = UDim2.new(0, 100, 0, 30)
				bg.StudsOffset = Vector3.new(0, 3, 0)
				bg.AlwaysOnTop = true
				bg.Parent = head

				local label = Instance.new("TextLabel")
				label.Size = UDim2.new(1, 0, 1, 0)
				label.BackgroundTransparency = 1
				label.Text = "SPECTATOR"
				label.TextColor3 = Config.Colors.TextMuted
				label.TextSize = 14
				label.Font = Enum.Font.GothamBold
				label.Parent = bg
			end
		end
	end

	-- Teleport to rooftop (spectator area)
	local rooftopY = 20 + 14 + 2
	if character then
		local hrp = character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(100, rooftopY + 2, 0)
		end
	end

	-- Notify the eliminated player
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("SpectatorMode")
	if remote then
		remote:FireClient(player, {
			eliminated = true,
			message = "You have been eliminated. You can now spectate the remaining players.",
		})
	end
end

function EliminationSystem._countActivePlayers(gameManager)
	local count = 0
	if gameManager then
		for userId, data in gameManager.playerMap do
			if not data.eliminated then
				count += 1
			end
		end
	end
	return count
end

function EliminationSystem._getEliminationQuote()
	local quotes = {
		"The Mansion shows no mercy.",
		"Another one bites the dust.",
		"The game continues without them.",
		"Goodbye is never easy... except when it is.",
		"The Mansion giveth, and the Mansion taketh away.",
		"Their story ends here. Yours continues.",
		"One less player. One step closer to the crown.",
		"In this house, nobody is safe forever.",
	}
	return quotes[math.random(1, #quotes)]
end

-- ============================================================
-- FULL ELIMINATION FLOW (called by GameManager)
-- ============================================================

function EliminationSystem.runFullElimination(nominees, results, gameManager)
	-- 1. Start ceremony (teleport everyone)
	EliminationSystem.startCeremony(gameManager)
	task.wait(5)

	-- 2. Dramatic reveal (spotlights, countdown)
	local eliminated = EliminationSystem.runDramaticReveal(nominees, results, gameManager)
	task.wait(3)

	-- 3. Process the elimination
	if eliminated then
		EliminationSystem.eliminatePlayer(eliminated.userId, gameManager)
	end

	return eliminated
end

-- ============================================================
-- UTILITIES
-- ============================================================

function EliminationSystem.isSpectator(userId)
	return EliminationSystem.spectators[userId] == true
end

function EliminationSystem.isEliminated(userId)
	return EliminationSystem.eliminatedPlayers[userId] ~= nil
end

function EliminationSystem.getEliminatedList()
	local list = {}
	for userId, data in EliminationSystem.eliminatedPlayers do
		table.insert(list, {
			userId = userId,
			name = data.name,
			week = data.week,
		})
	end
	table.sort(list, function(a, b) return a.week < b.week end)
	return list
end

function EliminationSystem.onPlayerLeave(player)
	-- If an eliminated spectator leaves, just clean up
	EliminationSystem.spectators[player.UserId] = nil
end

return EliminationSystem
]]></string>
        </Properties>
      </Item>
      <Item class="ModuleScript" referent="13">
        <Properties>
          <string name="Name">FightSystem</string>
          <string name="Source"><![CDATA[-- ============================================================
-- FIGHT SYSTEM — Proximity-triggered altercations in the Mansion
-- Detects fights, tracks intensity, dispatches security, awards XP
-- ============================================================

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")

local SupabaseAPI = require(script.Parent.SupabaseAPI)
local Config = require(ReplicatedStorage.Shared.Config)

local FightSystem = {}

-- State
FightSystem.activeFights = {} -- { [fightId] = fightData }
FightSystem.fightCooldowns = {} -- { [sortedPlayerKey] = cooldownEndTime }
FightSystem.playerProximity = {} -- { [sortedPlayerKey] = { startTime, distance } }
FightSystem.fightIdCounter = 0
FightSystem._heartbeatConnection = nil

-- Config
local PROXIMITY_TRIGGER_DISTANCE = 5 -- studs
local PROXIMITY_TRIGGER_DURATION = 3 -- seconds of close proximity to trigger
local FIGHT_COOLDOWN = 120 -- seconds between fights for same pair
local SECURITY_DISPATCH_THRESHOLD = 7 -- intensity threshold
local SECURITY_BREAKUP_DELAY = 10 -- seconds before security arrives
local FIGHT_AUTO_RESOLVE_TIME = 30 -- seconds before auto-resolve
local XP_WINNER = 25
local XP_LOSER = -10
local XP_INSTIGATOR_PENALTY = -15
local DRAMA_PER_INTENSITY = 5

-- Fight locations
local MANSION_ROOMS = {
	"Lobby", "Living Room", "Kitchen", "Drama Room",
	"Confession Booth", "Rooftop", "Corridor", "Bedroom",
}

-- ============================================================
-- INITIALIZATION
-- ============================================================

function FightSystem.init()
	-- Start proximity detection loop
	FightSystem._heartbeatConnection = RunService.Heartbeat:Connect(function()
		FightSystem._checkProximity()
	end)

	print("[FightSystem] Initialized — proximity detection active")
end

-- ============================================================
-- PROXIMITY DETECTION
-- ============================================================

function FightSystem._checkProximity()
	local players = Players:GetPlayers()
	local now = os.clock()

	for i = 1, #players do
		for j = i + 1, #players do
			local p1 = players[i]
			local p2 = players[j]

			if not p1.Character or not p2.Character then continue end
			local hrp1 = p1.Character:FindFirstChild("HumanoidRootPart")
			local hrp2 = p2.Character:FindFirstChild("HumanoidRootPart")
			if not hrp1 or not hrp2 then continue end

			local distance = (hrp1.Position - hrp2.Position).Magnitude
			local key = FightSystem._pairKey(p1.UserId, p2.UserId)

			if distance <= PROXIMITY_TRIGGER_DISTANCE then
				-- Players are close
				if not FightSystem.playerProximity[key] then
					FightSystem.playerProximity[key] = {
						startTime = now,
						player1 = p1,
						player2 = p2,
					}
				else
					local elapsed = now - FightSystem.playerProximity[key].startTime
					if elapsed >= PROXIMITY_TRIGGER_DURATION then
						-- Check cooldown
						if not FightSystem.fightCooldowns[key] or FightSystem.fightCooldowns[key] < now then
							-- Proximity trigger met — offer fight interaction
							FightSystem._offerFightInteraction(p1, p2, key)
							FightSystem.playerProximity[key] = nil -- reset
						end
					end
				end
			else
				-- Players moved apart
				FightSystem.playerProximity[key] = nil
			end
		end
	end
end

function FightSystem._pairKey(id1, id2)
	if id1 < id2 then
		return id1 .. "_" .. id2
	else
		return id2 .. "_" .. id1
	end
end

function FightSystem._offerFightInteraction(player1, player2, pairKey)
	-- Send fight prompt to both players
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("FightPrompt")
	if remote then
		remote:FireClient(player1, {
			targetUserId = player2.UserId,
			targetName = player2.DisplayName or player2.Name,
		})
		remote:FireClient(player2, {
			targetUserId = player1.UserId,
			targetName = player1.DisplayName or player1.Name,
		})
	end
end

-- ============================================================
-- FIGHT INITIATION (called by client interaction)
-- ============================================================

function FightSystem.startFight(aggressor, defenderUserId, reason, gameManager)
	if not aggressor then return nil end

	local defender = Players:GetPlayerByUserId(defenderUserId)
	if not defender then return nil end

	local pairKey = FightSystem._pairKey(aggressor.UserId, defenderUserId)

	-- Check cooldown
	local now = os.clock()
	if FightSystem.fightCooldowns[pairKey] and FightSystem.fightCooldowns[pairKey] > now then
		return nil
	end

	-- Determine intensity based on player history
	local intensity = FightSystem._calculateIntensity(aggressor.UserId, defenderUserId, gameManager)

	-- Generate fight ID
	FightSystem.fightIdCounter += 1
	local fightId = "fight_" .. FightSystem.fightIdCounter .. "_" .. os.time()

	-- Determine location based on character position
	local location = FightSystem._detectLocation(aggressor)

	-- Create fight record
	local fight = {
		id = fightId,
		aggressorId = aggressor.UserId,
		aggressorName = aggressor.DisplayName or aggressor.Name,
		defenderId = defenderUserId,
		defenderName = defender.DisplayName or defender.Name,
		intensity = intensity,
		location = location,
		reason = reason or "Tensions boiled over",
		status = "active",
		startTime = os.clock(),
		dramaPoints = intensity * DRAMA_PER_INTENSITY,
		securityDispatched = false,
	}

	FightSystem.activeFights[fightId] = fight

	-- Set cooldown
	FightSystem.fightCooldowns[pairKey] = os.clock() + FIGHT_COOLDOWN

	print("[FightSystem] FIGHT STARTED:", fight.aggressorName, "vs", fight.defenderName, "— Intensity:", intensity, "at", location)

	-- Broadcast fight alert to all players
	FightSystem._broadcastFightAlert(fight, gameManager)

	-- Auto-dispatch security at high intensity
	if intensity >= SECURITY_DISPATCH_THRESHOLD then
		fight.securityDispatched = true
		FightSystem._dispatchSecurity(fightId, gameManager)
	end

	-- Auto-resolve timer
	task.delay(FIGHT_AUTO_RESOLVE_TIME, function()
		if FightSystem.activeFights[fightId] and FightSystem.activeFights[fightId].status == "active" then
			FightSystem.resolveFight(fightId, nil, gameManager)
		end
	end)

	-- Call Supabase
	if gameManager and gameManager.seasonData then
		local seasonId = gameManager.seasonData.season and gameManager.seasonData.season.id
		if seasonId then
			task.spawn(function()
				SupabaseAPI.startFight(
					seasonId,
					tostring(aggressor.UserId),
					tostring(defenderUserId),
					location,
					reason or "Tensions boiled over",
					intensity
				)
			end)
		end
	end

	return fight
end

function FightSystem._calculateIntensity(aggressorId, defenderId, gameManager)
	local base = math.random(3, 6)

	-- Check if they are in same alliance (betrayal = higher intensity)
	if gameManager and gameManager.allianceSystem then
		local sameAlliance = gameManager.allianceSystem.areAllied(aggressorId, defenderId)
		if sameAlliance then
			base += 2 -- betrayal makes fights more intense
		end
	end

	-- Check fight history between pair
	local pairKey = FightSystem._pairKey(aggressorId, defenderId)
	local previousFights = 0
	for _, fight in FightSystem.activeFights do
		if fight.status == "resolved" then
			local fk = FightSystem._pairKey(fight.aggressorId, fight.defenderId)
			if fk == pairKey then
				previousFights += 1
			end
		end
	end
	base += math.min(previousFights, 3) -- recurring fights escalate

	return math.min(math.max(base, 1), 10)
end

function FightSystem._detectLocation(player)
	if not player.Character then return "Unknown" end
	local hrp = player.Character:FindFirstChild("HumanoidRootPart")
	if not hrp then return "Unknown" end

	local pos = hrp.Position

	-- Check position against known room coordinates
	if pos.Y > 35 then return "Rooftop" end
	if pos.Y > 18 then return "Bedrooms" end

	if pos.X < 40 then return "Lobby" end
	if pos.X >= 40 and pos.X < 70 and pos.Z > 10 then return "Living Room" end
	if pos.X >= 80 and pos.X < 110 and pos.Z > 10 then return "Kitchen" end
	if pos.X >= 40 and pos.X < 70 and pos.Z < -10 then return "Drama Room" end
	if pos.X >= 80 and pos.X < 110 and pos.Z < -10 then return "Confession Booth" end
	if pos.X >= 120 and pos.Z < -5 then return "Elimination Room" end

	return "Corridor"
end

-- ============================================================
-- FIGHT ALERTS
-- ============================================================

function FightSystem._broadcastFightAlert(fight, gameManager)
	-- Director announcement
	if gameManager then
		local intensityWord = fight.intensity >= 7 and "MAJOR" or (fight.intensity >= 4 and "heated" or "minor")
		gameManager.directorAnnounce(
			"FIGHT ALERT: A " .. intensityWord .. " altercation between " ..
			fight.aggressorName .. " and " .. fight.defenderName ..
			" in the " .. fight.location .. "! Intensity: " .. fight.intensity .. "/10"
		)
	end

	-- Send alert to all clients
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("FightAlert")
	if remote then
		remote:FireAllClients({
			fightId = fight.id,
			aggressor = fight.aggressorName,
			defender = fight.defenderName,
			intensity = fight.intensity,
			location = fight.location,
			securityDispatched = fight.securityDispatched,
			message = fight.securityDispatched and "SECURITY HAS BEEN DISPATCHED!" or "The cameras are rolling...",
		})
	end
end

-- ============================================================
-- SECURITY DISPATCH
-- ============================================================

function FightSystem._dispatchSecurity(fightId, gameManager)
	print("[FightSystem] SECURITY DISPATCHED for fight:", fightId)

	if gameManager then
		task.wait(2)
		gameManager.directorAnnounce("SECURITY TO THE " .. string.upper(FightSystem.activeFights[fightId].location) .. "! BREAK IT UP!")
	end

	-- Security NPC behavior: after delay, break up the fight
	task.delay(SECURITY_BREAKUP_DELAY, function()
		local fight = FightSystem.activeFights[fightId]
		if fight and fight.status == "active" then
			FightSystem.breakupFight(fightId, gameManager)
		end
	end)
end

function FightSystem.breakupFight(fightId, gameManager)
	local fight = FightSystem.activeFights[fightId]
	if not fight or fight.status ~= "active" then return end

	fight.status = "broken_up"
	print("[FightSystem] Fight broken up by security:", fight.aggressorName, "vs", fight.defenderName)

	if gameManager then
		gameManager.directorAnnounce("Security has separated " .. fight.aggressorName .. " and " .. fight.defenderName .. ". Everyone cool off.")
	end

	-- Separate the players physically
	local aggressor = Players:GetPlayerByUserId(fight.aggressorId)
	local defender = Players:GetPlayerByUserId(fight.defenderId)

	if aggressor and aggressor.Character then
		local hrp = aggressor.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(hrp.Position + Vector3.new(15, 0, 0))
		end
	end

	if defender and defender.Character then
		local hrp = defender.Character:FindFirstChild("HumanoidRootPart")
		if hrp then
			hrp.CFrame = CFrame.new(hrp.Position + Vector3.new(-15, 0, 0))
		end
	end

	-- Then resolve
	task.delay(3, function()
		FightSystem.resolveFight(fightId, nil, gameManager)
	end)
end

-- ============================================================
-- FIGHT RESOLUTION
-- ============================================================

function FightSystem.resolveFight(fightId, winnerId, gameManager)
	local fight = FightSystem.activeFights[fightId]
	if not fight then return end
	if fight.status == "resolved" then return end

	fight.status = "resolved"

	-- Determine winner if not specified (random based on intensity)
	if not winnerId then
		-- Higher intensity = aggressor more likely to "lose" (impulsive)
		local aggressorWinChance = 0.5 - (fight.intensity * 0.03)
		if math.random() < aggressorWinChance then
			winnerId = fight.aggressorId
		else
			winnerId = fight.defenderId
		end
	end

	local loserId = winnerId == fight.aggressorId and fight.defenderId or fight.aggressorId
	local winnerName = winnerId == fight.aggressorId and fight.aggressorName or fight.defenderName
	local loserName = loserId == fight.aggressorId and fight.aggressorName or fight.defenderName

	print("[FightSystem] Fight resolved:", winnerName, "wins over", loserName)

	-- XP rewards/penalties
	FightSystem._applyXP(fight, winnerId, loserId, gameManager)

	-- Notify clients
	local remote = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("FightResolved")
	if remote then
		remote:FireAllClients({
			fightId = fightId,
			winner = winnerName,
			loser = loserName,
			intensity = fight.intensity,
			dramaPoints = fight.dramaPoints,
		})
	end

	-- Consequences announcement
	if gameManager and fight.intensity >= 8 then
		task.wait(2)
		gameManager.directorAnnounce(fight.aggressorName .. " receives an EXILE WARNING for starting a high-intensity fight.")
	end

	return {
		winner = winnerId,
		loser = loserId,
		intensity = fight.intensity,
		dramaPoints = fight.dramaPoints,
	}
end

function FightSystem._applyXP(fight, winnerId, loserId, gameManager)
	if not gameManager then return end

	-- Winner XP
	local winnerData = gameManager.playerMap[winnerId]
	if winnerData then
		winnerData.xp = (winnerData.xp or 0) + XP_WINNER
	end

	-- Loser XP
	local loserData = gameManager.playerMap[loserId]
	if loserData then
		loserData.xp = math.max(0, (loserData.xp or 0) + XP_LOSER)
	end

	-- Instigator penalty (always applies to aggressor)
	local aggressorData = gameManager.playerMap[fight.aggressorId]
	if aggressorData then
		aggressorData.xp = math.max(0, (aggressorData.xp or 0) + XP_INSTIGATOR_PENALTY)
	end

	-- Track fight stats
	if winnerData then winnerData.fightsWon = (winnerData.fightsWon or 0) + 1 end
	if loserData then loserData.fightsLost = (loserData.fightsLost or 0) + 1 end
end

-- ============================================================
-- UTILITIES
-- ============================================================

function FightSystem.getActiveFights()
	local list = {}
	for _, fight in FightSystem.activeFights do
		if fight.status == "active" then
			table.insert(list, fight)
		end
	end
	return list
end

function FightSystem.onPlayerLeave(player)
	-- Resolve any active fights involving this player
	for fightId, fight in FightSystem.activeFights do
		if fight.status == "active" then
			if fight.aggressorId == player.UserId or fight.defenderId == player.UserId then
				fight.status = "resolved"
				print("[FightSystem] Fight auto-resolved — player left:", player.Name)
			end
		end
	end

	-- Clean up proximity tracking
	for key, data in FightSystem.playerProximity do
		if data.player1 == player or data.player2 == player then
			FightSystem.playerProximity[key] = nil
		end
	end
end

function FightSystem.shutdown()
	if FightSystem._heartbeatConnection then
		FightSystem._heartbeatConnection:Disconnect()
		FightSystem._heartbeatConnection = nil
	end
end

return FightSystem
]]></string>
