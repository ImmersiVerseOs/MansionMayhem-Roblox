function MainUI.updateLeaderboard(data)
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end
	local panel = sg:FindFirstChild("LeaderboardPanel")
	if not panel then return end

	local list = panel.PlayerList
	for _, child in list:GetChildren() do
		if child:IsA("Frame") then child:Destroy() end
	end

	local leaderboard = data.leaderboard or {}
	for i, entry in leaderboard do
		local row = Instance.new("Frame")
		row.Name = "Rank_" .. i
		row.Size = UDim2.new(1, 0, 0, 32)
		row.BackgroundColor3 = i <= 3 and Config.Colors.Card or Config.Colors.Surface
		row.BorderSizePixel = 0
		row.LayoutOrder = i
		row.Parent = list
		createCorner(row, 4)

		-- Rank colors
		local rankColors = { Config.Colors.Gold, Color3.fromHex("#C0C0C0"), Color3.fromHex("#CD7F32") }
		local rankColor = rankColors[i] or Config.Colors.TextMuted

		local rankLabel = Instance.new("TextLabel")
		rankLabel.Size = UDim2.new(0, 25, 1, 0)
		rankLabel.Position = UDim2.new(0, 4, 0, 0)
		rankLabel.BackgroundTransparency = 1
		rankLabel.Text = "#" .. i
		rankLabel.TextColor3 = rankColor
		rankLabel.TextSize = 11
		rankLabel.Font = Enum.Font.GothamBold
		rankLabel.Parent = row

		local nameLabel = Instance.new("TextLabel")
		nameLabel.Size = UDim2.new(0.5, 0, 1, 0)
		nameLabel.Position = UDim2.new(0, 32, 0, 0)
		nameLabel.BackgroundTransparency = 1
		nameLabel.Text = entry.name or entry.display_name or "Unknown"
		nameLabel.TextColor3 = (entry.eliminated) and Config.Colors.TextMuted or Config.Colors.Text
		nameLabel.TextSize = 11
		nameLabel.Font = Enum.Font.GothamBold
		nameLabel.TextXAlignment = Enum.TextXAlignment.Left
		nameLabel.Parent = row

		local xpLabel = Instance.new("TextLabel")
		xpLabel.Size = UDim2.new(0.25, -8, 1, 0)
		xpLabel.Position = UDim2.new(0.75, 0, 0, 0)
		xpLabel.BackgroundTransparency = 1
		xpLabel.Text = tostring(entry.xp or 0) .. " XP"
		xpLabel.TextColor3 = Config.Colors.Gold
		xpLabel.TextSize = 10
		xpLabel.Font = Enum.Font.GothamBold
		xpLabel.TextXAlignment = Enum.TextXAlignment.Right
		xpLabel.Parent = row
	end

	list.CanvasSize = UDim2.new(0, 0, 0, #leaderboard * 36)
end

-- ============================================================
-- QUEEN CROWN NOTIFICATION
-- ============================================================

function MainUI.showQueenCrowned(data)
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	SoundSystem.play("queen_crowning")
	SoundSystem.playMusic("celebration")

	MainUI.showDirectorAnnouncement(
		"ALL HAIL THE QUEEN: " .. (data.queenName or "???") ..
		" | Week " .. tostring(data.weekNumber or "?")
	)

	-- Return to ambient music after celebration
	task.delay(15, function()
		SoundSystem.playMusic("mansion_ambient")
	end)
end

-- ============================================================
-- EVENT LISTENERS
-- ============================================================

function MainUI.listenForEvents()
	local remotes = ReplicatedStorage:WaitForChild("Remotes")

	-- Season update
	remotes:WaitForChild("SeasonUpdate").OnClientEvent:Connect(function(data)
		if data and data.season then
			local sg = playerGui:FindFirstChild("MansionUI")
			if not sg then return end
			local hud = sg:FindFirstChild("HUD")
			if hud then
				hud.SeasonTitle.Text = data.season.title or "MANSION OF MAYHEM"
				if data.day then
					hud.PhaseLabel.Text = string.upper(data.day.day_type:gsub("_", " "))
				end
			end
		end
	end)

	-- Tea wall
	remotes:WaitForChild("TeaWallUpdate").OnClientEvent:Connect(function(confessions)
		MainUI.updateTeaWall(confessions)
	end)

	-- Director announcements
	remotes:WaitForChild("DirectorAnnounce").OnClientEvent:Connect(function(message)
		MainUI.showDirectorAnnouncement(message)
	end)

	-- Check-in result
	remotes:WaitForChild("CheckInResult").OnClientEvent:Connect(function(result)
		MainUI.showCheckInResult(result)
	end)

	-- Event update
	remotes:WaitForChild("EventUpdate").OnClientEvent:Connect(function(events)
		-- Could show events list UI here
	end)

	-- Phase update
	remotes:WaitForChild("PhaseUpdate").OnClientEvent:Connect(function(data)
		local sg = playerGui:FindFirstChild("MansionUI")
		if not sg then return end
		local hud = sg:FindFirstChild("HUD")
		if hud then
			hud.PhaseLabel.Text = string.upper((data.phase or ""):gsub("_", " "))
		end
	end)

	-- Voting
	remotes:WaitForChild("VoteStart").OnClientEvent:Connect(function(data)
		MainUI.showVotingScreen(data)
	end)

	remotes:WaitForChild("VoteEnd").OnClientEvent:Connect(function(data)
		MainUI.showVoteResults(data)
	end)

	remotes:WaitForChild("VoteConfirm").OnClientEvent:Connect(function(data)
		MainUI.showVoteConfirm(data)
	end)

	-- Nomination
	remotes:WaitForChild("NominationStart").OnClientEvent:Connect(function(data)
		-- Show nomination screen (reuse voting screen with different title)
		data.nominees = {}
		for _, p in data.eligible or {} do
			table.insert(data.nominees, p)
		end

		local sg = playerGui:FindFirstChild("MansionUI")
		if not sg then return end
		local panel = sg.VotingScreen
		panel.VoteTitle.Text = "NOMINATE FOR ELIMINATION"
		panel.VoteStatus.Text = "Select a player to nominate"
		panel.Visible = true

		local list = panel.NomineeList
		for _, child in list:GetChildren() do
			if child:IsA("Frame") then child:Destroy() end
		end

		for i, nominee in data.eligible or {} do
			local card = Instance.new("Frame")
			card.Size = UDim2.new(1, 0, 0, 40)
			card.BackgroundColor3 = Config.Colors.Card
			card.BorderSizePixel = 0
			card.LayoutOrder = i
			card.Parent = list
			createCorner(card, 6)

			local nameLabel = Instance.new("TextLabel")
			nameLabel.Size = UDim2.new(0.6, 0, 1, 0)
			nameLabel.Position = UDim2.new(0, 12, 0, 0)
			nameLabel.BackgroundTransparency = 1
			nameLabel.Text = nominee.name
			nameLabel.TextColor3 = Config.Colors.Text
			nameLabel.TextSize = 12
			nameLabel.Font = Enum.Font.GothamBold
			nameLabel.TextXAlignment = Enum.TextXAlignment.Left
			nameLabel.Parent = card

			local nomBtn = Instance.new("TextButton")
			nomBtn.Size = UDim2.new(0, 80, 0, 28)
			nomBtn.Position = UDim2.new(1, -90, 0.5, -14)
			nomBtn.BackgroundColor3 = Config.Colors.Red
			nomBtn.Text = "NOMINATE"
			nomBtn.TextColor3 = Color3.new(1, 1, 1)
			nomBtn.TextSize = 10
			nomBtn.Font = Enum.Font.GothamBold
			nomBtn.Parent = card
			createCorner(nomBtn, 6)

			nomBtn.MouseButton1Click:Connect(function()
				SoundSystem.play("vote_cast")
				local rems = ReplicatedStorage:FindFirstChild("Remotes")
				if rems then
					local r = rems:FindFirstChild("SubmitNomination")
					if r then r:FireServer(nominee.userId) end
				end
				nomBtn.Text = "DONE"
				nomBtn.BackgroundColor3 = Config.Colors.TextMuted
			end)
		end

		list.CanvasSize = UDim2.new(0, 0, 0, #(data.eligible or {}) * 46)

		-- Timer
		if data.duration then
			task.spawn(function()
				local remaining = data.duration
				while remaining > 0 and panel.Visible do
					panel.VoteTimer.Text = remaining .. "s — Nomination phase"
					task.wait(1)
					remaining -= 1
				end
			end)
		end
	end)

	-- Elimination
	remotes:WaitForChild("EliminationStart").OnClientEvent:Connect(function(data)
		MainUI.handleEliminationStart(data)
	end)

	remotes:WaitForChild("EliminationReveal").OnClientEvent:Connect(function(data)
		MainUI.handleEliminationReveal(data)
	end)

	remotes:WaitForChild("EliminationComplete").OnClientEvent:Connect(function(data)
		MainUI.handleEliminationComplete(data)
	end)

	remotes:WaitForChild("SpectatorMode").OnClientEvent:Connect(function(data)
		MainUI.handleSpectatorMode(data)
	end)

	-- Fight
	remotes:WaitForChild("FightAlert").OnClientEvent:Connect(function(data)
		MainUI.showFightAlert(data)
	end)

	remotes:WaitForChild("FightResolved").OnClientEvent:Connect(function(data)
		MainUI.showFightResolved(data)
	end)

	-- Alliance
	remotes:WaitForChild("AllianceInvite").OnClientEvent:Connect(function(data)
		MainUI.showAllianceInvite(data)
	end)

	remotes:WaitForChild("AllianceUpdate").OnClientEvent:Connect(function(data)
		MainUI.updateAlliancePanel(data)
	end)

	-- Queen
	remotes:WaitForChild("QueenCrowned").OnClientEvent:Connect(function(data)
		MainUI.showQueenCrowned(data)
	end)

	-- Challenges
	remotes:WaitForChild("ChallengeList").OnClientEvent:Connect(function(data)
		MainUI.updateChallengeList(data)
	end)

	remotes:WaitForChild("ChallengeUpdate").OnClientEvent:Connect(function(data)
		MainUI.handleChallengeUpdate(data)
	end)

	remotes:WaitForChild("GroupGoalUpdate").OnClientEvent:Connect(function(data)
		MainUI.handleGroupGoalUpdate(data)
	end)

	-- Immunity
	remotes:WaitForChild("ImmunityUpdate").OnClientEvent:Connect(function(data)
		if data.type == "shard_update" or data.type == "full_sync" or data.type == "token_used" or data.type == "token_earned" then
			MainUI.updateImmunityHUD(data.shards, data.tokens)
		end
		if data.type == "token_used" then
			SoundSystem.play("immunity_use")
		end
		if data.message then
			MainUI.showDirectorAnnouncement(data.message)
		end
	end)

	remotes:WaitForChild("ImmunityAnnounce").OnClientEvent:Connect(function(data)
		if data.immune then
			SoundSystem.play("immunity_use")
			MainUI.showDirectorAnnouncement((data.name or "Someone") .. " is IMMUNE this round!")
		end
	end)

	-- Season info response
	remotes:WaitForChild("SeasonInfoResponse").OnClientEvent:Connect(function(data)
		MainUI.updateSeasonInfo(data)
	end)

	-- Leaderboard
	remotes:WaitForChild("LeaderboardUpdate").OnClientEvent:Connect(function(data)
		MainUI.updateLeaderboard(data)
	end)

	-- Particle Effects
	remotes:WaitForChild("PlayEffect").OnClientEvent:Connect(function(data)
		if not MainUI._particleEffects then return end
		local fx = MainUI._particleEffects

		if data.effect == "confetti" then
			fx.confetti(data.position, data.duration)

		elseif data.effect == "smoke" then
			fx.smoke(data.position, data.duration)

		elseif data.effect == "fireSparks" then
			fx.fireSparks(data.position, data.continuous)

		elseif data.effect == "shieldGlow" then
			local targetPlayer = Players:GetPlayerByUserId(data.targetUserId or 0)
			if targetPlayer and targetPlayer.Character then
				fx.shieldGlow(targetPlayer.Character, data.enable)
			end

		elseif data.effect == "spotlightSweep" then
			fx.spotlightSweep(data.position, data.duration)

		elseif data.effect == "crownSparkle" then
			local targetPlayer = Players:GetPlayerByUserId(data.targetUserId or 0)
			if targetPlayer and targetPlayer.Character then
				fx.crownSparkle(targetPlayer.Character, data.enable)
			end
		end
	end)

	-- Cinematic Camera Control
	remotes:WaitForChild("CameraControl").OnClientEvent:Connect(function(data)
		if not MainUI._cinematicCamera then return end
		local cam = MainUI._cinematicCamera

		if data.action == "lockCamera" then
			cam.lockCamera()

		elseif data.action == "unlockCamera" then
			cam.unlockCamera()

		elseif data.action == "panTo" then
			cam.panTo(data.targetPosition, data.duration)

		elseif data.action == "zoomOnPlayer" then
			cam.zoomOnPlayer(data.targetUserId, data.distance, data.duration)

		elseif data.action == "orbitAround" then
			cam.orbitAround(data.center, data.radius, data.duration, data.height)

		elseif data.action == "dramaticReveal" then
			cam.dramaticReveal(data.targetPosition)
		end
	end)

	-- Bus system events
	MainUI._listenBusEvents()
end

-- ============================================================
-- BUS UI — Countdown, Cinematic, Arrival
-- ============================================================

function MainUI.createBusUI(parent)
	-- Bus countdown timer (big text on screen)
	local countdownFrame = Instance.new("Frame")
	countdownFrame.Name = "BusCountdown"
	countdownFrame.Size = UDim2.new(0, 300, 0, 80)
	countdownFrame.Position = UDim2.new(0.5, -150, 0, 20)
	countdownFrame.BackgroundColor3 = Color3.fromHex("#0A0610")
	countdownFrame.BackgroundTransparency = 0.3
	countdownFrame.BorderSizePixel = 0
	countdownFrame.Visible = false
	countdownFrame.ZIndex = 20
	countdownFrame.Parent = parent
	createCorner(countdownFrame, 12)
	createStroke(countdownFrame, Color3.fromHex("#FFD700"), 2)

	local countdownTitle = Instance.new("TextLabel")
	countdownTitle.Name = "Title"
	countdownTitle.Size = UDim2.new(1, 0, 0.4, 0)
	countdownTitle.BackgroundTransparency = 1
	countdownTitle.Text = "BUS DEPARTING IN"
	countdownTitle.TextColor3 = Color3.fromHex("#FFD700")
	countdownTitle.TextSize = math.floor(14 * BASE_TEXT_SCALE)
	countdownTitle.Font = Enum.Font.GothamBold
	countdownTitle.Parent = countdownFrame

	local countdownTime = Instance.new("TextLabel")
	countdownTime.Name = "TimeLabel"
	countdownTime.Size = UDim2.new(1, 0, 0.6, 0)
	countdownTime.Position = UDim2.new(0, 0, 0.4, 0)
	countdownTime.BackgroundTransparency = 1
	countdownTime.Text = "1:00"
	countdownTime.TextColor3 = Color3.new(1, 1, 1)
	countdownTime.TextSize = math.floor(32 * BASE_TEXT_SCALE)
	countdownTime.Font = Enum.Font.GothamBold
	countdownTime.Parent = countdownFrame

	-- Cinematic overlay (letterbox + text)
	local cinematicFrame = Instance.new("Frame")
	cinematicFrame.Name = "BusCinematic"
	cinematicFrame.Size = UDim2.new(1, 0, 1, 0)
	cinematicFrame.BackgroundTransparency = 1
	cinematicFrame.Visible = false
	cinematicFrame.ZIndex = 50
	cinematicFrame.Parent = parent

	-- Top letterbox bar
	local topBar = Instance.new("Frame")
	topBar.Name = "TopBar"
	topBar.Size = UDim2.new(1, 0, 0.12, 0)
	topBar.Position = UDim2.new(0, 0, 0, 0)
	topBar.BackgroundColor3 = Color3.new(0, 0, 0)
	topBar.BorderSizePixel = 0
	topBar.ZIndex = 51
	topBar.Parent = cinematicFrame

	-- Bottom letterbox bar
	local bottomBar = Instance.new("Frame")
	bottomBar.Name = "BottomBar"
	bottomBar.Size = UDim2.new(1, 0, 0.12, 0)
	bottomBar.Position = UDim2.new(0, 0, 0.88, 0)
	bottomBar.BackgroundColor3 = Color3.new(0, 0, 0)
	bottomBar.BorderSizePixel = 0
	bottomBar.ZIndex = 51
	bottomBar.Parent = cinematicFrame

	-- Dark background overlay
	local darkOverlay = Instance.new("Frame")
	darkOverlay.Name = "DarkOverlay"
	darkOverlay.Size = UDim2.new(1, 0, 0.76, 0)
	darkOverlay.Position = UDim2.new(0, 0, 0.12, 0)
	darkOverlay.BackgroundColor3 = Color3.new(0, 0, 0)
	darkOverlay.BackgroundTransparency = 0.3
	darkOverlay.BorderSizePixel = 0
	darkOverlay.ZIndex = 50
	darkOverlay.Parent = cinematicFrame

	-- Center text
	local cinematicText = Instance.new("TextLabel")
	cinematicText.Name = "CinematicText"
	cinematicText.Size = UDim2.new(0.8, 0, 0.15, 0)
	cinematicText.Position = UDim2.new(0.1, 0, 0.42, 0)
	cinematicText.BackgroundTransparency = 1
	cinematicText.Text = "EN ROUTE TO THE MANSION..."
	cinematicText.TextColor3 = Color3.fromHex("#FFD700")
	cinematicText.TextSize = math.floor(28 * BASE_TEXT_SCALE)
	cinematicText.Font = Enum.Font.GothamBold
	cinematicText.ZIndex = 52
	cinematicText.Parent = cinematicFrame

	-- Loading dots
	local dotsLabel = Instance.new("TextLabel")
	dotsLabel.Name = "DotsLabel"
	dotsLabel.Size = UDim2.new(0.5, 0, 0.08, 0)
	dotsLabel.Position = UDim2.new(0.25, 0, 0.58, 0)
	dotsLabel.BackgroundTransparency = 1
	dotsLabel.Text = "..."
	dotsLabel.TextColor3 = Color3.fromHex("#E8A0BF")
	dotsLabel.TextSize = math.floor(24 * BASE_TEXT_SCALE)
	dotsLabel.Font = Enum.Font.GothamBold
	dotsLabel.ZIndex = 52
	dotsLabel.Parent = cinematicFrame

	-- Arrival overlay
	local arriveFrame = Instance.new("Frame")
	arriveFrame.Name = "BusArrival"
	arriveFrame.Size = UDim2.new(1, 0, 1, 0)
	arriveFrame.BackgroundColor3 = Color3.new(0, 0, 0)
	arriveFrame.BackgroundTransparency = 0.5
	arriveFrame.Visible = false
	arriveFrame.ZIndex = 50
	arriveFrame.Parent = parent

	local arriveText = Instance.new("TextLabel")
	arriveText.Name = "ArriveText"
	arriveText.Size = UDim2.new(0.8, 0, 0.15, 0)
	arriveText.Position = UDim2.new(0.1, 0, 0.42, 0)
	arriveText.BackgroundTransparency = 1
	arriveText.Text = "WELCOME TO THE MANSION OF MAYHEM"
	arriveText.TextColor3 = Color3.fromHex("#FFD700")
	arriveText.TextSize = math.floor(32 * BASE_TEXT_SCALE)
	arriveText.Font = Enum.Font.GothamBold
	arriveText.ZIndex = 51
	arriveText.Parent = arriveFrame
end

function MainUI._listenBusEvents()
	local remotes = ReplicatedStorage:WaitForChild("Remotes")
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	-- Bus countdown
	local countdownEvent = remotes:FindFirstChild("BusCountdown")
	if countdownEvent then
		countdownEvent.OnClientEvent:Connect(function(data)
			local countdownFrame = sg:FindFirstChild("BusCountdown")
			if not countdownFrame then return end

			if data.timeRemaining and data.timeRemaining > 0 then
				countdownFrame.Visible = true
				local timeLabel = countdownFrame:FindFirstChild("TimeLabel")
				if timeLabel then
					timeLabel.Text = data.timeStr or tostring(data.timeRemaining)
				end
			else
				countdownFrame.Visible = false
			end
		end)
	end

	-- Bus cinematic
	local cinematicEvent = remotes:FindFirstChild("BusCinematic")
	if cinematicEvent then
		cinematicEvent.OnClientEvent:Connect(function(data)
			local cinematicFrame = sg:FindFirstChild("BusCinematic")
			if not cinematicFrame then return end

			if data.action == "start" then
				cinematicFrame.Visible = true
				-- Hide countdown
				local countdownFrame = sg:FindFirstChild("BusCountdown")
				if countdownFrame then countdownFrame.Visible = false end

				-- Update text if provided
				local textLabel = cinematicFrame:FindFirstChild("CinematicText")
				if textLabel and data.text then
					textLabel.Text = data.text
				end

				-- Animate loading dots
				task.spawn(function()
					local dotsLabel = cinematicFrame:FindFirstChild("DotsLabel")
					if dotsLabel then
						local dots = {".", "..", "...", "....", "....."}
						local idx = 1
						while cinematicFrame.Visible do
							dotsLabel.Text = dots[idx]
							idx = (idx % #dots) + 1
							task.wait(0.5)
						end
					end
				end)

			elseif data.action == "stop" then
				cinematicFrame.Visible = false
			end
		end)
	end

	-- Bus arrive
	local arriveEvent = remotes:FindFirstChild("BusArrive")
	if arriveEvent then
		arriveEvent.OnClientEvent:Connect(function(data)
			-- Hide cinematic
			local cinematicFrame = sg:FindFirstChild("BusCinematic")
			if cinematicFrame then cinematicFrame.Visible = false end

			-- Show arrival splash
			local arriveFrame = sg:FindFirstChild("BusArrival")
			if arriveFrame then
				local arriveText = arriveFrame:FindFirstChild("ArriveText")
				if arriveText and data.message then
					arriveText.Text = data.message
				end

				arriveFrame.Visible = true
				arriveFrame.BackgroundTransparency = 0

				-- Fade out after 3 seconds
				task.delay(1, function()
					TweenService:Create(arriveFrame, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
						BackgroundTransparency = 1,
					}):Play()
					if arriveText then
						TweenService:Create(arriveText, TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
							TextTransparency = 1,
						}):Play()
					end
					task.delay(2.5, function()
						arriveFrame.Visible = false
						arriveFrame.BackgroundTransparency = 0.5
						if arriveText then arriveText.TextTransparency = 0 end
					end)
				end)
			end
		end)
	end
end

return MainUI
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="28">
          <Properties>
            <string name="Name">ParticleEffects</string>
            <string name="Source"><![CDATA[-- ============================================================
-- PARTICLE EFFECTS — Client-side visual effects for Mansion Mayhem
-- Confetti, Smoke, Fire Sparks, Shield Glow, Spotlight, Crown Sparkle
-- ============================================================

local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local ParticleEffects = {}

-- Track active effects for cleanup
ParticleEffects._activeEffects = {} -- { [id] = { parts, connections } }
ParticleEffects._effectCounter = 0

-- ============================================================
-- INITIALIZATION
-- ============================================================

function ParticleEffects.init()
	-- Create a folder for effect parts
	local folder = workspace:FindFirstChild("ClientEffects")
	if not folder then
		folder = Instance.new("Folder")
		folder.Name = "ClientEffects"
		folder.Parent = workspace
	end
	ParticleEffects._folder = folder
	print("[ParticleEffects] Initialized")
end

-- ============================================================
-- HELPER: Generate unique effect ID
-- ============================================================

local function nextId()
	ParticleEffects._effectCounter += 1
	return "effect_" .. ParticleEffects._effectCounter
end

local function cleanupEffect(id, delay)
	task.delay(delay or 0, function()
		local effect = ParticleEffects._activeEffects[id]
		if not effect then return end

		-- Disconnect any RunService connections
		for _, conn in effect.connections or {} do
			if typeof(conn) == "RBXScriptConnection" then
				conn:Disconnect()
			end
		end

		-- Destroy parts
		for _, part in effect.parts or {} do
			if part and part.Parent then
				part:Destroy()
			end
		end

		ParticleEffects._activeEffects[id] = nil
	end)
end

-- ============================================================
-- CONFETTI — Colorful particles for celebrations
-- ============================================================

function ParticleEffects.confetti(position, duration)
	duration = duration or 5

	local id = nextId()
	local parts = {}
	local connections = {}

	-- Create emitter part above position
	local emitterPart = Instance.new("Part")
	emitterPart.Name = "ConfettiEmitter"
	emitterPart.Size = Vector3.new(8, 1, 8)
	emitterPart.Position = position + Vector3.new(0, 15, 0)
	emitterPart.Anchored = true
	emitterPart.CanCollide = false
	emitterPart.Transparency = 1
	emitterPart.Parent = ParticleEffects._folder
	table.insert(parts, emitterPart)

	-- Confetti colors
	local confettiColors = {
		Color3.fromHex("#FFD700"), -- Gold
		Color3.fromHex("#FF1493"), -- Pink
		Color3.fromHex("#9B30FF"), -- Purple
		Color3.fromHex("#F8F4F0"), -- White
	}

	-- Create a ParticleEmitter for each color
	for _, color in confettiColors do
		local emitter = Instance.new("ParticleEmitter")
		emitter.Color = ColorSequence.new(color)
		emitter.Size = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.3),
			NumberSequenceKeypoint.new(0.5, 0.5),
			NumberSequenceKeypoint.new(1, 0.1),
		})
		emitter.Lifetime = NumberRange.new(2, 4)
		emitter.Rate = 50 / #confettiColors -- total ~50/sec
		emitter.Speed = NumberRange.new(2, 6)
		emitter.SpreadAngle = Vector2.new(180, 180)
		emitter.RotSpeed = NumberRange.new(-180, 180)
		emitter.Rotation = NumberRange.new(0, 360)
		emitter.Acceleration = Vector3.new(0, -8, 0) -- gravity-like fall
		emitter.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0),
			NumberSequenceKeypoint.new(0.8, 0),
			NumberSequenceKeypoint.new(1, 1),
		})
		emitter.LightEmission = 0.3
		emitter.Parent = emitterPart
	end

	ParticleEffects._activeEffects[id] = { parts = parts, connections = connections }

	-- Stop emitting after duration, then cleanup
	task.delay(duration, function()
		for _, child in emitterPart:GetChildren() do
			if child:IsA("ParticleEmitter") then
				child.Enabled = false
			end
		end
	end)

	cleanupEffect(id, duration + 5) -- extra time for particles to fade

	return id
end

-- ============================================================
-- SMOKE / FOG — Dark smoke rising from floor
-- ============================================================

function ParticleEffects.smoke(position, duration)
	duration = duration or 10

	local id = nextId()
	local parts = {}
	local connections = {}

	-- Create emitter at floor level
	local emitterPart = Instance.new("Part")
	emitterPart.Name = "SmokeEmitter"
	emitterPart.Size = Vector3.new(12, 1, 12)
	emitterPart.Position = position + Vector3.new(0, 0.5, 0)
	emitterPart.Anchored = true
	emitterPart.CanCollide = false
	emitterPart.Transparency = 1
	emitterPart.Parent = ParticleEffects._folder
	table.insert(parts, emitterPart)

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromHex("#1A1A1A")),
		ColorSequenceKeypoint.new(0.5, Color3.fromHex("#333333")),
		ColorSequenceKeypoint.new(1, Color3.fromHex("#555555")),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 1),
		NumberSequenceKeypoint.new(0.3, 4),
		NumberSequenceKeypoint.new(1, 8),
	})
	emitter.Lifetime = NumberRange.new(4, 7)
	emitter.Rate = 15
	emitter.Speed = NumberRange.new(1, 3)
	emitter.SpreadAngle = Vector2.new(30, 30)
	emitter.Rotation = NumberRange.new(0, 360)
	emitter.RotSpeed = NumberRange.new(-20, 20)
	emitter.Acceleration = Vector3.new(0, 2, 0) -- slow rise
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.5),
		NumberSequenceKeypoint.new(0.3, 0.3),
		NumberSequenceKeypoint.new(0.7, 0.5),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.LightEmission = 0
	emitter.LightInfluence = 0.5
	emitter.Parent = emitterPart

	ParticleEffects._activeEffects[id] = { parts = parts, connections = connections }

	-- Stop after duration
	task.delay(duration, function()
		emitter.Enabled = false
	end)

	cleanupEffect(id, duration + 8)

	return id
end

-- ============================================================
-- FIRE SPARKS — Orange/red particles rising
-- ============================================================

function ParticleEffects.fireSparks(position, continuous)
	local id = nextId()
	local parts = {}
	local connections = {}

	local emitterPart = Instance.new("Part")
	emitterPart.Name = "FireSparksEmitter"
	emitterPart.Size = Vector3.new(3, 1, 3)
	emitterPart.Position = position + Vector3.new(0, 0.5, 0)
	emitterPart.Anchored = true
	emitterPart.CanCollide = false
	emitterPart.Transparency = 1
	emitterPart.Parent = ParticleEffects._folder
	table.insert(parts, emitterPart)

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromHex("#FF4500")),
		ColorSequenceKeypoint.new(0.4, Color3.fromHex("#FF8C00")),
		ColorSequenceKeypoint.new(1, Color3.fromHex("#FFD700")),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.2),
		NumberSequenceKeypoint.new(0.3, 0.4),
		NumberSequenceKeypoint.new(1, 0.05),
	})
	emitter.Lifetime = NumberRange.new(0.5, 1.5)
	emitter.Rate = 30
	emitter.Speed = NumberRange.new(4, 10)
	emitter.SpreadAngle = Vector2.new(15, 15)
	emitter.Rotation = NumberRange.new(0, 360)
	emitter.RotSpeed = NumberRange.new(-90, 90)
	emitter.Acceleration = Vector3.new(0, 3, 0)
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0),
		NumberSequenceKeypoint.new(0.5, 0.2),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.LightEmission = 1
	emitter.Parent = emitterPart

	-- Point light for glow
	local glow = Instance.new("PointLight")
	glow.Color = Color3.fromHex("#FF6600")
	glow.Brightness = 2
	glow.Range = 12
	glow.Parent = emitterPart

	ParticleEffects._activeEffects[id] = { parts = parts, connections = connections }

	if not continuous then
		-- 3-second burst for fights
		task.delay(3, function()
			emitter.Enabled = false
			glow.Enabled = false
		end)
		cleanupEffect(id, 6)
	end

	return id
end

-- ============================================================
-- SHIELD GLOW — Blue/cyan particles orbiting player
-- ============================================================

function ParticleEffects.shieldGlow(character, enable)
	if not character then return nil end

	local rootPart = character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return nil end

	-- Cleanup existing shield effect
	local existingShield = rootPart:FindFirstChild("ShieldGlow")
	if existingShield then
		existingShield:Destroy()
	end

	if not enable then return nil end

	local id = nextId()
	local parts = {}
	local connections = {}

	-- Create orbiting attachment on root part
	local attachment = Instance.new("Attachment")
	attachment.Name = "ShieldGlow"
	attachment.Parent = rootPart

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromHex("#00BFFF")),
		ColorSequenceKeypoint.new(0.5, Color3.fromHex("#00FFFF")),
		ColorSequenceKeypoint.new(1, Color3.fromHex("#0088FF")),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.15),
		NumberSequenceKeypoint.new(0.5, 0.3),
		NumberSequenceKeypoint.new(1, 0.05),
	})
	emitter.Lifetime = NumberRange.new(0.8, 1.5)
	emitter.Rate = 25
	emitter.Speed = NumberRange.new(2, 4)
	emitter.SpreadAngle = Vector2.new(360, 360)
	emitter.Rotation = NumberRange.new(0, 360)
	emitter.RotSpeed = NumberRange.new(-60, 60)
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.3),
		NumberSequenceKeypoint.new(0.5, 0.1),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.LightEmission = 0.8
	emitter.Parent = attachment

	-- Soft blue point light
	local light = Instance.new("PointLight")
	light.Color = Color3.fromHex("#00BFFF")
	light.Brightness = 1.5
	light.Range = 10
	light.Parent = attachment

	ParticleEffects._activeEffects[id] = { parts = { attachment }, connections = connections }

	return id
end

-- ============================================================
-- SPOTLIGHT SWEEP — Sweeping light in elimination room
-- ============================================================

function ParticleEffects.spotlightSweep(position, duration)
	duration = duration or 15

	local id = nextId()
	local parts = {}
	local connections = {}

	-- Create spotlight part above the center
	local spotPart = Instance.new("Part")
	spotPart.Name = "SpotlightSweep"
	spotPart.Size = Vector3.new(1, 1, 1)
	spotPart.Position = position + Vector3.new(0, 14, 0) -- near ceiling
	spotPart.Anchored = true
	spotPart.CanCollide = false
	spotPart.Transparency = 1
	spotPart.Parent = ParticleEffects._folder
	table.insert(parts, spotPart)

	-- Create a SpotLight pointing downward
	local spotlight = Instance.new("SpotLight")
	spotlight.Color = Color3.fromHex("#F8F4F0")
	spotlight.Brightness = 5
	spotlight.Range = 30
	spotlight.Angle = 25
	spotlight.Face = Enum.NormalId.Bottom
	spotlight.Parent = spotPart

	-- Sweep the spotlight in a circle using RunService
	local startTime = os.clock()
	local radius = 6
	local sweepSpeed = 1.5 -- revolutions per cycle

	local conn = RunService.RenderStepped:Connect(function()
		local elapsed = os.clock() - startTime
		if elapsed > duration then return end

		local angle = elapsed * sweepSpeed * math.pi * 2
		local offsetX = math.cos(angle) * radius
		local offsetZ = math.sin(angle) * radius

		spotPart.CFrame = CFrame.new(
			position.X + offsetX,
			position.Y + 14,
			position.Z + offsetZ
		) * CFrame.Angles(math.rad(90 + 20), 0, 0) -- angled downward
	end)
	table.insert(connections, conn)

	ParticleEffects._activeEffects[id] = { parts = parts, connections = connections }

	cleanupEffect(id, duration + 1)

	return id
end

-- ============================================================
-- CROWN SPARKLE — Golden particles around queen's head
-- ============================================================

function ParticleEffects.crownSparkle(character, enable)
	if not character then return nil end

	local head = character:FindFirstChild("Head")
	if not head then return nil end

	-- Cleanup existing sparkle
	local existingSparkle = head:FindFirstChild("CrownSparkle")
	if existingSparkle then
		existingSparkle:Destroy()
	end

	if not enable then return nil end

	local id = nextId()
	local parts = {}
	local connections = {}

	local attachment = Instance.new("Attachment")
	attachment.Name = "CrownSparkle"
	attachment.Position = Vector3.new(0, 1.2, 0) -- above head
	attachment.Parent = head

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromHex("#FFD700")),
		ColorSequenceKeypoint.new(0.5, Color3.fromHex("#FFEC80")),
		ColorSequenceKeypoint.new(1, Color3.fromHex("#FFD700")),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.05),
		NumberSequenceKeypoint.new(0.3, 0.15),
		NumberSequenceKeypoint.new(1, 0.02),
	})
	emitter.Lifetime = NumberRange.new(0.5, 1.2)
	emitter.Rate = 12
	emitter.Speed = NumberRange.new(0.5, 2)
	emitter.SpreadAngle = Vector2.new(360, 180)
	emitter.Rotation = NumberRange.new(0, 360)
	emitter.RotSpeed = NumberRange.new(-45, 45)
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.2),
		NumberSequenceKeypoint.new(0.5, 0),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.LightEmission = 1
	emitter.Parent = attachment

	ParticleEffects._activeEffects[id] = { parts = { attachment }, connections = connections }

	return id
end

-- ============================================================
-- CLEANUP ALL
-- ============================================================

function ParticleEffects.cleanup()
	for id, _ in ParticleEffects._activeEffects do
		cleanupEffect(id, 0)
	end
end

return ParticleEffects
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="29">
          <Properties>
            <string name="Name">ShopUI</string>
            <string name="Source"><![CDATA[-- ============================================================
-- SHOP UI — In-game shop for Game Passes and Dev Products
-- Gold/premium themed UI matching mansion aesthetic
-- ============================================================

local Players = game:GetService("Players")
local MarketplaceService = game:GetService("MarketplaceService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local Config = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Config"))

local ShopUI = {}

-- ============================================================
-- ITEM DEFINITIONS (mirrors server MonetizationSystem)
-- IDs are placeholders — will match server IDs
-- ============================================================

local GAME_PASSES = {
	{
		name = "VIP",
		displayName = "VIP Pass",
		description = "Gold name tag, VIP lounge access, exclusive outfit colors",
		id = 0,
		price = "499",
		icon = "VIP",
		color = Config.Colors.Gold,
	},
	{
		name = "DoubleXP",
		displayName = "Double XP",
		description = "2x XP from all activities — level up faster",
		id = 0,
		price = "299",
		icon = "2X",
		color = Config.Colors.Purple,
	},
	{
		name = "ExtraVote",
		displayName = "Extra Vote",
		description = "Cast 2 votes during elimination instead of 1",
		id = 0,
		price = "399",
		icon = "2V",
		color = Config.Colors.Red,
	},
	{
		name = "CustomRoom",
		displayName = "Custom Room",
		description = "Decorate your bedroom with exclusive items",
		id = 0,
		price = "199",
		icon = "ROOM",
		color = Config.Colors.Blue,
	},
}

local DEV_PRODUCTS = {
	{
		name = "ImmunityToken",
		displayName = "Immunity Token",
		description = "Buy 1 immunity token to survive elimination",
		id = 0,
		price = "149",
		icon = "SHIELD",
		color = Config.Colors.Green,
	},
	{
		name = "Coins50",
		displayName = "50 Coins",
		description = "In-game currency for the Mansion",
		id = 0,
		price = "49",
		icon = "COIN",
		color = Config.Colors.Gold,
	},
	{
		name = "RoomUpgrade",
		displayName = "Room Upgrade",
		description = "Upgrade your bedroom temporarily",
		id = 0,
		price = "99",
		icon = "UP",
		color = Config.Colors.Pink,
	},
	{
		name = "ConfettiBomb",
		displayName = "Confetti Bomb",
		description = "Throw confetti on yourself (flex)",
		id = 0,
		price = "29",
		icon = "PARTY",
		color = Config.Colors.Purple,
	},
}

-- ============================================================
-- HELPERS
-- ============================================================

local function createCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius or 10)
	corner.Parent = parent
	return corner
end

local function createStroke(parent, color, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color or Config.Colors.Border
	stroke.Thickness = thickness or 1
	stroke.Parent = parent
	return stroke
end

-- ============================================================
-- CREATE SHOP PANEL
-- ============================================================

function ShopUI.createShopPanel(parent)
	local panel = Instance.new("Frame")
	panel.Name = "ShopPanel"
	panel.Size = UDim2.new(0.55, 0, 0.75, 0)
	panel.Position = UDim2.new(0.225, 0, 0.08, 0)
	panel.BackgroundColor3 = Config.Colors.Background
	panel.BackgroundTransparency = 0.03
	panel.BorderSizePixel = 0
	panel.Visible = false
	panel.ZIndex = 10
	panel.Parent = parent

	createCorner(panel, 16)
	createStroke(panel, Config.Colors.Gold, 2)

	-- Title bar
	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.Size = UDim2.new(1, 0, 0, 50)
	titleBar.BackgroundColor3 = Config.Colors.Gold
	titleBar.BackgroundTransparency = 0.3
	titleBar.BorderSizePixel = 0
	titleBar.Parent = panel
	createCorner(titleBar, 16)

	-- Cover bottom corners of title bar
	local titleBarCover = Instance.new("Frame")
	titleBarCover.Size = UDim2.new(1, 0, 0, 16)
	titleBarCover.Position = UDim2.new(0, 0, 1, -16)
	titleBarCover.BackgroundColor3 = Config.Colors.Gold
	titleBarCover.BackgroundTransparency = 0.3
	titleBarCover.BorderSizePixel = 0
	titleBarCover.Parent = titleBar

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.Size = UDim2.new(0.8, 0, 1, 0)
	titleLabel.Position = UDim2.new(0, 16, 0, 0)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text = "MANSION SHOP"
	titleLabel.TextColor3 = Config.Colors.Background
	titleLabel.TextSize = 22
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.Parent = titleBar

	-- Close button
	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseBtn"
	closeBtn.Size = UDim2.new(0, 36, 0, 36)
	closeBtn.Position = UDim2.new(1, -44, 0, 7)
	closeBtn.BackgroundColor3 = Config.Colors.Background
	closeBtn.BackgroundTransparency = 0.5
	closeBtn.Text = "X"
	closeBtn.TextColor3 = Config.Colors.Gold
	closeBtn.TextSize = 16
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Parent = titleBar
	createCorner(closeBtn, 8)

	closeBtn.MouseButton1Click:Connect(function()
		panel.Visible = false
	end)

	-- Scrolling content area
	local content = Instance.new("ScrollingFrame")
	content.Name = "Content"
	content.Size = UDim2.new(0.94, 0, 1, -60)
	content.Position = UDim2.new(0.03, 0, 0, 55)
	content.BackgroundTransparency = 1
	content.BorderSizePixel = 0
	content.ScrollBarThickness = 4
	content.ScrollBarImageColor3 = Config.Colors.Gold
	content.CanvasSize = UDim2.new(0, 0, 0, 0)
	content.Parent = panel

	local layout = Instance.new("UIListLayout")
	layout.SortOrder = Enum.SortOrder.LayoutOrder
	layout.Padding = UDim.new(0, 8)
	layout.Parent = content

	-- Section: Game Passes
	ShopUI._createSectionHeader(content, "GAME PASSES (One-Time)", 0, Config.Colors.Gold)

	for i, pass in GAME_PASSES do
		ShopUI._createShopItem(content, pass, "gamepass", i)
	end

	-- Divider
	local divider = Instance.new("Frame")
	divider.Name = "Divider"
	divider.Size = UDim2.new(0.9, 0, 0, 2)
	divider.BackgroundColor3 = Config.Colors.Border
	divider.BorderSizePixel = 0
	divider.LayoutOrder = #GAME_PASSES + 2
	divider.Parent = content
	createCorner(divider, 1)

	-- Section: Dev Products
	ShopUI._createSectionHeader(content, "ITEMS (Repeatable)", #GAME_PASSES + 3, Config.Colors.Pink)

	for i, product in DEV_PRODUCTS do
		ShopUI._createShopItem(content, product, "devproduct", #GAME_PASSES + 4 + i)
	end

	-- Update canvas size
	local totalItems = #GAME_PASSES + #DEV_PRODUCTS + 4 -- headers + divider + padding
	content.CanvasSize = UDim2.new(0, 0, 0, totalItems * 95 + 60)

	return panel
end

-- ============================================================
-- SECTION HEADER
-- ============================================================

function ShopUI._createSectionHeader(parent, text, order, color)
	local header = Instance.new("Frame")
	header.Name = "Header_" .. text
	header.Size = UDim2.new(1, 0, 0, 30)
	header.BackgroundTransparency = 1
	header.BorderSizePixel = 0
	header.LayoutOrder = order
	header.Parent = parent

	local label = Instance.new("TextLabel")
	label.Size = UDim2.new(1, 0, 1, 0)
	label.Position = UDim2.new(0, 4, 0, 0)
	label.BackgroundTransparency = 1
	label.Text = text
	label.TextColor3 = color or Config.Colors.Gold
	label.TextSize = 13
	label.Font = Enum.Font.GothamBold
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Parent = header

	-- Accent line
	local line = Instance.new("Frame")
	line.Size = UDim2.new(1, 0, 0, 1)
	line.Position = UDim2.new(0, 0, 1, -1)
	line.BackgroundColor3 = color or Config.Colors.Gold
	line.BackgroundTransparency = 0.5
	line.BorderSizePixel = 0
	line.Parent = header
end

-- ============================================================
-- SHOP ITEM CARD
-- ============================================================

function ShopUI._createShopItem(parent, itemData, itemType, order)
	local card = Instance.new("Frame")
	card.Name = "Item_" .. itemData.name
	card.Size = UDim2.new(1, 0, 0, 80)
	card.BackgroundColor3 = Config.Colors.Card
	card.BorderSizePixel = 0
	card.LayoutOrder = order
	card.Parent = parent
	createCorner(card, 10)

	-- Left accent bar
	local accent = Instance.new("Frame")
	accent.Size = UDim2.new(0, 4, 0.8, 0)
	accent.Position = UDim2.new(0, 6, 0.1, 0)
	accent.BackgroundColor3 = itemData.color or Config.Colors.Gold
	accent.BorderSizePixel = 0
	accent.Parent = card
	createCorner(accent, 2)

	-- Icon badge
	local iconFrame = Instance.new("Frame")
	iconFrame.Size = UDim2.new(0, 44, 0, 44)
	iconFrame.Position = UDim2.new(0, 18, 0.5, -22)
	iconFrame.BackgroundColor3 = itemData.color or Config.Colors.Gold
	iconFrame.BackgroundTransparency = 0.2
	iconFrame.BorderSizePixel = 0
	iconFrame.Parent = card
	createCorner(iconFrame, 8)

	local iconLabel = Instance.new("TextLabel")
	iconLabel.Size = UDim2.new(1, 0, 1, 0)
	iconLabel.BackgroundTransparency = 1
	iconLabel.Text = itemData.icon or "?"
	iconLabel.TextColor3 = Config.Colors.Background
	iconLabel.TextSize = 11
	iconLabel.Font = Enum.Font.GothamBold
	iconLabel.Parent = iconFrame

	-- Item name
	local nameLabel = Instance.new("TextLabel")
	nameLabel.Size = UDim2.new(0.5, 0, 0, 20)
	nameLabel.Position = UDim2.new(0, 72, 0, 10)
	nameLabel.BackgroundTransparency = 1
	nameLabel.Text = itemData.displayName
	nameLabel.TextColor3 = Config.Colors.Text
	nameLabel.TextSize = 14
	nameLabel.Font = Enum.Font.GothamBold
	nameLabel.TextXAlignment = Enum.TextXAlignment.Left
	nameLabel.Parent = card

	-- Description
	local descLabel = Instance.new("TextLabel")
	descLabel.Size = UDim2.new(0.55, 0, 0, 32)
	descLabel.Position = UDim2.new(0, 72, 0, 32)
	descLabel.BackgroundTransparency = 1
	descLabel.Text = itemData.description
	descLabel.TextColor3 = Config.Colors.TextMuted
	descLabel.TextSize = 10
	descLabel.Font = Enum.Font.Gotham
	descLabel.TextWrapped = true
	descLabel.TextXAlignment = Enum.TextXAlignment.Left
	descLabel.TextYAlignment = Enum.TextYAlignment.Top
	descLabel.Parent = card

	-- Buy button
	local buyBtn = Instance.new("TextButton")
	buyBtn.Name = "BuyBtn"
	buyBtn.Size = UDim2.new(0, 90, 0, 36)
	buyBtn.Position = UDim2.new(1, -100, 0.5, -18)
	buyBtn.BackgroundColor3 = Config.Colors.Gold
	buyBtn.Text = "R$ " .. itemData.price
	buyBtn.TextColor3 = Config.Colors.Background
	buyBtn.TextSize = 13
	buyBtn.Font = Enum.Font.GothamBold
	buyBtn.Parent = card
	createCorner(buyBtn, 8)

	-- Hover effect
	buyBtn.MouseEnter:Connect(function()
		TweenService:Create(buyBtn, TweenInfo.new(0.15), {
			BackgroundColor3 = Color3.fromHex("#FFE44D"),
		}):Play()
	end)
	buyBtn.MouseLeave:Connect(function()
		TweenService:Create(buyBtn, TweenInfo.new(0.15), {
			BackgroundColor3 = Config.Colors.Gold,
		}):Play()
	end)

	-- Purchase handler
	buyBtn.MouseButton1Click:Connect(function()
		if itemType == "gamepass" and itemData.id ~= 0 then
			MarketplaceService:PromptGamePassPurchase(player, itemData.id)
		elseif itemType == "devproduct" and itemData.id ~= 0 then
			MarketplaceService:PromptProductPurchase(player, itemData.id)
		else
			-- Placeholder — show message
			buyBtn.Text = "COMING SOON"
			buyBtn.BackgroundColor3 = Config.Colors.TextMuted
			task.delay(2, function()
				buyBtn.Text = "R$ " .. itemData.price
				buyBtn.BackgroundColor3 = Config.Colors.Gold
			end)
		end
	end)

	-- If game pass, check ownership and show "OWNED" status
	if itemType == "gamepass" and itemData.id ~= 0 then
		task.spawn(function()
			local success, owns = pcall(function()
				return MarketplaceService:UserOwnsGamePassAsync(player.UserId, itemData.id)
			end)
			if success and owns then
				buyBtn.Text = "OWNED"
				buyBtn.BackgroundColor3 = Config.Colors.Green
			end
		end)
	end
end

return ShopUI
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="30">
          <Properties>
            <string name="Name">SoundSystem</string>
            <string name="Source"><![CDATA[-- ============================================================
-- SOUND SYSTEM — Manages all game audio
-- Sound effects + looping background music
-- ============================================================

local SoundService = game:GetService("SoundService")

local SoundSystem = {}

-- Track current music
SoundSystem._currentMusic = nil
SoundSystem._musicVolume = 0.5
SoundSystem._initialized = false

-- Sound effect definitions
local SFX = {
	elimination_drumroll = { id = "rbxassetid://5765633489", volume = 0.8 },
	elimination_reveal   = { id = "rbxassetid://5765634832", volume = 0.8 },
	fight_alert          = { id = "rbxassetid://5765635476", volume = 0.7 },
	queen_crowning       = { id = "rbxassetid://5765636123", volume = 0.9 },
	vote_cast            = { id = "rbxassetid://421058925",  volume = 0.6 },
	check_in_success     = { id = "rbxassetid://421058925",  volume = 0.6 },
	director_chime       = { id = "rbxassetid://6042053626", volume = 0.7 },
	immunity_use         = { id = "rbxassetid://4612373815", volume = 0.7 },
	alliance_form        = { id = "rbxassetid://4612373815", volume = 0.6 },
	challenge_complete   = { id = "rbxassetid://5765634832", volume = 0.7 },
	ui_click             = { id = "rbxassetid://876939830",  volume = 0.4 },
	ui_open              = { id = "rbxassetid://876939830",  volume = 0.3 },
	notification         = { id = "rbxassetid://6042053626", volume = 0.5 },
}

-- Background music definitions
local MUSIC = {
	mansion_ambient      = { id = "rbxassetid://1837849285", volume = 0.3 },
	elimination_tension  = { id = "rbxassetid://1839841276", volume = 0.35 },
	celebration          = { id = "rbxassetid://1845554017", volume = 0.35 },
	drama_buildup        = { id = "rbxassetid://1836677817", volume = 0.3 },
}

-- ============================================================
-- INITIALIZATION
-- ============================================================

function SoundSystem.init()
	if SoundSystem._initialized then return end
	SoundSystem._initialized = true

	-- Create SFX folder under SoundService
	local sfxFolder = Instance.new("Folder")
	sfxFolder.Name = "SFX"
	sfxFolder.Parent = SoundService

	for name, data in SFX do
		local sound = Instance.new("Sound")
		sound.Name = name
		sound.SoundId = data.id
		sound.Volume = data.volume
		sound.Looped = false
		sound.Parent = sfxFolder
	end

	-- Create Music folder under SoundService
	local musicFolder = Instance.new("Folder")
	musicFolder.Name = "Music"
	musicFolder.Parent = SoundService

	for name, data in MUSIC do
		local sound = Instance.new("Sound")
		sound.Name = name
		sound.SoundId = data.id
		sound.Volume = data.volume * SoundSystem._musicVolume
		sound.Looped = true
		sound.Parent = musicFolder
	end

	print("[SoundSystem] Initialized — " .. tostring(#SFX) .. " SFX, " .. tostring(#MUSIC) .. " music tracks")
end

-- ============================================================
-- PLAY SOUND EFFECT
-- ============================================================

function SoundSystem.play(soundName)
	local sfxFolder = SoundService:FindFirstChild("SFX")
	if not sfxFolder then return end

	local sound = sfxFolder:FindFirstChild(soundName)
	if sound then
		sound:Play()
	else
		warn("[SoundSystem] Unknown SFX: " .. tostring(soundName))
	end
end

-- ============================================================
-- BACKGROUND MUSIC
-- ============================================================

function SoundSystem.playMusic(musicName)
	-- Stop current music first
	SoundSystem.stopMusic()

	local musicFolder = SoundService:FindFirstChild("Music")
	if not musicFolder then return end

	local sound = musicFolder:FindFirstChild(musicName)
	if sound then
		sound.Volume = (MUSIC[musicName] and MUSIC[musicName].volume or 0.3) * SoundSystem._musicVolume
		sound:Play()
		SoundSystem._currentMusic = sound
	else
		warn("[SoundSystem] Unknown music track: " .. tostring(musicName))
	end
end

function SoundSystem.stopMusic()
	if SoundSystem._currentMusic then
		SoundSystem._currentMusic:Stop()
		SoundSystem._currentMusic = nil
	end
end

function SoundSystem.setMusicVolume(vol)
	vol = math.clamp(vol, 0, 1)
	SoundSystem._musicVolume = vol

	-- Update currently playing music
	if SoundSystem._currentMusic then
		local name = SoundSystem._currentMusic.Name
		local baseVol = MUSIC[name] and MUSIC[name].volume or 0.3
		SoundSystem._currentMusic.Volume = baseVol * vol
	end
end

return SoundSystem
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="31">
          <Properties>
            <string name="Name">SpectatorSystem</string>
            <string name="Source"><![CDATA[-- ============================================================
-- SPECTATOR SYSTEM — Free-fly and follow-cam for eliminated players
-- Cycle between alive players, free-cam with WASD, Tab to toggle mode
-- ============================================================

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local camera = workspace.CurrentCamera

local Config = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Config"))

local SpectatorSystem = {}

-- State
SpectatorSystem._active = false
SpectatorSystem._mode = "follow" -- "follow" or "freecam"
SpectatorSystem._targetIndex = 1
SpectatorSystem._alivePlayers = {}
SpectatorSystem._freeCamCFrame = CFrame.new(100, 40, 0) -- starting position
SpectatorSystem._moveSpeed = 40
SpectatorSystem._renderConnection = nil
SpectatorSystem._inputConnection = nil
SpectatorSystem._spectatorHUD = nil

-- Movement keys state
SpectatorSystem._keys = {
	W = false,
	A = false,
	S = false,
	D = false,
	Space = false,
	LeftShift = false,
}

-- ============================================================
-- INITIALIZATION
-- ============================================================

function SpectatorSystem.init()
	-- Nothing to do on init — spectator mode is activated by server event
	print("[SpectatorSystem] Spectator system ready")
end

-- ============================================================
-- ENTER SPECTATOR MODE
-- ============================================================

function SpectatorSystem.enterSpectatorMode()
	if SpectatorSystem._active then return end
	SpectatorSystem._active = true
	SpectatorSystem._mode = "follow"
	SpectatorSystem._targetIndex = 1

	print("[SpectatorSystem] Entering spectator mode")

	-- Build alive player list
	SpectatorSystem._refreshAlivePlayers()

	-- Detach camera from character
	camera.CameraType = Enum.CameraType.Scriptable

	-- Create spectator HUD
	SpectatorSystem._createSpectatorHUD()

	-- Set up input handling
	SpectatorSystem._inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if gameProcessed then return end
		SpectatorSystem._handleInput(input)
	end)

	-- Track key releases for free-cam movement
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if not SpectatorSystem._active then return end
		if gameProcessed then return end
		local keyName = input.KeyCode.Name
		if SpectatorSystem._keys[keyName] ~= nil then
			SpectatorSystem._keys[keyName] = true
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if not SpectatorSystem._active then return end
		local keyName = input.KeyCode.Name
		if SpectatorSystem._keys[keyName] ~= nil then
			SpectatorSystem._keys[keyName] = false
		end
	end)

	-- Start render loop
	SpectatorSystem._renderConnection = RunService.RenderStepped:Connect(function(dt)
		SpectatorSystem._update(dt)
	end)

	-- Start following first alive player
	if #SpectatorSystem._alivePlayers > 0 then
		SpectatorSystem.followPlayer(SpectatorSystem._alivePlayers[1])
	else
		SpectatorSystem.freeCam()
	end
end

-- ============================================================
-- EXIT SPECTATOR MODE
-- ============================================================

function SpectatorSystem.exitSpectatorMode()
	if not SpectatorSystem._active then return end
	SpectatorSystem._active = false

	print("[SpectatorSystem] Exiting spectator mode")

	-- Disconnect render loop
	if SpectatorSystem._renderConnection then
		SpectatorSystem._renderConnection:Disconnect()
		SpectatorSystem._renderConnection = nil
	end

	-- Disconnect input
	if SpectatorSystem._inputConnection then
		SpectatorSystem._inputConnection:Disconnect()
		SpectatorSystem._inputConnection = nil
	end

	-- Reset camera
	camera.CameraType = Enum.CameraType.Custom
	if player.Character then
		camera.CameraSubject = player.Character:FindFirstChild("Humanoid")
	end

	-- Remove spectator HUD
	SpectatorSystem._removeSpectatorHUD()

	-- Reset key state
	for key in SpectatorSystem._keys do
		SpectatorSystem._keys[key] = false
	end
end

-- ============================================================
-- FOLLOW PLAYER MODE
-- ============================================================

function SpectatorSystem.followPlayer(targetPlayer)
	if not SpectatorSystem._active then return end
	if not targetPlayer then return end

	SpectatorSystem._mode = "follow"

	-- Find the target's character
	local character = targetPlayer.Character
	if character then
		local humanoid = character:FindFirstChild("Humanoid")
		if humanoid then
			camera.CameraType = Enum.CameraType.Custom
			camera.CameraSubject = humanoid
		end
	end

	-- Update HUD
	SpectatorSystem._updateHUD()
end

-- ============================================================
-- FREE CAM MODE
-- ============================================================

function SpectatorSystem.freeCam()
	if not SpectatorSystem._active then return end

	SpectatorSystem._mode = "freecam"
	camera.CameraType = Enum.CameraType.Scriptable

	-- Initialize free cam position from current camera
	SpectatorSystem._freeCamCFrame = camera.CFrame

	-- Update HUD
	SpectatorSystem._updateHUD()
end

-- ============================================================
-- CYCLE PLAYERS
-- ============================================================

function SpectatorSystem.nextPlayer()
	if not SpectatorSystem._active then return end

	SpectatorSystem._refreshAlivePlayers()
	if #SpectatorSystem._alivePlayers == 0 then return end

	SpectatorSystem._targetIndex = SpectatorSystem._targetIndex + 1
	if SpectatorSystem._targetIndex > #SpectatorSystem._alivePlayers then
		SpectatorSystem._targetIndex = 1
	end

	local target = SpectatorSystem._alivePlayers[SpectatorSystem._targetIndex]
	if target then
		SpectatorSystem.followPlayer(target)
	end
end

function SpectatorSystem.prevPlayer()
	if not SpectatorSystem._active then return end

	SpectatorSystem._refreshAlivePlayers()
	if #SpectatorSystem._alivePlayers == 0 then return end

	SpectatorSystem._targetIndex = SpectatorSystem._targetIndex - 1
	if SpectatorSystem._targetIndex < 1 then
		SpectatorSystem._targetIndex = #SpectatorSystem._alivePlayers
	end

	local target = SpectatorSystem._alivePlayers[SpectatorSystem._targetIndex]
	if target then
		SpectatorSystem.followPlayer(target)
	end
end

-- ============================================================
-- UPDATE LOOP
-- ============================================================

function SpectatorSystem._update(dt)
	if not SpectatorSystem._active then return end

	if SpectatorSystem._mode == "freecam" then
		-- Free-fly camera with WASD
		local moveDir = Vector3.new(0, 0, 0)

		if SpectatorSystem._keys.W then
			moveDir = moveDir + camera.CFrame.LookVector
		end
		if SpectatorSystem._keys.S then
			moveDir = moveDir - camera.CFrame.LookVector
		end
		if SpectatorSystem._keys.A then
			moveDir = moveDir - camera.CFrame.RightVector
		end
		if SpectatorSystem._keys.D then
			moveDir = moveDir + camera.CFrame.RightVector
		end
		if SpectatorSystem._keys.Space then
			moveDir = moveDir + Vector3.new(0, 1, 0)
		end
		if SpectatorSystem._keys.LeftShift then
			moveDir = moveDir - Vector3.new(0, 1, 0)
		end

		if moveDir.Magnitude > 0 then
			moveDir = moveDir.Unit * SpectatorSystem._moveSpeed * dt
			SpectatorSystem._freeCamCFrame = CFrame.new(SpectatorSystem._freeCamCFrame.Position + moveDir) * SpectatorSystem._freeCamCFrame.Rotation
		end

		-- Apply mouse rotation from UserInputService
		camera.CFrame = SpectatorSystem._freeCamCFrame

	elseif SpectatorSystem._mode == "follow" then
		-- Camera follows the target player (handled by CameraType.Custom)
		-- Just ensure the target is still valid
		if #SpectatorSystem._alivePlayers > 0 then
			local target = SpectatorSystem._alivePlayers[SpectatorSystem._targetIndex]
			if not target or not target.Parent or not target.Character then
				SpectatorSystem.nextPlayer()
			end
		end
	end
end

-- ============================================================
-- INPUT HANDLING
-- ============================================================

function SpectatorSystem._handleInput(input)
	if not SpectatorSystem._active then return end

	if input.KeyCode == Enum.KeyCode.E then
		SpectatorSystem.nextPlayer()

	elseif input.KeyCode == Enum.KeyCode.Q then
		SpectatorSystem.prevPlayer()

	elseif input.KeyCode == Enum.KeyCode.Tab then
		-- Toggle between free-cam and follow mode
		if SpectatorSystem._mode == "follow" then
			SpectatorSystem.freeCam()
		else
			-- Switch back to follow
			if #SpectatorSystem._alivePlayers > 0 then
				local target = SpectatorSystem._alivePlayers[SpectatorSystem._targetIndex]
				if target then
					SpectatorSystem.followPlayer(target)
				end
			end
		end
	end
end

-- ============================================================
-- ALIVE PLAYER LIST
-- ============================================================

function SpectatorSystem._refreshAlivePlayers()
	SpectatorSystem._alivePlayers = {}

	for _, p in Players:GetPlayers() do
		-- Skip self (we are spectating)
		if p ~= player and p.Character then
			-- Only add players who are not transparent (not spectators themselves)
			local hrp = p.Character:FindFirstChild("HumanoidRootPart")
			if hrp and hrp.Transparency < 0.5 then
				table.insert(SpectatorSystem._alivePlayers, p)
			end
		end
	end

	-- Clamp target index
	if SpectatorSystem._targetIndex > #SpectatorSystem._alivePlayers then
		SpectatorSystem._targetIndex = math.max(1, #SpectatorSystem._alivePlayers)
	end
end

-- ============================================================
-- SPECTATOR HUD
-- ============================================================

function SpectatorSystem._createSpectatorHUD()
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	-- Remove existing if any
	SpectatorSystem._removeSpectatorHUD()

	local hudFrame = Instance.new("Frame")
	hudFrame.Name = "SpectatorHUD"
	hudFrame.Size = UDim2.new(1, 0, 1, 0)
	hudFrame.BackgroundTransparency = 1
	hudFrame.BorderSizePixel = 0
	hudFrame.ZIndex = 5
	hudFrame.Parent = sg

	-- SPECTATOR watermark (semi-transparent, centered)
	local watermark = Instance.new("TextLabel")
	watermark.Name = "Watermark"
	watermark.Size = UDim2.new(0.4, 0, 0, 40)
	watermark.Position = UDim2.new(0.3, 0, 0.05, 0)
	watermark.BackgroundTransparency = 1
	watermark.Text = "SPECTATOR"
	watermark.TextColor3 = Config.Colors.Text
	watermark.TextTransparency = 0.6
	watermark.TextSize = 32
	watermark.Font = Enum.Font.GothamBold
	watermark.Parent = hudFrame

	-- Controls help text at bottom
	local controls = Instance.new("Frame")
	controls.Name = "ControlsHelp"
	controls.Size = UDim2.new(0.5, 0, 0, 70)
	controls.Position = UDim2.new(0.25, 0, 1, -140)
	controls.BackgroundColor3 = Config.Colors.Background
	controls.BackgroundTransparency = 0.4
	controls.BorderSizePixel = 0
	controls.Parent = hudFrame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 10)
	corner.Parent = controls

	local controlsText = Instance.new("TextLabel")
	controlsText.Name = "ControlsText"
	controlsText.Size = UDim2.new(0.9, 0, 1, 0)
	controlsText.Position = UDim2.new(0.05, 0, 0, 0)
	controlsText.BackgroundTransparency = 1
	controlsText.Text = "Q/E - Cycle players  |  Tab - Toggle free-cam\nWASD - Move (free-cam)  |  Space/Shift - Up/Down"
	controlsText.TextColor3 = Config.Colors.TextMuted
	controlsText.TextSize = 11
	controlsText.Font = Enum.Font.Gotham
	controlsText.TextWrapped = true
	controlsText.Parent = controls

	-- Target player info (who you're watching)
	local targetInfo = Instance.new("Frame")
	targetInfo.Name = "TargetInfo"
	targetInfo.Size = UDim2.new(0.3, 0, 0, 35)
	targetInfo.Position = UDim2.new(0.35, 0, 0, 60)
	targetInfo.BackgroundColor3 = Config.Colors.Surface
	targetInfo.BackgroundTransparency = 0.3
	targetInfo.BorderSizePixel = 0
	targetInfo.Parent = hudFrame

	local targetCorner = Instance.new("UICorner")
	targetCorner.CornerRadius = UDim.new(0, 8)
	targetCorner.Parent = targetInfo

	local targetLabel = Instance.new("TextLabel")
	targetLabel.Name = "TargetLabel"
	targetLabel.Size = UDim2.new(1, 0, 1, 0)
	targetLabel.BackgroundTransparency = 1
	targetLabel.Text = "Watching: ..."
	targetLabel.TextColor3 = Config.Colors.Pink
	targetLabel.TextSize = 12
	targetLabel.Font = Enum.Font.GothamBold
	targetLabel.Parent = targetInfo

	-- Mode indicator
	local modeLabel = Instance.new("TextLabel")
	modeLabel.Name = "ModeLabel"
	modeLabel.Size = UDim2.new(0.15, 0, 0, 22)
	modeLabel.Position = UDim2.new(0.425, 0, 0, 98)
	modeLabel.BackgroundColor3 = Config.Colors.Card
	modeLabel.BackgroundTransparency = 0.3
	modeLabel.Text = "FOLLOW"
	modeLabel.TextColor3 = Config.Colors.Gold
	modeLabel.TextSize = 10
	modeLabel.Font = Enum.Font.GothamBold
	modeLabel.Parent = hudFrame

	local modeCorner = Instance.new("UICorner")
	modeCorner.CornerRadius = UDim.new(0, 6)
	modeCorner.Parent = modeLabel

	SpectatorSystem._spectatorHUD = hudFrame
	SpectatorSystem._updateHUD()
end

function SpectatorSystem._removeSpectatorHUD()
	local sg = playerGui:FindFirstChild("MansionUI")
	if not sg then return end

	local existing = sg:FindFirstChild("SpectatorHUD")
	if existing then
		existing:Destroy()
	end
	SpectatorSystem._spectatorHUD = nil
end

function SpectatorSystem._updateHUD()
	if not SpectatorSystem._spectatorHUD then return end
	local hud = SpectatorSystem._spectatorHUD

	-- Update target label
	local targetInfo = hud:FindFirstChild("TargetInfo")
	if targetInfo then
		local targetLabel = targetInfo:FindFirstChild("TargetLabel")
		if targetLabel then
			if SpectatorSystem._mode == "follow" and #SpectatorSystem._alivePlayers > 0 then
				local target = SpectatorSystem._alivePlayers[SpectatorSystem._targetIndex]
				if target then
					targetLabel.Text = "Watching: " .. target.DisplayName .. " (" .. SpectatorSystem._targetIndex .. "/" .. #SpectatorSystem._alivePlayers .. ")"
				else
					targetLabel.Text = "Watching: ..."
				end
			elseif SpectatorSystem._mode == "freecam" then
				targetLabel.Text = "Free Camera"
			else
				targetLabel.Text = "No players to watch"
			end
		end
	end

	-- Update mode label
	local modeLabel = hud:FindFirstChild("ModeLabel")
	if modeLabel then
		if SpectatorSystem._mode == "follow" then
			modeLabel.Text = "FOLLOW"
			modeLabel.TextColor3 = Config.Colors.Gold
		else
			modeLabel.Text = "FREE CAM"
			modeLabel.TextColor3 = Config.Colors.Blue
		end
	end
end

return SpectatorSystem
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="32">
          <Properties>
            <string name="Name">TutorialSystem</string>
            <string name="Source"><![CDATA[-- ============================================================
-- TUTORIAL SYSTEM — First-join onboarding walkthrough
-- Step-by-step overlay with dark background + highlighted text
-- ============================================================

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local Config = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Config"))
local SoundSystem = require(script.Parent.SoundSystem)

local TutorialSystem = {}

-- Platform detection for adaptive sizing
local isTouch = UserInputService.TouchEnabled
local BASE_TEXT_SCALE = isTouch and 1.25 or 1.0
local MIN_BUTTON_SIZE = isTouch and 48 or 36

-- Tutorial steps
local STEPS = {
	{
		title = "Welcome to Mansion of Mayhem!",
		body = "You've just moved into the most dramatic mansion in Roblox. "
			.. "Compete, scheme, and survive to become Queen of the Mansion!",
		highlight = nil,
	},
	{
		title = "Explore the Mansion",
		body = "Walk around to discover themed rooms like The Crown Suite, "
			.. "Velvet Noir, Neon Paradise, and more. Each room has a unique vibe!",
		highlight = nil,
	},
	{
		title = "Form Alliances",
		body = "Team up with other players for protection. But watch out — "
			.. "alliances can be broken! Tap the ALLY tab to manage your crew.",
		highlight = nil,
	},
	{
		title = "Daily Check-In",
		body = "Tap CHECK IN every day to earn XP and build your streak. "
			.. "Hit a 7-day streak for an Immunity Shard!",
		highlight = nil,
	},
	{
		title = "The Tea Wall",
		body = "Got secrets? Post confessions on the Tea Wall for everyone to see. "
			.. "Read the drama, spill the tea, stir the pot!",
		highlight = nil,
	},
	{
		title = "Survive Elimination",
		body = "Each round, players vote to eliminate someone. Use Immunity Tokens "
			.. "to protect yourself. Collect 3 shards to earn a token!",
		highlight = nil,
	},
	{
		title = "Become Queen!",
		body = "The player with the most XP, alliances, and strategy earns the crown. "
			.. "Reign supreme — until someone takes it from you!",
		highlight = nil,
	},
}

-- ============================================================
-- CHECK IF TUTORIAL NEEDED
-- ============================================================

function TutorialSystem.shouldShow()
	local attr = player:GetAttribute("TutorialComplete")
	return not attr
end

-- ============================================================
-- SHOW TUTORIAL
-- ============================================================

function TutorialSystem.show()
	if not TutorialSystem.shouldShow() then return end

	local sg = Instance.new("ScreenGui")
	sg.Name = "TutorialUI"
	sg.ResetOnSpawn = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.DisplayOrder = 100 -- Above all other UI
	sg.Parent = playerGui

	-- Dark overlay background
	local overlay = Instance.new("Frame")
	overlay.Name = "Overlay"
	overlay.Size = UDim2.new(1, 0, 1, 0)
	overlay.BackgroundColor3 = Color3.new(0, 0, 0)
	overlay.BackgroundTransparency = 0.5
	overlay.BorderSizePixel = 0
	overlay.ZIndex = 50
	overlay.Parent = sg

	-- Content card
	local card = Instance.new("Frame")
	card.Name = "TutorialCard"
	card.Size = UDim2.new(0.5, 0, 0.45, 0)
	card.Position = UDim2.new(0.25, 0, 0.275, 0)
	card.BackgroundColor3 = Config.Colors.Surface
	card.BorderSizePixel = 0
	card.ZIndex = 51
	card.Parent = sg

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 16)
	corner.Parent = card

	local stroke = Instance.new("UIStroke")
	stroke.Color = Config.Colors.Gold
	stroke.Thickness = 2
	stroke.Parent = card

	-- Step counter (e.g., "1 / 7")
	local stepCounter = Instance.new("TextLabel")
	stepCounter.Name = "StepCounter"
	stepCounter.Size = UDim2.new(1, 0, 0, 24)
	stepCounter.Position = UDim2.new(0, 0, 0, 10)
	stepCounter.BackgroundTransparency = 1
	stepCounter.Text = "1 / " .. #STEPS
	stepCounter.TextColor3 = Config.Colors.TextMuted
	stepCounter.TextSize = math.floor(11 * BASE_TEXT_SCALE)
	stepCounter.Font = Enum.Font.Gotham
	stepCounter.ZIndex = 52
	stepCounter.Parent = card

	-- Title
	local title = Instance.new("TextLabel")
	title.Name = "Title"
	title.Size = UDim2.new(0.85, 0, 0, 40)
	title.Position = UDim2.new(0.075, 0, 0, 40)
	title.BackgroundTransparency = 1
	title.Text = ""
	title.TextColor3 = Config.Colors.Gold
	title.TextSize = math.floor(22 * BASE_TEXT_SCALE)
	title.Font = Enum.Font.GothamBold
	title.TextWrapped = true
	title.ZIndex = 52
	title.Parent = card

	-- Body text
	local body = Instance.new("TextLabel")
	body.Name = "Body"
	body.Size = UDim2.new(0.85, 0, 0.4, 0)
	body.Position = UDim2.new(0.075, 0, 0, 90)
	body.BackgroundTransparency = 1
	body.Text = ""
	body.TextColor3 = Config.Colors.Text
	body.TextSize = math.floor(14 * BASE_TEXT_SCALE)
	body.Font = Enum.Font.Gotham
	body.TextWrapped = true
	body.TextYAlignment = Enum.TextYAlignment.Top
	body.ZIndex = 52
	body.Parent = card

	-- Progress dots
	local dotsFrame = Instance.new("Frame")
	dotsFrame.Name = "Dots"
	dotsFrame.Size = UDim2.new(0.5, 0, 0, 12)
	dotsFrame.Position = UDim2.new(0.25, 0, 1, -60)
	dotsFrame.BackgroundTransparency = 1
	dotsFrame.ZIndex = 52
	dotsFrame.Parent = card

	local dotsLayout = Instance.new("UIListLayout")
	dotsLayout.FillDirection = Enum.FillDirection.Horizontal
	dotsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
	dotsLayout.Padding = UDim.new(0, 8)
	dotsLayout.Parent = dotsFrame

	for i = 1, #STEPS do
		local dot = Instance.new("Frame")
		dot.Name = "Dot_" .. i
		dot.Size = UDim2.new(0, 10, 0, 10)
		dot.BackgroundColor3 = Config.Colors.Border
		dot.BorderSizePixel = 0
		dot.ZIndex = 52
		dot.Parent = dotsFrame

		local dotCorner = Instance.new("UICorner")
		dotCorner.CornerRadius = UDim.new(1, 0)
		dotCorner.Parent = dot
	end

	-- Next button
	local nextBtnHeight = math.max(MIN_BUTTON_SIZE, 36)
	local nextBtn = Instance.new("TextButton")
	nextBtn.Name = "NextBtn"
	nextBtn.Size = UDim2.new(0.35, 0, 0, nextBtnHeight)
	nextBtn.Position = UDim2.new(0.55, 0, 1, -(nextBtnHeight + 12))
	nextBtn.BackgroundColor3 = Config.Colors.Pink
	nextBtn.Text = "Next"
	nextBtn.TextColor3 = Color3.new(1, 1, 1)
	nextBtn.TextSize = math.floor(14 * BASE_TEXT_SCALE)
	nextBtn.Font = Enum.Font.GothamBold
	nextBtn.ZIndex = 52
	nextBtn.Parent = card

	local nextCorner = Instance.new("UICorner")
	nextCorner.CornerRadius = UDim.new(0, 8)
	nextCorner.Parent = nextBtn

	-- Skip button
	local skipBtn = Instance.new("TextButton")
	skipBtn.Name = "SkipBtn"
	skipBtn.Size = UDim2.new(0.35, 0, 0, nextBtnHeight)
	skipBtn.Position = UDim2.new(0.1, 0, 1, -(nextBtnHeight + 12))
	skipBtn.BackgroundTransparency = 1
	skipBtn.Text = "Skip Tutorial"
	skipBtn.TextColor3 = Config.Colors.TextMuted
	skipBtn.TextSize = math.floor(12 * BASE_TEXT_SCALE)
	skipBtn.Font = Enum.Font.GothamBold
	skipBtn.ZIndex = 52
	skipBtn.Parent = card

	-- State
	local currentStep = 1

	local function updateStep()
		local step = STEPS[currentStep]
		title.Text = step.title
		body.Text = step.body
		stepCounter.Text = currentStep .. " / " .. #STEPS

		-- Update dots
		for i = 1, #STEPS do
			local dot = dotsFrame:FindFirstChild("Dot_" .. i)
			if dot then
				dot.BackgroundColor3 = (i == currentStep) and Config.Colors.Pink or Config.Colors.Border
			end
		end

		-- Update button text on last step
		if currentStep == #STEPS then
			nextBtn.Text = "Let's Go!"
			nextBtn.BackgroundColor3 = Config.Colors.Gold
		else
			nextBtn.Text = "Next"
			nextBtn.BackgroundColor3 = Config.Colors.Pink
		end

		-- Animate card entrance
		card.Position = UDim2.new(0.25, 0, 0.3, 0)
		card.BackgroundTransparency = 0.1
		TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.25, 0, 0.275, 0),
			BackgroundTransparency = 0,
		}):Play()
	end

	local function completeTutorial()
		SoundSystem.play("ui_click")
		player:SetAttribute("TutorialComplete", true)

		-- Fade out
		TweenService:Create(overlay, TweenInfo.new(0.4), {
			BackgroundTransparency = 1,
		}):Play()
		TweenService:Create(card, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {
			Position = UDim2.new(0.25, 0, 1.2, 0),
		}):Play()

		task.delay(0.5, function()
			sg:Destroy()
		end)
	end

	nextBtn.MouseButton1Click:Connect(function()
		SoundSystem.play("ui_click")
		if currentStep < #STEPS then
			currentStep += 1
			updateStep()
		else
			completeTutorial()
		end
	end)

	skipBtn.MouseButton1Click:Connect(function()
		completeTutorial()
	end)

	-- Show first step
	updateStep()
	SoundSystem.play("notification")
end

return TutorialSystem
]]></string>
          </Properties>
        </Item>
      </Item>
    </Item>
  </Item>
</roblox>